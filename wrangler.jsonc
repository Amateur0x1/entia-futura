{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "entia-futura",
  "compatibility_date": "2025-04-05",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
