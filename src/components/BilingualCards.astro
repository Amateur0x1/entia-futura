---
interface Item {
  zhTitle: string;
  enTitle: string;
  zhBody: string;
  enBody: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="cards-grid">
  {items.map((item) => (
    <article class="mini-card">
      <h3>{item.zhTitle}</h3>
      <span class="en">{item.enTitle}</span>
      <div class="dual-grid">
        <div class="lang-block">
          <h3>中文</h3>
          <p>{item.zhBody}</p>
        </div>
        <div class="lang-block">
          <h3>English</h3>
          <p>{item.enBody}</p>
        </div>
      </div>
    </article>
  ))}
</div>
