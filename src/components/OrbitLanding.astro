---
import { toLocalePath, type Locale } from '../i18n/config';

interface Props {
  locale?: Locale;
}

const { locale = 'zh' } = Astro.props;
---

<section class="landing-system">
  <div class="floating-brand-cluster" data-brand-cluster>
    <!-- Logo buttons intentionally avoid sheen classes; motion is GSAP-only for now. -->
    <a
      class="floating-brand-button floating-nameplate-button"
      data-brand-logo-button
      data-brand-cluster-button
      href={toLocalePath(locale, '/')}
    >
      <span data-brand-animated-text>Entia Futura</span>
      <small data-brand-animated-text>未来人研究所</small>
    </a>
    <a
      class="floating-brand-button floating-more-button"
      data-brand-cluster-button
      href={toLocalePath(locale, '/about')}
    >
      <span>more</span>
    </a>
  </div>
  <a class="floating-brand-button floating-sheen-button floating-contact-button" href={toLocalePath(locale, '/contact')}>
    <span>Contact</span>
  </a>

  <section class="calibration-stage" data-calibration-root>
    <div class="calibration-frame" data-orbit-frame>
      <div class="hero-video-shell" data-hero-video-shell>
        <div class="hero-video-loading" data-hero-video-loading aria-hidden="true"></div>
        <video
          class="hero-video hero-video-scroll"
          data-scroll-video
          src="/videos/portal-scroll.mp4"
          muted
          playsinline
          preload="auto"
        ></video>
        <video
          class="hero-video hero-video-loop"
          data-loop-video
          src="/videos/portal-loop.webm"
          autoplay
          loop
          muted
          playsinline
          preload="auto"
        ></video>
        <div class="hero-video-overlay" aria-hidden="true"></div>
        <div class="hero-video-vignette" aria-hidden="true"></div>
      </div>
    </div>
  </section>
</section>

<script>
  import gsap from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const sheenButtons = Array.from(document.querySelectorAll('.floating-sheen-button')).filter(
    (button) => button instanceof HTMLElement,
  );
  const resetSheen = (button) => {
    button.classList.remove('is-sheen-entering', 'is-sheen-leaving');
  };
  const restartSheen = (button, className) => {
    resetSheen(button);
    void button.offsetWidth;
    button.classList.add(className);
  };

  sheenButtons.forEach((button) => {
    button.addEventListener('animationend', (event) => {
      if (!(event.target instanceof HTMLElement)) {
        return;
      }

      if (event.animationName === 'floating-nameplate-sheen-enter') {
        button.classList.remove('is-sheen-entering');
      }

      if (event.animationName === 'floating-nameplate-sheen-leave') {
        button.classList.remove('is-sheen-leaving');
      }
    });
  });

  const getAnimatedTextNodes = (button) =>
    Array.from(button.querySelectorAll('[data-brand-animated-text]')).filter((node) => node instanceof HTMLElement);

  if (!prefersReducedMotion) {
    const brandCluster = document.querySelector('[data-brand-cluster]');
    const logoButton =
      brandCluster instanceof HTMLElement
        ? brandCluster.querySelector('[data-brand-logo-button]')
        : null;
    const logoTextNodes = logoButton instanceof HTMLElement ? getAnimatedTextNodes(logoButton) : [];
    const standaloneButtons = sheenButtons.filter((button) => !button.hasAttribute('data-brand-cluster-button'));
    /*
    const clusterDelay = 960;
    let clusterTimers = [];

    const clearClusterTimers = () => {
      clusterTimers.forEach((timer) => window.clearTimeout(timer));
      clusterTimers = [];
    };

    const playClusterSheen = (className) => {
      clearClusterTimers();

      clusterButtons.forEach((button, index) => {
        const startSheen = () => restartSheen(button, className);
        const delay = index * clusterDelay;

        if (delay === 0) {
          startSheen();
          return;
        }

        const timer = window.setTimeout(startSheen, delay);
        clusterTimers.push(timer);
      });
    };
    */

    const playTextRotate = (elements, delay = 0) => {
      if (elements.length === 0) {
        return;
      }

      gsap.killTweensOf(elements);
      gsap.set(elements, {
        rotationX: 0,
        rotationY: 0,
        rotationZ: 0,
        yPercent: 0,
        textShadow: '0 0 0 rgba(185, 202, 208, 0)',
      });

      gsap
        .timeline({ delay })
        .to(elements, {
          rotationX: -72,
          rotationY: 10,
          rotationZ: -4,
          yPercent: -18,
          textShadow: '0 6px 18px rgba(185, 202, 208, 0.22)',
          duration: 0.18,
          ease: 'power2.in',
          stagger: 0.06,
        })
        .to(elements, {
          rotationX: 0,
          rotationY: 0,
          rotationZ: 0,
          yPercent: 0,
          textShadow: '0 0 0 rgba(185, 202, 208, 0)',
          duration: 0.58,
          ease: 'back.out(1.7)',
          stagger: 0.06,
        });
    };

    const triggerLogoTextMotion = () => {
      playTextRotate(logoTextNodes);
    };

    standaloneButtons.forEach((button) => {
      button.addEventListener('pointerenter', () => {
        restartSheen(button, 'is-sheen-entering');
      });

      button.addEventListener('pointerleave', () => {
        restartSheen(button, 'is-sheen-leaving');
      });

      button.addEventListener('focus', () => {
        restartSheen(button, 'is-sheen-entering');
      });

      button.addEventListener('blur', () => {
        restartSheen(button, 'is-sheen-leaving');
      });
    });

    if (brandCluster instanceof HTMLElement) {
      const setClusterActive = (active) => {
        brandCluster.classList.toggle('is-cluster-active', active);
      };

      brandCluster.addEventListener('pointerenter', () => {
        setClusterActive(true);
      });

      brandCluster.addEventListener('pointerleave', () => {
        setClusterActive(false);
        // playClusterSheen('is-sheen-leaving');
      });

      brandCluster.addEventListener('focusin', () => {
        if (!brandCluster.classList.contains('is-cluster-active')) {
          setClusterActive(true);
          // playClusterSheen('is-sheen-entering');
          playClusterTextEffect();
        }
      });

      brandCluster.addEventListener('focusout', (event) => {
        const nextTarget = event.relatedTarget;

        if (nextTarget instanceof Node && brandCluster.contains(nextTarget)) {
          return;
        }

        setClusterActive(false);
        // playClusterSheen('is-sheen-leaving');
      });
    }

    if (logoButton instanceof HTMLElement) {
      logoButton.addEventListener('pointerenter', triggerLogoTextMotion);
      logoButton.addEventListener('focus', triggerLogoTextMotion);
    }
  }
</script>

<style>
  .landing-system {
    position: relative;
  }

  .floating-brand-cluster {
    position: fixed;
    top: max(1rem, calc(env(safe-area-inset-top) + 0.5rem));
    left: max(1rem, calc(env(safe-area-inset-left) + 0.5rem));
    z-index: 12;
    display: inline-flex;
    align-items: center;
    gap: 0;
    --brand-button-fg: var(--color-text-primary);
    --brand-button-highlight-opacity: 0;
    will-change: transform;
    animation: floating-brand-drift 14s ease-in-out infinite;
  }

  .floating-brand-button {
    position: relative;
    display: inline-grid;
    align-items: center;
    justify-content: center;
    width: fit-content;
    max-width: 100%;
    gap: 0.2rem;
    justify-items: center;
    text-align: center;
    min-height: 50px;
    padding: 0.56rem 0.9rem 0.62rem;
    border: 0;
    border-radius: 18px;
    background: transparent;
    color: var(--brand-button-fg);
    text-decoration: none;
    -webkit-font-smoothing: antialiased;
    transition: color 180ms ease;
    perspective: 960px;
    transform-style: preserve-3d;
  }

  .floating-sheen-button {
    position: relative;
    overflow: clip;
    isolation: isolate;
  }

  .floating-sheen-button::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-action-secondary-bg) 82%, var(--color-brand-mint) 18%),
      color-mix(in srgb, var(--color-action-secondary-bg) 92%, black 8%)
    );
    opacity: var(--brand-button-highlight-opacity);
    pointer-events: none;
    transition: opacity 180ms ease;
    z-index: 0;
  }

  .floating-sheen-button::after {
    content: '';
    position: absolute;
    inset: -35%;
    background: linear-gradient(135deg, transparent 38%, rgba(255, 255, 255, 0.34) 50%, transparent 62%);
    pointer-events: none;
    opacity: 0;
    transform: translate3d(-28%, -28%, 0);
    will-change: transform, opacity;
    z-index: 2;
  }

  .floating-contact-button {
    position: fixed;
    top: max(1rem, calc(env(safe-area-inset-top) + 0.5rem));
    left: auto;
    right: max(1rem, calc(env(safe-area-inset-right) + 0.5rem));
    z-index: 12;
    --brand-button-fg: var(--color-text-primary);
    --brand-button-highlight-opacity: 0;
    will-change: transform;
    animation: floating-brand-drift 14s ease-in-out infinite;
  }

  .floating-brand-button > span,
  .floating-brand-button > small {
    position: relative;
    z-index: 1;
  }

  [data-brand-animated-text] {
    color: var(--brand-button-fg);
    transform-origin: 50% 60%;
    transform-style: preserve-3d;
    backface-visibility: hidden;
    will-change: transform, text-shadow;
  }

  .floating-brand-button span {
    display: block;
    font-family: 'POIRETONE-REGULAR', "Helvetica Neue", Arial, sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
  }

  .floating-brand-button small {
    display: block;
    color: color-mix(in srgb, var(--brand-button-fg) 54%, transparent);
    font-family: 'POIRETONE-REGULAR', "Hiragino Sans GB", "Noto Sans SC", sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    line-height: 1;
    font-weight: 400;
    white-space: nowrap;
    letter-spacing: 0.8em;
  }

  small[data-brand-animated-text] {
    color: color-mix(in srgb, var(--brand-button-fg) 54%, transparent);
  }

  .floating-more-button {
    align-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 82px;
    min-height: 38px;
    padding-block: 0.36rem;
    padding-inline: 1rem;
    box-shadow: inset 0 0 0 1px var(--color-border-default);
    transition: color 180ms ease, box-shadow 180ms ease;
  }

  .floating-more-button span {
    letter-spacing: 0.18em;
    line-height: 1;
    text-transform: none;
    transform: translateY(-2px);
  }

  .floating-more-button:hover,
  .floating-more-button:focus-visible {
    box-shadow: inset 0 0 0 1px var(--color-border-strong);
  }

  .floating-brand-cluster:hover,
  .floating-brand-cluster:focus-within,
  .floating-brand-cluster.is-cluster-active {
    --brand-button-fg: var(--color-text-primary);
    --brand-button-highlight-opacity: 0;
  }

  .floating-contact-button:hover,
  .floating-contact-button:focus-visible {
    --brand-button-fg: var(--color-action-secondary-fg);
    --brand-button-highlight-opacity: 1;
  }

  .floating-sheen-button.is-sheen-entering::after {
    animation: floating-nameplate-sheen-enter 900ms ease forwards;
  }

  .floating-sheen-button.is-sheen-leaving::after {
    animation: floating-nameplate-sheen-leave 900ms ease forwards;
  }

  @keyframes floating-brand-drift {
    0% {
      transform: translate3d(0, 0, 0);
    }

    33% {
      transform: translate3d(2px, -2px, 0);
    }

    66% {
      transform: translate3d(-1px, 2px, 0);
    }

    100% {
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes floating-nameplate-sheen-enter {
    0% {
      opacity: 0;
      transform: translate3d(-28%, -28%, 0);
    }

    14% {
      opacity: 1;
    }

    38% {
      opacity: 0.82;
    }

    62% {
      opacity: 0.56;
      transform: translate3d(12%, 12%, 0);
    }

    82% {
      opacity: 0.28;
    }

    100% {
      opacity: 0;
      transform: translate3d(28%, 28%, 0);
    }
  }

  @keyframes floating-nameplate-sheen-leave {
    0% {
      opacity: 0;
      transform: translate3d(28%, 28%, 0);
    }

    16% {
      opacity: 0.72;
    }

    42% {
      opacity: 0.58;
    }

    68% {
      opacity: 0.32;
      transform: translate3d(-10%, -10%, 0);
    }

    100% {
      opacity: 0;
      transform: translate3d(-28%, -28%, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-brand-cluster,
    .floating-contact-button {
      animation: none;
    }

    .floating-sheen-button::after {
      display: none;
    }
  }

  .calibration-stage {
    position: relative;
    min-height: 100svh;
    margin-inline: calc(50% - 50vw);
    width: 100vw;
  }

  .calibration-frame {
    min-height: 100svh;
    overflow: clip;
    isolation: isolate;
  }

  .hero-video-shell {
    position: relative;
    width: 100%;
    min-height: 100svh;
    overflow: clip;
    background: var(--gradient-hero-stage);
    isolation: isolate;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video-scroll {
    filter: var(--filter-hero-scroll);
  }

  .hero-video-loop {
    opacity: 0;
    filter: var(--filter-hero-loop);
  }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero-overlay);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero-video-vignette {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero-vignette);
    pointer-events: none;
  }

  .hero-video-loading {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: var(--gradient-loading-screen);
    transition: opacity 320ms ease;
  }

  .hero-video-loading.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .floating-brand-cluster {
      top: max(0.8rem, calc(env(safe-area-inset-top) + 0.35rem));
      left: max(0.8rem, calc(env(safe-area-inset-left) + 0.35rem));
      gap: 0;
    }

    .floating-brand-button {
      max-width: calc(100vw - 1.6rem);
      min-height: 46px;
      padding: 0.5rem 0.8rem 0.54rem;
      border-radius: 16px;
    }

    .floating-brand-button span {
      font-size: 0.94rem;
    }

    .floating-brand-button small {
      font-size: 0.54rem;
    }

    .floating-more-button {
      min-width: 64px;
      min-height: 34px;
      padding-block: 0.3rem;
      padding-inline: 0.72rem;
    }

    .floating-more-button span {
      letter-spacing: 0.14em;
      transform: translateY(-0.5px);
    }

    .floating-contact-button {
      top: max(0.8rem, calc(env(safe-area-inset-top) + 0.35rem));
      left: auto;
      right: max(0.8rem, calc(env(safe-area-inset-right) + 0.35rem));
    }
  }
</style>
