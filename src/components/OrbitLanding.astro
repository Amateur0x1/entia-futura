---
import { toLocalePath, type Locale } from '../i18n/config';

interface Props {
  locale?: Locale;
}

const { locale = 'zh' } = Astro.props;
---

<section class="landing-system">
  <div class="floating-brand-cluster" data-brand-cluster>
    <!-- Logo buttons intentionally avoid sheen classes; motion is GSAP-only for now. -->
    <a
      class="floating-base-button floating-nameplate-button"
      data-brand-logo-button
      data-brand-cluster-button
      href={toLocalePath(locale, '/')}
    >
      <span data-brand-animated-text>Entia Futura</span>
      <small data-brand-animated-text>未来人研究所</small>
    </a>
  </div>
  <a class="floating-base-button floating-button floating-contact-button" data-brand-contact-button href={toLocalePath(locale, '/contact')}>
    <i class="floating-more-fill" data-contact-fill aria-hidden="true"></i>
    <span style="transform: translateY(-0.5px)">Contact</span>
  </a>
  <button class="floating-know-more-button" data-know-more-button type="button" aria-label="Know more">
    <span>KNOW MORE</span>
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M12 16.2 5.8 10l1.4-1.4L12 13.4l4.8-4.8 1.4 1.4z"></path>
    </svg>
  </button>

  <section class="calibration-stage" data-calibration-root>
    <div class="calibration-frame" data-orbit-frame>
      <div class="hero-video-shell" data-hero-video-shell>
        <div class="hero-video-loading" data-hero-video-loading aria-hidden="true"></div>
        <video
          class="hero-video hero-video-scroll"
          data-scroll-video
          src="/videos/portal-scroll.mp4"
          muted
          playsinline
          preload="auto"
        ></video>
        <video
          class="hero-video hero-video-loop"
          data-loop-video
          src="/videos/portal-loop.webm"
          autoplay
          loop
          muted
          playsinline
          preload="auto"
        ></video>
        <div class="hero-video-overlay" aria-hidden="true"></div>
        <div class="hero-video-vignette" aria-hidden="true"></div>
      </div>
    </div>
  </section>
</section>

<script>
  import gsap from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const knowMoreButton = document.querySelector('[data-know-more-button]');
  const sheenButtons = Array.from(document.querySelectorAll('.floating-sheen-button')).filter(
    (button) => button instanceof HTMLElement,
  );
  const resetSheen = (button) => {
    button.classList.remove('is-sheen-entering', 'is-sheen-leaving');
  };
  const restartSheen = (button, className) => {
    resetSheen(button);
    void button.offsetWidth;
    button.classList.add(className);
  };

  sheenButtons.forEach((button) => {
    button.addEventListener('animationend', (event) => {
      if (!(event.target instanceof HTMLElement)) {
        return;
      }

      if (event.animationName === 'floating-nameplate-sheen-enter') {
        button.classList.remove('is-sheen-entering');
      }

      if (event.animationName === 'floating-nameplate-sheen-leave') {
        button.classList.remove('is-sheen-leaving');
      }
    });
  });

  const getAnimatedTextNodes = (button) =>
    Array.from(button.querySelectorAll('[data-brand-animated-text]')).filter((node) => node instanceof HTMLElement);

  if (!prefersReducedMotion) {
    const brandCluster = document.querySelector('[data-brand-cluster]');
    const logoButton =
      brandCluster instanceof HTMLElement
        ? brandCluster.querySelector('[data-brand-logo-button]')
        : null;
    const moreButton =
      brandCluster instanceof HTMLElement
        ? brandCluster.querySelector('[data-brand-more-button]')
        : null;
    const moreFill =
      moreButton instanceof HTMLElement
        ? moreButton.querySelector('[data-more-fill]')
        : null;
    const contactButton = document.querySelector('[data-brand-contact-button]');
    const contactFill =
      contactButton instanceof HTMLElement
        ? contactButton.querySelector('[data-contact-fill]')
        : null;
    const logoTextNodes = logoButton instanceof HTMLElement ? getAnimatedTextNodes(logoButton) : [];
    const standaloneButtons = sheenButtons.filter((button) => !button.hasAttribute('data-brand-cluster-button'));
    /*
    const clusterDelay = 960;
    let clusterTimers = [];

    const clearClusterTimers = () => {
      clusterTimers.forEach((timer) => window.clearTimeout(timer));
      clusterTimers = [];
    };

    const playClusterSheen = (className) => {
      clearClusterTimers();

      clusterButtons.forEach((button, index) => {
        const startSheen = () => restartSheen(button, className);
        const delay = index * clusterDelay;

        if (delay === 0) {
          startSheen();
          return;
        }

        const timer = window.setTimeout(startSheen, delay);
        clusterTimers.push(timer);
      });
    };
    */

    const playTextRotate = (elements, delay = 0) => {
      if (elements.length === 0) {
        return;
      }

      gsap.killTweensOf(elements);
      gsap.set(elements, {
        rotationX: 0,
        rotationY: 0,
        rotationZ: 0,
        yPercent: 0,
        textShadow: '0 0 0 rgba(185, 202, 208, 0)',
      });

      gsap
        .timeline({ delay })
        .to(elements, {
          rotationX: -72,
          rotationY: 10,
          rotationZ: -4,
          yPercent: -18,
          textShadow: '0 6px 18px rgba(185, 202, 208, 0.22)',
          duration: 0.18,
          ease: 'power2.in',
          stagger: 0.06,
        })
        .to(elements, {
          rotationX: 0,
          rotationY: 0,
          rotationZ: 0,
          yPercent: 0,
          textShadow: '0 0 0 rgba(185, 202, 208, 0)',
          duration: 0.58,
          ease: 'back.out(1.7)',
          stagger: 0.06,
        });
    };

    const triggerLogoTextMotion = () => {
      playTextRotate(logoTextNodes);
    };

    const getMoreFillMetrics = (button, originX, originY) => {
      const { width, height } = button.getBoundingClientRect();
      const maxX = Math.max(originX, width - originX);
      const maxY = Math.max(originY, height - originY);
      const radius = Math.hypot(maxX, maxY);

      return {
        diameter: radius * 2,
        x: originX - radius,
        y: originY - radius,
      };
    };
    const moreFillStartScale = 0.016;

    const setMoreFilled = (filled) => {
      if (moreButton instanceof HTMLElement) {
        moreButton.classList.toggle('is-more-filled', filled);
      }
    };

    const expandMoreFill = (originX, originY) => {
      if (!(moreButton instanceof HTMLElement) || !(moreFill instanceof HTMLElement)) {
        return;
      }

      const { diameter, x, y } = getMoreFillMetrics(moreButton, originX, originY);

      gsap.killTweensOf(moreFill);
      gsap.set(moreFill, {
        width: diameter,
        height: diameter,
        x,
        y,
        scale: moreFillStartScale,
        opacity: 1,
      });
      setMoreFilled(true);

      gsap.to(moreFill, {
        scale: 1,
        duration: 0.6,
        ease: 'power2.out',
      });
    };

    const collapseMoreFill = () => {
      if (!(moreButton instanceof HTMLElement) || !(moreFill instanceof HTMLElement)) {
        return;
      }

      gsap.killTweensOf(moreFill);
      gsap.to(moreFill, {
        scale: moreFillStartScale,
        opacity: 0,
        duration: 0.28,
        ease: 'power2.in',
        onComplete: () => {
          setMoreFilled(false);
        },
      });
    };

    const setContactFilled = (filled) => {
      if (contactButton instanceof HTMLElement) {
        contactButton.classList.toggle('is-more-filled', filled);
      }
    };

    const expandContactFill = (originX, originY) => {
      if (!(contactButton instanceof HTMLElement) || !(contactFill instanceof HTMLElement)) {
        return;
      }

      const { diameter, x, y } = getMoreFillMetrics(contactButton, originX, originY);

      gsap.killTweensOf(contactFill);
      gsap.set(contactFill, {
        width: diameter,
        height: diameter,
        x,
        y,
        scale: moreFillStartScale,
        opacity: 1,
      });
      setContactFilled(true);

      gsap.to(contactFill, {
        scale: 1,
        duration: 0.6,
        ease: 'power2.out',
      });
    };

    const collapseContactFill = () => {
      if (!(contactButton instanceof HTMLElement) || !(contactFill instanceof HTMLElement)) {
        return;
      }

      gsap.killTweensOf(contactFill);
      gsap.to(contactFill, {
        scale: moreFillStartScale,
        opacity: 0,
        duration: 0.28,
        ease: 'power2.in',
        onComplete: () => {
          setContactFilled(false);
        },
      });
    };

    standaloneButtons.forEach((button) => {
      button.addEventListener('pointerenter', () => {
        restartSheen(button, 'is-sheen-entering');
      });

      button.addEventListener('pointerleave', () => {
        restartSheen(button, 'is-sheen-leaving');
      });

      button.addEventListener('focus', () => {
        restartSheen(button, 'is-sheen-entering');
      });

      button.addEventListener('blur', () => {
        restartSheen(button, 'is-sheen-leaving');
      });
    });

    if (brandCluster instanceof HTMLElement) {
      const setClusterActive = (active) => {
        brandCluster.classList.toggle('is-cluster-active', active);
      };

      brandCluster.addEventListener('pointerenter', () => {
        setClusterActive(true);
      });

      brandCluster.addEventListener('pointerleave', () => {
        setClusterActive(false);
        // playClusterSheen('is-sheen-leaving');
      });

      brandCluster.addEventListener('focusin', () => {
        if (!brandCluster.classList.contains('is-cluster-active')) {
          setClusterActive(true);
          // playClusterSheen('is-sheen-entering');
        }
      });

      brandCluster.addEventListener('focusout', (event) => {
        const nextTarget = event.relatedTarget;

        if (nextTarget instanceof Node && brandCluster.contains(nextTarget)) {
          return;
        }

        setClusterActive(false);
        // playClusterSheen('is-sheen-leaving');
      });
    }

    if (logoButton instanceof HTMLElement) {
      logoButton.addEventListener('pointerenter', triggerLogoTextMotion);
      logoButton.addEventListener('focus', triggerLogoTextMotion);
    }

    if (moreButton instanceof HTMLElement) {
      moreButton.addEventListener('pointerenter', (event) => {
        const rect = moreButton.getBoundingClientRect();
        expandMoreFill(event.clientX - rect.left, event.clientY - rect.top);
      });

      moreButton.addEventListener('pointerleave', () => {
        collapseMoreFill();
      });

      moreButton.addEventListener('focus', () => {
        const rect = moreButton.getBoundingClientRect();
        expandMoreFill(rect.width / 2, rect.height / 2);
      });

      moreButton.addEventListener('blur', () => {
        collapseMoreFill();
      });
    }

    if (contactButton instanceof HTMLElement) {
      contactButton.addEventListener('pointerenter', (event) => {
        const rect = contactButton.getBoundingClientRect();
        expandContactFill(event.clientX - rect.left, event.clientY - rect.top);
      });

      contactButton.addEventListener('pointerleave', () => {
        collapseContactFill();
      });

      contactButton.addEventListener('focus', () => {
        const rect = contactButton.getBoundingClientRect();
        expandContactFill(rect.width / 2, rect.height / 2);
      });

      contactButton.addEventListener('blur', () => {
        collapseContactFill();
      });
    }

    if (knowMoreButton instanceof HTMLElement) {
      gsap.to(knowMoreButton, {
        y: 8,
        duration: 1.25,
        ease: 'sine.inOut',
        repeat: -1,
        yoyo: true,
      });
    }
  }

  if (knowMoreButton instanceof HTMLElement) {
    knowMoreButton.addEventListener('click', () => {
      const nextPanel = document.querySelector('[data-next-panel]');
      const nextPanelTop =
        nextPanel instanceof HTMLElement
          ? nextPanel.getBoundingClientRect().top + window.scrollY
          : window.innerHeight;
      const startY = window.scrollY;
      const distance = Math.max(nextPanelTop - startY, 0);

      if (distance < 4) {
        return;
      }

      if (prefersReducedMotion) {
        window.scrollTo({ top: nextPanelTop });
        return;
      }

      const duration = Math.min(3200, Math.max(1800, distance * 0.9));
      const startTime = performance.now();
      const easeInOutCubic = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

      const step = (currentTime: number) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = easeInOutCubic(progress);
        const y = startY + distance * eased;

        window.scrollTo({ top: y });

        if (progress < 1) {
          window.requestAnimationFrame(step);
        }
      };

      window.requestAnimationFrame(step);
    });
  }
</script>

<style>
  .landing-system {
    position: relative;
  }

  .floating-brand-cluster {
    position: fixed;
    top: max(1rem, calc(env(safe-area-inset-top) + 0.5rem));
    left: max(1rem, calc(env(safe-area-inset-left) + 0.5rem));
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0;
    --brand-button-fg: var(--color-text-primary);
    --brand-button-highlight-opacity: 0;
    will-change: transform;
    animation: floating-brand-drift 14s ease-in-out infinite;
  }

  .floating-base-button {
    position: relative;
    display: inline-grid;
    align-items: center;
    justify-content: center;
    width: fit-content;
    max-width: 100%;
    gap: 0.2rem;
    justify-items: center;
    text-align: center;
    min-height: 50px;
    padding: 0.56rem 0.9rem 0.62rem;
    border: 0;
    border-radius: 18px;
    background: transparent;
    color: var(--brand-button-fg);
    text-decoration: none;
    -webkit-font-smoothing: antialiased;
    transition: color 180ms ease;
    perspective: 960px;
    transform-style: preserve-3d;
  }

  .floating-contact-button {
    position: fixed;
    top: max(1.3rem, calc(env(safe-area-inset-top) + 1rem));
    left: auto;
    right: max(1rem, calc(env(safe-area-inset-right) + 0.5rem));
    z-index: 60;
    will-change: transform;
    animation: floating-brand-drift 14s ease-in-out infinite;
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
    box-shadow:
      inset 0 0 0 2px color-mix(in srgb, var(--color-secondary) 30%, transparent),
      0 0 10px color-mix(in srgb, var(--color-secondary) 18%, transparent);
  }

  .floating-know-more-button {
    position: fixed;
    left: 50%;
    bottom: max(1.8rem, calc(env(safe-area-inset-bottom) + 1.2rem));
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.62rem 1rem 0.6rem;
    border: 1.5px solid color-mix(in srgb, var(--color-primary) 62%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
    box-shadow: 0 0 14px color-mix(in srgb, var(--color-primary) 24%, transparent);
    transform: translateX(-50%);
    font-family: 'POIRETONE-REGULAR', "Helvetica Neue", Arial, sans-serif;
    letter-spacing: 0.16em;
    line-height: 1;
    cursor: pointer;
    transition: background 180ms ease, box-shadow 180ms ease, color 180ms ease;
  }

  .floating-know-more-button span {
    font-size: 0.84rem;
  }

  .floating-know-more-button svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    transform: translateY(1px);
  }

  .floating-know-more-button:hover,
  .floating-know-more-button:focus-visible {
    background: color-mix(in srgb, var(--color-primary) 20%, transparent);
    box-shadow: 0 0 18px color-mix(in srgb, var(--color-primary) 34%, transparent);
    color: color-mix(in srgb, var(--color-primary) 86%, white 14%);
  }

  .floating-base-button > span,
  .floating-base-button > small {
    position: relative;
    z-index: 1;
  }

  [data-brand-animated-text] {
    color: var(--brand-button-fg);
    transform-origin: 50% 60%;
    transform-style: preserve-3d;
    backface-visibility: hidden;
    will-change: transform, text-shadow;
  }

  .floating-base-button span {
    display: block;
    font-family: 'POIRETONE-REGULAR', "Helvetica Neue", Arial, sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
  }

  .floating-base-button small {
    display: block;
    color: color-mix(in srgb, var(--brand-button-fg) 54%, transparent);
    font-family: 'POIRETONE-REGULAR', "Hiragino Sans GB", "Noto Sans SC", sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    line-height: 1;
    font-weight: 400;
    white-space: nowrap;
    letter-spacing: 0.8em;
  }

  small[data-brand-animated-text] {
    color: color-mix(in srgb, var(--brand-button-fg) 54%, transparent);
  }

  .floating-button {
    border-radius: 12px;
    align-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 82px;
    min-height: 38px;
    padding-block: 0.36rem;
    padding-inline: 1rem;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      inset 0 0 0 2px var(--color-border-accent-soft),
      0 0 10px color-mix(in srgb, var(--color-secondary) 18%, transparent);
    transition: color 180ms ease, box-shadow 180ms ease;
  }

  .floating-more-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    border-radius: 999px;
    background: var(--color-secondary);
    opacity: 0;
    pointer-events: none;
    transform: translate3d(0, 0, 0) scale(0.016);
    transform-origin: 50% 50%;
    will-change: transform, opacity;
    z-index: 0;
  }

  .floating-button span {
    position: relative;
    z-index: 1;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: none;
    transform: translateY(-2px);
  }

  .floating-button.is-more-filled,
  .floating-button:hover,
  .floating-button:focus-visible {
    color: var(--color-secondary-foreground);
    box-shadow:
      inset 0 0 0 2px var(--color-border-accent-medium),
      0 0 16px color-mix(in srgb, var(--color-secondary) 30%, transparent);
  }

  .floating-contact-button.is-more-filled,
  .floating-contact-button:hover,
  .floating-contact-button:focus-visible {
    box-shadow:
      inset 0 0 0 2px var(--color-secondary),
      0 0 16px color-mix(in srgb, var(--color-secondary) 34%, transparent);
  }

  .floating-brand-cluster:hover,
  .floating-brand-cluster:focus-within,
  .floating-brand-cluster.is-cluster-active {
    --brand-button-fg: var(--color-text-primary);
    --brand-button-highlight-opacity: 0;
  }

  @keyframes floating-brand-drift {
    0% {
      transform: translate3d(0, 0, 0);
    }

    33% {
      transform: translate3d(2px, -2px, 0);
    }

    66% {
      transform: translate3d(-1px, 2px, 0);
    }

    100% {
      transform: translate3d(0, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-brand-cluster,
    .floating-contact-button {
      animation: none;
    }
  }

  .calibration-stage {
    position: relative;
    min-height: 340svh;
    margin-inline: calc(50% - 50vw);
    width: 100vw;
  }

  .calibration-frame {
    position: sticky;
    top: 0;
    height: 100svh;
    min-height: 100svh;
    overflow: clip;
    isolation: isolate;
  }

  .hero-video-shell {
    position: relative;
    width: 100%;
    min-height: 100svh;
    overflow: clip;
    background: var(--gradient-hero-stage);
    isolation: isolate;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video-scroll {
    filter: var(--filter-hero-scroll);
  }

  .hero-video-loop {
    opacity: 0;
    filter: var(--filter-hero-loop);
  }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero-overlay);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero-video-vignette {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero-vignette);
    pointer-events: none;
  }

  .hero-video-loading {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: var(--gradient-loading-screen);
    transition: opacity 320ms ease;
  }

  .hero-video-loading.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .calibration-stage {
      min-height: 300svh;
    }

    .floating-brand-cluster {
      top: max(0.8rem, calc(env(safe-area-inset-top) + 0.35rem));
      left: max(0.8rem, calc(env(safe-area-inset-left) + 0.35rem));
      gap: 0;
    }

    .floating-base-button {
      max-width: calc(100vw - 1.6rem);
      min-height: 46px;
      padding: 0.5rem 0.8rem 0.54rem;
      border-radius: 16px;
    }

    .floating-base-button span {
      font-size: 0.94rem;
    }

    .floating-base-button small {
      font-size: 0.54rem;
    }

    .floating-button {
      min-width: 64px;
      min-height: 34px;
      padding-block: 0.3rem;
      padding-inline: 0.72rem;
      border-radius: 10px;
    }

    .floating-button span {
      letter-spacing: 0.14em;
      transform: translateY(-0.5px);
    }

    .floating-contact-button {
      top: max(1rem, calc(env(safe-area-inset-top) + 0.5rem));
      left: auto;
      right: max(0.8rem, calc(env(safe-area-inset-right) + 0.35rem));
    }

    .floating-know-more-button {
      bottom: max(1.2rem, calc(env(safe-area-inset-bottom) + 0.7rem));
      padding: 0.54rem 0.84rem 0.52rem;
      gap: 0.42rem;
    }

    .floating-know-more-button span {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
    }

  }
</style>
