---
import {
  collaborationFormsEn,
  collaborationFormsZh,
  joinWaysEn,
  joinWaysZh,
  practiceItems,
  programs,
  publicationCategoriesEn,
  publicationCategoriesZh,
  researchAreas,
  siteMeta,
  ventureItems,
} from '../content/site';
import { pickByLocale, toLocalePath, type Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const questions = pickByLocale(
  locale,
  [
    '未来我们将如何学习，而不只是被工具加速？',
    '当组织越来越智能，人如何保有判断力与方向感？',
    '品牌何时不再只是传播对象，而是共同体的接口？',
    '我们会在怎样的空间里工作、居住、连接与思考？',
    '当技术进入日常，什么样的生活方式值得被发明？',
  ],
  [
    'How shall we learn, rather than merely be accelerated by tools?',
    'As organizations grow more intelligent, how do humans keep judgment and orientation?',
    'When does a brand stop being a message and become an interface for collective life?',
    'What kinds of spaces will hold our work, dwelling, connection, and thought?',
    'As technology enters the everyday, what forms of life are still worth inventing?',
  ],
);

const signalCards = pickByLocale(
  locale,
  [
    {
      eyebrow: 'research archive',
      title: '问题并不直接进入现实，而先进入长期积累的研究档案。',
    },
    {
      eyebrow: 'translation layer',
      title: '研究在这里被转成方法、叙事、活动、空间与组织接口。',
    },
    {
      eyebrow: 'initiatives',
      title: '最后才以出版、驻留、实验、合作与公共计划的形式发生。',
    },
  ],
  [
    {
      eyebrow: 'research archive',
      title: 'Questions do not enter reality directly. They first accumulate in an archive of inquiry.',
    },
    {
      eyebrow: 'translation layer',
      title: 'Research is translated here into methods, narratives, programs, spaces, and organizational interfaces.',
    },
    {
      eyebrow: 'initiatives',
      title: 'Only then does it take form as publications, residencies, experiments, collaborations, and public programs.',
    },
  ],
);

const archiveItems = [
  ...programs.slice(0, 3).map((item) => pickByLocale(locale, item.zhTitle, item.enTitle)),
  ...practiceItems.slice(0, 2).map((item) => pickByLocale(locale, item.zhTitle, item.enTitle)),
];

const translationItems = [
  ...practiceItems.slice(0, 3).map((item) => pickByLocale(locale, item.zhTitle, item.enTitle)),
  pickByLocale(locale, '公共活动', 'Public Programs'),
  pickByLocale(locale, '空间脚本', 'Spatial Scripts'),
];

const initiativeItems = [
  ...ventureItems.slice(0, 3).map((item) => pickByLocale(locale, item.zhTitle, item.enTitle)),
  pickByLocale(locale, '出版计划', 'Publication Programs'),
  pickByLocale(locale, '长期合作', 'Long-term Collaboration'),
];

const interfaceCards = [
  {
    eyebrow: pickByLocale(locale, '研究成果', 'Publications'),
    title: pickByLocale(locale, '研究、评论、档案与出版计划。', 'Research outputs, commentary, archives, and publication plans.'),
    items: pickByLocale(locale, publicationCategoriesZh.slice(0, 4), publicationCategoriesEn.slice(0, 4)),
    href: toLocalePath(locale, '/publications'),
    cta: pickByLocale(locale, '查看成果', 'View publications'),
  },
  {
    eyebrow: pickByLocale(locale, '合作方式', 'Collaboration'),
    title: pickByLocale(locale, '联合研究、内容共创、地方合作与实验性合作。', 'Joint research, co-created content, place-based work, and experimental collaboration.'),
    items: pickByLocale(locale, collaborationFormsZh.slice(0, 4), collaborationFormsEn.slice(0, 4)),
    href: toLocalePath(locale, '/collaboration'),
    cta: pickByLocale(locale, '发起合作', 'Start collaboration'),
  },
  {
    eyebrow: pickByLocale(locale, '加入方式', 'Participation'),
    title: pickByLocale(locale, '活动、社群、共创项目、提案与驻留入口。', 'Events, community entry points, co-created projects, proposals, and residencies.'),
    items: pickByLocale(locale, joinWaysZh.slice(0, 4), joinWaysEn.slice(0, 4)),
    href: toLocalePath(locale, '/join-us'),
    cta: pickByLocale(locale, '了解参与', 'Explore participation'),
  },
];
---

<section class="landing-system" data-landing-system>
  <div class="landing-atmosphere" aria-hidden="true"></div>

  <section class="calibration-stage" data-calibration-root>
    <div class="calibration-frame" data-orbit-frame>
      <div class="calibration-copy">
        <h1>{pickByLocale(locale, siteMeta.coreQuestionZh, siteMeta.coreQuestionEn)}</h1>
        <p class="calibration-lede">{pickByLocale(locale, siteMeta.oneLineZh, siteMeta.oneLineEn)}</p>

        <div class="cta-row calibration-actions">
          <a class="button primary" href={toLocalePath(locale, '/research')}>
            {pickByLocale(locale, '进入研究', 'Enter Research')}
          </a>
          <a class="button secondary" href={toLocalePath(locale, '/programs')}>
            {pickByLocale(locale, '查看机制', 'View Programs')}
          </a>
          <a class="button secondary" href={toLocalePath(locale, '/collaboration')}>
            {pickByLocale(locale, '发起合作', 'Start Collaboration')}
          </a>
        </div>

        <div class="signal-stack">
          {signalCards.map((card) => (
            <article class="signal-card" data-signal-note>
              <p>{card.eyebrow}</p>
              <h2>{card.title}</h2>
            </article>
          ))}
        </div>
      </div>

      <div class="instrument-stage">
        <div class="instrument-shell">
          <div class="instrument-depth instrument-depth-a" aria-hidden="true"></div>
          <div class="instrument-depth instrument-depth-b" aria-hidden="true"></div>

          <div class="orbit-assembly" data-orbit-assembly>
            <div class="orbit-plane orbit-plane-back" aria-hidden="true">
              <div class="orbit-ring orbit-ring-back"></div>
            </div>

            <div class="orbit-logo-layer" data-logo-layer>
              <div class="orbit-logo-shadow" aria-hidden="true"></div>
              <img class="orbit-logo-image" src="/brand/entia-logo-cutout.png" alt="Entia Futura logo" />
            </div>

            <div class="orbit-plane orbit-plane-front" aria-hidden="true">
              <div class="orbit-ring orbit-ring-front"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="index-stage section-card" data-reveal>
    <div class="section-heading">
      <p class="eyebrow">{pickByLocale(locale, '01 / 问题被重新编目', '01 / Questions Re-indexed')}</p>
      <h2>{pickByLocale(locale, '问题不是栏目标题，而是研究入口。', 'Questions are not menu labels, but entrances into inquiry.')}</h2>
      <p>
        {pickByLocale(
          locale,
          '首页不直接陈列卖点，而是把核心问题重新索引为持续展开的研究领域。',
          'The homepage does not list selling points. It re-indexes core questions into ongoing fields of inquiry.',
        )}
      </p>
    </div>

    <div class="index-grid">
      <div class="question-column">
        {questions.map((question, index) => (
          <article class="question-fragment">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{question}</p>
          </article>
        ))}
      </div>

      <div class="field-grid">
        {researchAreas.map((area, index) => (
          <article class="field-card">
            <p>{String(index + 1).padStart(2, '0')}</p>
            <h3>{pickByLocale(locale, area.zhTitle, area.enTitle)}</h3>
            <p>{pickByLocale(locale, area.zhBody, area.enBody)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="transformation-stage" data-transform-section>
    <div class="transformation-pin" data-transform-pin>
      <div class="transformation-header">
        <p class="eyebrow">{pickByLocale(locale, '02 / 从研究到实践', '02 / From Inquiry to Practice')}</p>
        <h2>{pickByLocale(locale, '纵向滚动驱动一条横向转译链。', 'Vertical scrolling drives a horizontal chain of translation.')}</h2>
        <p>
          {pickByLocale(
            locale,
            '这不是三栏介绍，而是把研究材料如何被转成现实形式的机构方法做成一条可被观看的动态结构线。',
            'This is not a three-column explainer. It turns the institute’s method of translating research into reality into a visible moving structure.',
          )}
        </p>
      </div>

      <div class="transformation-shell">
        <div class="transform-axis" aria-hidden="true">
          <span class="transform-axis-line"></span>
          <span class="transform-axis-node"></span>
          <span class="transform-axis-node"></span>
          <span class="transform-axis-node"></span>
        </div>

        <div class="transform-viewport" data-transform-viewport>
          <div class="transform-track" data-transform-track>
            <article class="transform-panel transform-panel-archive" data-transform-panel>
              <div class="transform-panel-meta">
                <span>01</span>
                <p>{pickByLocale(locale, 'RESEARCH ARCHIVE', 'RESEARCH ARCHIVE')}</p>
              </div>
              <h3>{pickByLocale(locale, '访谈、观察、档案与研究计划在这里沉积。', 'Interviews, observation, archives, and research plans accumulate here.')}</h3>
              <div class="transform-token-grid">
                {archiveItems.map((item) => (
                  <span class="transform-token">{item}</span>
                ))}
              </div>
            </article>

            <article class="transform-panel transform-panel-translation" data-transform-panel>
              <div class="transform-panel-meta">
                <span>02</span>
                <p>{pickByLocale(locale, 'TRANSLATION LAYER', 'TRANSLATION LAYER')}</p>
              </div>
              <h3>{pickByLocale(locale, '研究在这里被转译为方法、叙事、活动、空间与组织接口。', 'Research is translated here into methods, narratives, programs, spaces, and organizational interfaces.')}</h3>
              <div class="transform-token-grid">
                {translationItems.map((item) => (
                  <span class="transform-token">{item}</span>
                ))}
              </div>
            </article>

            <article class="transform-panel transform-panel-initiatives" data-transform-panel>
              <div class="transform-panel-meta">
                <span>03</span>
                <p>{pickByLocale(locale, 'INITIATIVES', 'INITIATIVES')}</p>
              </div>
              <h3>{pickByLocale(locale, '最后才成为出版、驻留、实验、协作与面向现实的未来项目。', 'Only then does it take form as publications, residencies, experiments, collaborations, and future-facing initiatives.')}</h3>
              <div class="transform-token-grid">
                {initiativeItems.map((item) => (
                  <span class="transform-token">{item}</span>
                ))}
              </div>
            </article>
          </div>
        </div>
      </div>

      <p class="transform-caption">
        {pickByLocale(
          locale,
          '纵向滚动在这一段不再向下翻页，而是推动研究材料、转译机制与现实形式在同一条轴线上横向流动。',
          'In this passage, vertical scroll no longer flips downward. It pushes research material, translation mechanisms, and real-world forms across the same horizontal axis.',
        )}
      </p>
    </div>
  </section>

  <section class="interfaces-stage section-card" data-reveal>
    <div class="section-heading">
      <p class="eyebrow">{pickByLocale(locale, '03 / 现实接口', '03 / Interfaces')}</p>
      <h2>{pickByLocale(locale, '当抽象研究回到现实，就变成这些入口。', 'When abstract research returns to reality, it becomes these interfaces.')}</h2>
      <p>
        {pickByLocale(
          locale,
          '在机构气质之后，用户仍然需要清楚的去路。出版、合作与参与方式应该是可立即进入的接口。',
          'After the institutional atmosphere is established, users still need clear routes. Publications, collaboration, and participation must remain immediate interfaces.',
        )}
      </p>
    </div>

    <div class="interfaces-grid">
      {interfaceCards.map((card) => (
        <article class="interface-card">
          <p class="interface-card-eyebrow">{card.eyebrow}</p>
          <h3>{card.title}</h3>
          <ul>
            {card.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a class="button secondary" href={card.href}>{card.cta}</a>
        </article>
      ))}
    </div>
  </section>
</section>

<style>
  .landing-system {
    position: relative;
    display: grid;
    gap: 2rem;
  }

  .landing-atmosphere {
    position: absolute;
    inset: -6rem 0 auto;
    height: 52rem;
    pointer-events: none;
    background:
      radial-gradient(circle at 16% 24%, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0) 18rem),
      radial-gradient(circle at 52% 20%, rgba(255, 244, 90, 0.22), rgba(255, 244, 90, 0) 24rem),
      radial-gradient(circle at 84% 28%, rgba(95, 53, 255, 0.12), rgba(95, 53, 255, 0) 22rem);
    filter: blur(2px);
  }

  .calibration-stage {
    position: relative;
    min-height: 100svh;
  }

  .calibration-frame {
    position: relative;
    display: grid;
    grid-template-columns: minmax(18rem, 1.05fr) minmax(22rem, 1.25fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: center;
    min-height: calc(100svh - 5rem);
    padding: clamp(2rem, 4vh, 3rem) 0 clamp(2rem, 4vh, 3rem);
  }

  .calibration-copy {
    display: grid;
    gap: 1.4rem;
    align-content: center;
    max-width: 34rem;
  }

  .calibration-copy h1 {
    margin: 0;
    font-size: clamp(3.1rem, 7.4vw, 6.8rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
  }

  html[lang^='zh'] .calibration-copy h1 {
    font-family: 'EntiaTitleZh', "Hiragino Sans GB", "Noto Sans SC", sans-serif;
    font-weight: 400;
  }

  html[lang='en'] .calibration-copy h1 {
    font-family: 'EntiaTitleEn', "Helvetica Neue", Arial, sans-serif;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .calibration-lede {
    margin: 0;
    max-width: 30rem;
    color: rgba(23, 23, 23, 0.78);
    font-size: 1.04rem;
    line-height: 1.85;
  }

  .calibration-actions {
    margin-top: 0.4rem;
  }

  .signal-stack {
    display: grid;
    gap: 0.9rem;
    margin-top: 1rem;
  }

  .signal-card {
    padding: 1rem 1.1rem 1.1rem;
    border: 1px solid rgba(22, 22, 22, 0.12);
    border-radius: 1.25rem;
    background: linear-gradient(180deg, rgba(200, 212, 220, 0.84), rgba(183, 199, 210, 0.56));
    box-shadow: 0 20px 42px rgba(22, 22, 22, 0.08);
    backdrop-filter: blur(16px);
  }

  .signal-card p {
    margin: 0 0 0.55rem;
    color: var(--accent-2);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .signal-card h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.68;
  }

  .instrument-stage {
    display: grid;
    gap: 1.5rem;
    justify-items: center;
  }

  .instrument-shell {
    position: relative;
    width: min(100%, 44rem);
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
  }

  .instrument-depth {
    position: absolute;
    border-radius: 50%;
    filter: blur(16px);
    pointer-events: none;
  }

  .instrument-depth-a {
    width: 72%;
    aspect-ratio: 1 / 1;
    background: radial-gradient(circle, rgba(255, 244, 90, 0.22), rgba(255, 244, 90, 0));
  }

  .instrument-depth-b {
    width: 92%;
    aspect-ratio: 1 / 1;
    background: radial-gradient(circle, rgba(95, 53, 255, 0.12), rgba(95, 53, 255, 0));
  }

  .orbit-assembly {
    --orbit-flow: 0deg;
    position: relative;
    width: min(100%, 46rem);
    aspect-ratio: 1 / 1;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .orbit-plane {
    position: absolute;
    inset: 0;
  }

  .orbit-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 92%;
    height: 52%;
    border-radius: 50%;
    transform: translate(-50%, -50%) rotateX(72deg);
    transform-style: preserve-3d;
  }

  .orbit-ring::before,
  .orbit-ring::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .orbit-ring::before {
    inset: 7%;
    border: 2px solid rgba(22, 22, 22, 0.24);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.28) inset,
      0 0 0 8px rgba(255, 244, 90, 0.05) inset,
      0 0 28px rgba(255, 244, 90, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0) 40%),
      linear-gradient(90deg, rgba(95, 53, 255, 0.08), rgba(255, 244, 90, 0.08));
    -webkit-mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 1.1rem),
      #000 calc(100% - 1rem) calc(100% - 0.36rem),
      transparent calc(100% - 0.16rem)
    );
    mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 1.1rem),
      #000 calc(100% - 1rem) calc(100% - 0.36rem),
      transparent calc(100% - 0.16rem)
    );
  }

  .orbit-ring::after {
    inset: 7%;
    opacity: 0.96;
    background:
      conic-gradient(
        from -92deg,
        rgba(255, 255, 255, 0.18) 0deg,
        rgba(255, 255, 255, 0.12) 74deg,
        rgba(255, 244, 90, 0.12) 146deg,
        rgba(255, 255, 255, 0.16) 228deg,
        rgba(255, 255, 255, 0.22) 304deg,
        rgba(255, 255, 255, 0.18) 360deg
      ),
      conic-gradient(
        from calc(var(--orbit-flow) - 92deg),
        rgba(255, 255, 255, 0) 0deg,
        rgba(255, 255, 255, 0) 286deg,
        rgba(255, 255, 255, 0.14) 304deg,
        rgba(255, 255, 255, 0.82) 320deg,
        rgba(255, 244, 90, 0.98) 334deg,
        rgba(255, 244, 90, 0.46) 348deg,
        rgba(255, 255, 255, 0.06) 356deg,
        rgba(255, 255, 255, 0) 360deg
      );
    -webkit-mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 1.1rem),
      #000 calc(100% - 1rem) calc(100% - 0.36rem),
      transparent calc(100% - 0.16rem)
    );
    mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 1.1rem),
      #000 calc(100% - 1rem) calc(100% - 0.36rem),
      transparent calc(100% - 0.16rem)
    );
    filter: blur(0.4px);
  }

  .orbit-plane-back {
    z-index: 1;
    clip-path: inset(0 0 46% 0);
  }

  .orbit-plane-front {
    z-index: 4;
    clip-path: inset(46% 0 0 0);
  }

  .orbit-plane-front .orbit-ring::before {
    border-color: rgba(22, 22, 22, 0.34);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.34) inset,
      0 0 0 12px rgba(255, 244, 90, 0.06) inset,
      0 16px 28px rgba(22, 22, 22, 0.12),
      0 0 34px rgba(255, 244, 90, 0.18);
  }

  .orbit-plane-back .orbit-ring::after {
    opacity: 0.42;
    filter: blur(0.8px);
  }

  .orbit-plane-front .orbit-ring::after {
    opacity: 1;
    filter: blur(0.3px);
  }

  .orbit-logo-layer {
    position: absolute;
    inset: 50% auto auto 50%;
    z-index: 3;
    width: clamp(13.5rem, 30vw, 20rem);
    aspect-ratio: 1 / 1;
    transform: translate(-50%, -50%);
    will-change: transform;
  }

  .orbit-logo-shadow {
    position: absolute;
    left: 16%;
    right: 16%;
    bottom: 10%;
    height: 1.15rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(22, 22, 22, 0.28), rgba(22, 22, 22, 0));
    filter: blur(8px);
  }

  .orbit-logo-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter:
      drop-shadow(0 18px 34px rgba(22, 22, 22, 0.16))
      drop-shadow(0 0 20px rgba(255, 244, 90, 0.16));
  }

  .index-stage,
  .interfaces-stage {
    padding: 1rem 0 0;
    border-top: 1px solid rgba(22, 22, 22, 0.14);
  }

  .index-stage {
    display: grid;
    gap: 1.6rem;
  }

  .index-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 1.4rem 2rem;
    align-items: start;
  }

  .question-column {
    display: grid;
    gap: 0.8rem;
  }

  .question-fragment {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(22, 22, 22, 0.12);
  }

  .question-fragment span {
    color: var(--accent-2);
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .question-fragment p {
    margin: 0;
    font-size: clamp(1rem, 1.7vw, 1.24rem);
    line-height: 1.72;
  }

  .field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .field-card {
    min-height: 15rem;
    padding: 1.1rem 1.15rem 1.2rem;
    border: 1px solid rgba(22, 22, 22, 0.12);
    border-radius: 1.35rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(183, 199, 210, 0.28));
    box-shadow: 0 20px 44px rgba(22, 22, 22, 0.06);
  }

  .field-card p:first-child {
    margin: 0 0 0.8rem;
    color: var(--accent-2);
    font-size: 0.76rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .field-card h3 {
    margin: 0 0 0.65rem;
    font-size: 1.12rem;
    font-weight: 400;
    line-height: 1.45;
  }

  .field-card p:last-child {
    margin: 0;
    color: rgba(22, 22, 22, 0.78);
    line-height: 1.7;
  }

  .transformation-stage {
    position: relative;
    min-height: 100svh;
    padding-top: 0.8rem;
  }

  .transformation-pin {
    display: grid;
    gap: 1.6rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(22, 22, 22, 0.14);
  }

  .transformation-header {
