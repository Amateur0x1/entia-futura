<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const lenis = new Lenis({
      duration: 1.08,
      smoothWheel: true,
      wheelMultiplier: 0.92,
      touchMultiplier: 1.02,
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });

    gsap.ticker.lagSmoothing(0);
  }

  const revealSection = (section, index) => {
    const element = section;
    const heading = element.querySelector('.section-heading');
    const eyebrow = element.querySelector('.eyebrow');
    const title = element.querySelector('.section-heading h2, .section-heading h1');
    const subcopy = element.querySelector('.section-heading p:last-of-type');
    const cards = element.querySelectorAll('.field-card, .interface-card, .question-fragment');
    const buttons = element.querySelectorAll('.button');

    gsap.fromTo(
      element,
      {
        autoAlpha: 0,
      },
      {
        autoAlpha: 1,
        duration: 0.35,
        ease: 'none',
        delay: index === 0 ? 0.1 : 0,
        scrollTrigger: {
          trigger: element,
          start: 'top 88%',
          once: true,
        },
      },
    );

    if (heading) {
      gsap.fromTo(
        heading,
        {
          y: 72,
          clipPath: 'inset(0 0 100% 0)',
        },
        {
          y: 0,
          clipPath: 'inset(0 0 0% 0)',
          duration: 1.15,
          ease: 'power4.out',
          scrollTrigger: {
            trigger: element,
            start: 'top 76%',
            once: true,
          },
        },
      );
    }

    if (eyebrow) {
      gsap.fromTo(
        eyebrow,
        {
          x: -24,
          autoAlpha: 0,
        },
        {
          x: 0,
          autoAlpha: 1,
          duration: 0.78,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: element,
            start: 'top 78%',
            once: true,
          },
        },
      );
    }

    if (title) {
      gsap.fromTo(
        title,
        {
          y: 44,
          autoAlpha: 0,
        },
        {
          y: 0,
          autoAlpha: 1,
          duration: 0.95,
          ease: 'power4.out',
          scrollTrigger: {
            trigger: element,
            start: 'top 74%',
            once: true,
          },
        },
      );
    }

    if (subcopy) {
      gsap.fromTo(
        subcopy,
        {
          y: 28,
          autoAlpha: 0,
        },
        {
          y: 0,
          autoAlpha: 1,
          duration: 0.82,
          delay: 0.04,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: element,
            start: 'top 72%',
            once: true,
          },
        },
      );
    }

    if (cards.length > 0) {
      gsap.fromTo(
        cards,
        {
          autoAlpha: 0,
          y: 64,
        },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.95,
          stagger: 0.1,
          ease: 'power4.out',
          scrollTrigger: {
            trigger: element,
            start: 'top 68%',
            once: true,
          },
        },
      );
    }

    if (buttons.length > 0) {
      gsap.fromTo(
        buttons,
        {
          autoAlpha: 0,
          y: 18,
        },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.75,
          stagger: 0.08,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: element,
            start: 'top 66%',
            once: true,
          },
        },
      );
    }
  };

  const calibrationRoot = document.querySelector('[data-calibration-root]');
  const calibrationFrame = calibrationRoot?.querySelector('[data-orbit-frame]');
  const heroVideoShell = calibrationRoot?.querySelector('[data-hero-video-shell]');
  const scrollVideo = calibrationRoot?.querySelector('[data-scroll-video]');
  const loopVideo = calibrationRoot?.querySelector('[data-loop-video]');
  const heroVideoLoading = calibrationRoot?.querySelector('[data-hero-video-loading]');
  const portalShell = calibrationRoot?.querySelector('[data-future-portal-shell]');
  const signalCards = calibrationRoot?.querySelectorAll('[data-signal-note]');
  const primaryVisual =
    portalShell instanceof HTMLElement
      ? portalShell
      : heroVideoShell instanceof HTMLElement
        ? heroVideoShell
        : null;

  const hideHeroVideoLoading = () => {
    if (!(heroVideoLoading instanceof HTMLElement)) {
      return;
    }

    heroVideoLoading.classList.add('is-hidden');
  };

  const startLoopVideo = () => {
    if (!(loopVideo instanceof HTMLVideoElement)) {
      return;
    }

    const playAttempt = loopVideo.play();
    if (playAttempt && typeof playAttempt.catch === 'function') {
      playAttempt.catch(() => {});
    }
  };

  if (
    calibrationRoot instanceof HTMLElement &&
    calibrationFrame instanceof HTMLElement &&
    primaryVisual instanceof HTMLElement
  ) {
    const notes = signalCards ? Array.from(signalCards) : [];

    gsap.set(primaryVisual, {
      transformOrigin: '50% 50%',
    });

    const introTimeline = gsap.timeline({
      defaults: {
        ease: 'power3.out',
      },
    });

    introTimeline
      .fromTo(
        primaryVisual,
        {
          autoAlpha: 0,
          scale: 0.96,
          y: 28,
        },
        {
          autoAlpha: 1,
          scale: 1,
          y: 0,
          duration: 1.05,
        },
      )
      .fromTo(
        notes,
        {
          autoAlpha: 0,
          y: 34,
        },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.08,
        },
        '-=0.42',
      );

    let calibrationScrollInitialized = false;

    const setupCalibrationScroll = () => {
      if (calibrationScrollInitialized) {
        return;
      }

      calibrationScrollInitialized = true;

      const media = gsap.matchMedia();

      media.add('(min-width: 0px)', () => {
        const pageShell = document.querySelector('.page-shell');
        const siteHeader = document.querySelector('.site-header');
        const shellPaddingTop = pageShell instanceof HTMLElement ? parseFloat(window.getComputedStyle(pageShell).paddingTop) || 0 : 0;
        const headerStyles = siteHeader instanceof HTMLElement ? window.getComputedStyle(siteHeader) : null;
        const headerIsVisible =
          siteHeader instanceof HTMLElement &&
          headerStyles !== null &&
          headerStyles.display !== 'none' &&
          headerStyles.visibility !== 'hidden';
        const headerHeight = headerIsVisible ? siteHeader.getBoundingClientRect().height : 0;
        const headerMarginBottom = headerIsVisible ? parseFloat(headerStyles.marginBottom) || 0 : 0;
        const headerOffset = Math.max(shellPaddingTop + headerHeight + headerMarginBottom, 0);
        const playbackStretch = 3;
        const scrollDistance = (window.innerWidth <= 720 ? 1400 : 2400) * playbackStretch;

        const heroTimeline = gsap.timeline({
          defaults: { ease: 'none' },
          scrollTrigger: {
            trigger: calibrationRoot,
            start: `top top+=${Math.round(headerOffset)}`,
            end: `+=${scrollDistance}`,
            scrub: 1,
            pin: calibrationFrame,
            anticipatePin: 1,
          },
        });

        heroTimeline
          .to(
            primaryVisual,
            {
              yPercent: -2,
              scale: 1.03,
              duration: 1.2,
            },
            0,
          )
          .to(
            notes,
            {
              y: -42,
              autoAlpha: (index) => (index === notes.length - 1 ? 1 : 0.52),
              duration: 0.7,
              stagger: 0.03,
            },
            0.08,
          );

        if (
          heroVideoShell instanceof HTMLElement &&
          scrollVideo instanceof HTMLVideoElement &&
          loopVideo instanceof HTMLVideoElement
        ) {
          const targetDuration = Math.max(scrollVideo.duration - 0.04, 0);

          if (targetDuration > 0) {
            gsap.set(loopVideo, { autoAlpha: 0 });

            heroTimeline
              .to(
                scrollVideo,
                {
                  currentTime: targetDuration,
                  duration: 1,
                },
                0,
              )
              .to(
                loopVideo,
                {
                  autoAlpha: 1,
                  duration: 0.22,
                },
                0.78,
              )
              .to(
                scrollVideo,
                {
                  autoAlpha: 0.16,
                  duration: 0.16,
                },
                0.84,
              );
          }
        }

        return () => {
          heroTimeline.kill();
        };
      });
    };

    if (heroVideoShell instanceof HTMLElement && scrollVideo instanceof HTMLVideoElement && scrollVideo.readyState < 1) {
      scrollVideo.addEventListener('loadedmetadata', setupCalibrationScroll, { once: true });
    } else {
      setupCalibrationScroll();
    }
  }

  if (
    heroVideoShell instanceof HTMLElement &&
    scrollVideo instanceof HTMLVideoElement &&
    loopVideo instanceof HTMLVideoElement
  ) {
    const media = gsap.matchMedia();

    const syncScrollFrame = () => {
      if ('requestVideoFrameCallback' in scrollVideo) {
        const callback = () => {
          scrollVideo.requestVideoFrameCallback(callback);
        };

        scrollVideo.requestVideoFrameCallback(callback);
      }
    };

    const initializeHeroVideos = () => {
      gsap.set(loopVideo, { autoAlpha: 0 });
      gsap.set(scrollVideo, {
        autoAlpha: 1,
        currentTime: 0,
      });

      startLoopVideo();
      syncScrollFrame();

      if (prefersReducedMotion) {
        hideHeroVideoLoading();
        return;
      }

      hideHeroVideoLoading();
    };

    if (scrollVideo.readyState >= 1) {
      initializeHeroVideos();
    } else {
      scrollVideo.addEventListener('loadedmetadata', initializeHeroVideos, { once: true });
    }

    if (scrollVideo.readyState >= 3) {
      hideHeroVideoLoading();
    } else {
      scrollVideo.addEventListener('canplaythrough', hideHeroVideoLoading, { once: true });
      scrollVideo.addEventListener('loadeddata', hideHeroVideoLoading, { once: true });
    }

    if (loopVideo.readyState >= 2) {
      startLoopVideo();
    } else {
      loopVideo.addEventListener('canplay', startLoopVideo, { once: true });
    }
  }

  const transformSection = document.querySelector('[data-transform-section]');
  const transformPin = transformSection?.querySelector('[data-transform-pin]');
  const transformViewport = transformSection?.querySelector('[data-transform-viewport]');
  const transformTrack = transformSection?.querySelector('[data-transform-track]');
  const transformPanels = transformSection?.querySelectorAll('[data-transform-panel]');
  const axisLine = transformSection?.querySelector('.transform-axis-line');
  const axisNodes = transformSection?.querySelectorAll('.transform-axis-node');

  if (
    transformSection instanceof HTMLElement &&
    transformPin instanceof HTMLElement &&
    transformViewport instanceof HTMLElement &&
    transformTrack instanceof HTMLElement
  ) {
    const panels = transformPanels ? Array.from(transformPanels) : [];
    const tokensByPanel = panels.map((panel) => Array.from(panel.querySelectorAll('.transform-token')));
    const nodes = axisNodes ? Array.from(axisNodes) : [];

    gsap.fromTo(
      transformSection.querySelector('.transformation-header'),
      {
        autoAlpha: 0,
        y: 34,
      },
      {
        autoAlpha: 1,
        y: 0,
        duration: 0.88,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: transformSection,
          start: 'top 72%',
          once: true,
        },
      },
    );

    const media = gsap.matchMedia();

    media.add('(min-width: 721px)', () => {
      const totalShift = Math.max(transformTrack.scrollWidth - transformViewport.clientWidth, 0);

      if (totalShift <= 0) {
        return () => {};
      }

      if (axisLine instanceof HTMLElement) {
        gsap.set(axisLine, {
          scaleX: 0,
          transformOrigin: 'left center',
        });
      }

      gsap.set(nodes, {
        scale: 0.76,
        autoAlpha: 0.56,
      });

      tokensByPanel.forEach((tokens, index) => {
        gsap.set(tokens, {
          autoAlpha: index === 0 ? 1 : 0.36,
          y: index === 0 ? 0 : 24,
        });
      });

      const transformTimeline = gsap.timeline({
        defaults: { ease: 'none' },
        scrollTrigger: {
          trigger: transformSection,
          start: 'top top',
          end: `+=${totalShift + window.innerWidth * 1.2}`,
          scrub: 1,
          pin: transformPin,
          anticipatePin: 1,
        },
      });

      transformTimeline.to(
        transformTrack,
        {
          x: -totalShift,
          duration: 1,
        },
        0,
      );

      if (axisLine instanceof HTMLElement) {
        transformTimeline.to(
          axisLine,
          {
            scaleX: 1,
            duration: 1,
          },
          0,
        );
      }

      nodes.forEach((node, index) => {
        transformTimeline.to(
          node,
          {
            scale: 1.18,
            autoAlpha: 1,
            duration: 0.1,
          },
          index * 0.33,
        );
      });

      tokensByPanel.forEach((tokens, index) => {
        const start = index * 0.33;
        transformTimeline
          .to(
            tokens,
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.14,
              stagger: 0.03,
            },
            start,
          )
          .to(
            tokens,
            {
              autoAlpha: index === tokensByPanel.length - 1 ? 1 : 0.42,
              y: index === tokensByPanel.length - 1 ? 0 : -12,
              duration: 0.14,
              stagger: 0.02,
            },
            Math.min(start + 0.22, 0.88),
          );
      });

      panels.forEach((panel, index) => {
        transformTimeline.fromTo(
          panel,
          {
            y: 26,
          },
          {
            y: 0,
            duration: 0.18,
          },
          index * 0.28,
        );
      });

      return () => {
        transformTimeline.kill();
      };
    });
  }

  gsap.utils.toArray('[data-reveal]').forEach((section, index) => {
    revealSection(section, index);
  });

  window.addEventListener(
    'load',
    () => {
      ScrollTrigger.refresh();
    },
    { once: true },
  );
</script>
