<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const lenis = new Lenis({
      duration: 1.08,
      smoothWheel: true,
      wheelMultiplier: 0.92,
      touchMultiplier: 1.02,
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });

    gsap.ticker.lagSmoothing(0);

    const orbitRoot = document.querySelector('[data-orbit-landing]');
    const orbitFrame = orbitRoot?.querySelector('[data-orbit-frame]');
    const orbitAssembly = orbitRoot?.querySelector('[data-orbit-assembly]');
    const logoLayer = orbitRoot?.querySelector('[data-logo-layer]');
    const intro = orbitRoot?.querySelector('.orbit-intro');
    const glows = orbitRoot?.querySelectorAll('.orbit-depth-glow');
    const cards = orbitRoot?.querySelectorAll('[data-question-card]');

    if (
      orbitRoot instanceof HTMLElement &&
      orbitFrame instanceof HTMLElement &&
      orbitAssembly instanceof HTMLElement &&
      logoLayer instanceof HTMLElement &&
      intro instanceof HTMLElement &&
      cards
    ) {
      const questionCards = Array.from(cards);
      const glowEls = glows ? Array.from(glows) : [];
      const totalSteps = Math.max(questionCards.length, 1);
      const segment = 1;
      const totalDuration = totalSteps * segment + 0.9;

      gsap.set(questionCards, {
        autoAlpha: 0,
      });

      questionCards.forEach((card) => {
        const side = card.getAttribute('data-side');
        gsap.set(card, {
          yPercent: -50,
          x: side === 'left' ? -28 : 28,
          scale: 0.94,
        });
      });

      gsap.set(logoLayer, {
        transformOrigin: '50% 50%',
      });

      gsap.set(glowEls, {
        transformOrigin: '50% 50%',
      });

      const introTimeline = gsap.timeline({
        defaults: {
          ease: 'power3.out',
        },
      });

      introTimeline
        .fromTo(
          intro,
          {
            autoAlpha: 0,
            y: 24,
          },
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.8,
          },
        )
        .fromTo(
          orbitAssembly,
          {
            autoAlpha: 0,
            scale: 0.95,
          },
          {
            autoAlpha: 1,
            scale: 1,
            duration: 1,
          },
          '-=0.4',
        )
        .fromTo(
          logoLayer,
          {
            autoAlpha: 0,
            y: 18,
            scale: 0.9,
          },
          {
            autoAlpha: 1,
            y: 0,
            scale: 1,
            duration: 0.95,
            ease: 'back.out(1.4)',
          },
          '-=0.55',
        )
        .fromTo(
          glowEls,
          {
            autoAlpha: 0,
            scale: 0.88,
          },
          {
            autoAlpha: 1,
            scale: 1,
            duration: 1.1,
            stagger: 0.12,
          },
          '-=0.8',
        );

      gsap.to(glowEls[0], {
        scale: 1.06,
        opacity: 0.92,
        repeat: -1,
        yoyo: true,
        duration: 3.2,
        ease: 'sine.inOut',
      });

      gsap.to(glowEls[1], {
        scale: 0.96,
        opacity: 0.7,
        repeat: -1,
        yoyo: true,
        duration: 4.1,
        ease: 'sine.inOut',
      });

      const orbitTimeline = gsap.timeline({
        defaults: { ease: 'none' },
        scrollTrigger: {
          trigger: orbitRoot,
          start: 'top top',
          end: `+=${Math.max(questionCards.length * 880, 4200)}`,
          scrub: 1,
          pin: orbitFrame,
          anticipatePin: 1,
        },
      });

      orbitTimeline
        .to(
          orbitAssembly,
          {
            '--orbit-flow': '320deg',
            '--orbit-marker-rotation': '320deg',
            duration: totalDuration,
          },
          0,
        )
        .to(
          logoLayer,
          {
            scale: 1,
            duration: totalDuration,
          },
          0,
        )
        .to(
          intro,
          {
            autoAlpha: 0.58,
            yPercent: -4,
            duration: totalDuration * 0.4,
          },
          0,
        )
        ;

      questionCards.forEach((card, index) => {
        const side = card.getAttribute('data-side');
        const enterAt = 0.45 + index * segment;
        const exitAt = enterAt + 0.62;
        const exitX = side === 'left' ? -40 : 40;

        orbitTimeline
          .to(
            card,
            {
              autoAlpha: 1,
              x: 0,
              scale: 1,
              duration: 0.24,
              ease: 'power2.out',
            },
            enterAt,
          )
          .to(
            card,
            {
              autoAlpha: index === questionCards.length - 1 ? 1 : 0,
              x: index === questionCards.length - 1 ? 0 : exitX,
              scale: index === questionCards.length - 1 ? 1 : 0.97,
              duration: 0.2,
              ease: 'power2.in',
            },
            exitAt,
          );
      });

      gsap.utils.toArray('[data-reveal]').forEach((section, index) => {
        const element = section;
        const heading = element.querySelector('.section-heading');
        const eyebrow = element.querySelector('.eyebrow');
        const title = element.querySelector('.section-heading h2, h1, .hero-title-zh');
        const subcopy = element.querySelector('.section-heading p, .lede');
        const cards = element.querySelectorAll('.mini-card, .list-card');
        const paragraphs = element.querySelectorAll('p, li');
        const buttons = element.querySelectorAll('.button');

        gsap.fromTo(
          element,
          {
            autoAlpha: 0,
          },
          {
            autoAlpha: 1,
            duration: 0.35,
            ease: 'none',
            delay: index === 0 ? 0.1 : 0,
            scrollTrigger: {
              trigger: element,
              start: 'top 88%',
              once: true,
            },
          },
        );

        if (heading) {
          gsap.fromTo(
            heading,
            {
              y: 72,
              clipPath: 'inset(0 0 100% 0)',
            },
            {
              y: 0,
              clipPath: 'inset(0 0 0% 0)',
              duration: 1.2,
              ease: 'power4.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 76%',
                once: true,
              },
            },
          );
        }

        if (eyebrow) {
          gsap.fromTo(
            eyebrow,
            {
              x: -24,
              autoAlpha: 0,
            },
            {
              x: 0,
              autoAlpha: 1,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 78%',
                once: true,
              },
            },
          );
        }

        if (title) {
          gsap.fromTo(
            title,
            {
              y: 48,
              autoAlpha: 0,
            },
            {
              y: 0,
              autoAlpha: 1,
              duration: 1,
              ease: 'power4.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 74%',
                once: true,
              },
            },
          );
        }

        if (subcopy) {
          gsap.fromTo(
            subcopy,
            {
              y: 34,
              autoAlpha: 0,
            },
            {
              y: 0,
              autoAlpha: 1,
              duration: 0.9,
              delay: 0.05,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 72%',
                once: true,
              },
            },
          );
        }

        if (cards.length > 0) {
          gsap.fromTo(
            cards,
            {
              autoAlpha: 0,
              y: 80,
            },
            {
              autoAlpha: 1,
              y: 0,
              duration: 1,
              stagger: 0.16,
              ease: 'power4.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 68%',
                once: true,
              },
            },
          );
        }

        if (paragraphs.length > 0 && cards.length === 0) {
          gsap.fromTo(
            paragraphs,
            {
              autoAlpha: 0,
              y: 28,
            },
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.85,
              stagger: 0.06,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 68%',
                once: true,
              },
            },
          );
        }

        if (buttons.length > 0) {
          gsap.fromTo(
            buttons,
            {
              autoAlpha: 0,
              y: 18,
            },
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.8,
              stagger: 0.08,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 66%',
                once: true,
              },
            },
          );
        }
      });
    }
  } else {
    document.querySelectorAll('[data-question-card]').forEach((card, index) => {
      if (index === 0) {
        card.style.opacity = '1';
        card.style.transform = 'translate3d(0, -50%, 0)';
      }
    });
  }
</script>
