<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const lenis = new Lenis({
      duration: 1.15,
      smoothWheel: true,
      wheelMultiplier: 0.92,
      touchMultiplier: 1.1,
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });

    gsap.ticker.lagSmoothing(0);

    const hero = document.querySelector('[data-hero]');
    const heroHeading = hero?.querySelector('[data-hero-heading]');
    const heroText = hero?.querySelectorAll('[data-hero-copy]');
    const heroButtons = hero?.querySelectorAll<HTMLElement>('[data-hero-cta]');
    const heroOrbs = hero?.querySelectorAll('[data-hero-orb]');
    const heroBackdrop = hero?.querySelector('[data-hero-backdrop]');
    const heroLogo = hero?.querySelector('.hero-logo-art');

    if (hero && heroHeading && heroText && heroButtons) {
      gsap.set([heroHeading, heroText, heroButtons, heroLogo], {
        autoAlpha: 0,
        y: 28,
      });

      gsap
        .timeline({
          defaults: {
            ease: 'power3.out',
          },
        })
        .fromTo(
          hero,
          {
            autoAlpha: 0,
            scale: 0.985,
          },
          {
            autoAlpha: 1,
            scale: 1,
            duration: 0.9,
          },
        )
        .to(
          heroHeading,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.9,
          },
          '-=0.35',
        )
        .to(
          heroText,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.8,
            stagger: 0.14,
          },
          '-=0.5',
        )
        .to(
          heroButtons,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.7,
            stagger: 0.1,
          },
          '-=0.45',
        )
        .to(
          heroLogo,
          {
            autoAlpha: 1,
            y: 0,
            scale: 1,
            duration: 1.1,
          },
          '-=0.9',
        );

      if (heroLogo) {
        gsap.set(heroLogo, { scale: 0.92, rotate: -2 });

        gsap.to(heroLogo, {
          yPercent: -4,
          rotate: 1,
          duration: 6,
          repeat: -1,
          yoyo: true,
          ease: 'sine.inOut',
        });
      }

      if (heroOrbs?.length) {
        gsap.fromTo(
          heroOrbs,
          {
            autoAlpha: 0,
            scale: 0.82,
          },
          {
            autoAlpha: 1,
            scale: 1,
            duration: 1.4,
            stagger: 0.18,
            ease: 'power2.out',
          },
        );

        heroOrbs.forEach((orb, index) => {
          gsap.to(orb, {
            yPercent: index % 2 === 0 ? -10 : 10,
            xPercent: index % 2 === 0 ? 6 : -6,
            duration: 5 + index,
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut',
          });
        });
      }

      if (heroBackdrop) {
        gsap.to(heroBackdrop, {
          yPercent: -18,
          scale: 1.14,
          ease: 'none',
          scrollTrigger: {
            trigger: hero,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.5,
          },
        });
      }

      gsap
        .timeline({
          scrollTrigger: {
            trigger: hero,
            start: 'top top',
            end: 'bottom top',
            scrub: 1.2,
          },
        })
        .to(heroHeading, { yPercent: -18, autoAlpha: 0.4, ease: 'none' }, 0)
        .to(heroText, { yPercent: -10, autoAlpha: 0.18, ease: 'none', stagger: 0.04 }, 0)
        .to(heroButtons, { yPercent: -6, autoAlpha: 0, ease: 'none', stagger: 0.03 }, 0)
        .to(heroLogo, { yPercent: -12, scale: 0.86, autoAlpha: 0.3, ease: 'none' }, 0)
        .to(hero, { yPercent: -6, ease: 'none' }, 0);

      heroButtons.forEach((button) => {
        button.addEventListener('pointermove', (event) => {
          const rect = button.getBoundingClientRect();
          const offsetX = event.clientX - (rect.left + rect.width / 2);
          const offsetY = event.clientY - (rect.top + rect.height / 2);

          gsap.to(button, {
            x: offsetX * 0.12,
            y: offsetY * 0.18,
            duration: 0.28,
            ease: 'power2.out',
          });
        });

        button.addEventListener('pointerleave', () => {
          gsap.to(button, {
            x: 0,
            y: 0,
            duration: 0.42,
            ease: 'elastic.out(1, 0.45)',
          });
        });
      });
    }

    gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((section, index) => {
      const heading = section.querySelector('.section-heading');
      const eyebrow = section.querySelector('.eyebrow');
      const title = section.querySelector('.section-heading h2, .hero-title-zh');
      const subcopy = section.querySelector('.section-heading p, .lede');
      const cards = section.querySelectorAll('.mini-card, .list-card');
      const paragraphs = section.querySelectorAll('p, li');
      const buttons = section.querySelectorAll('.button');

      gsap.fromTo(
        section,
        {
          autoAlpha: 0,
        },
        {
          autoAlpha: 1,
          duration: 0.35,
          ease: 'none',
          delay: index === 0 ? 0.1 : 0,
          scrollTrigger: {
            trigger: section,
            start: 'top 88%',
            once: true,
          },
        },
      );

      if (heading) {
        gsap.fromTo(
          heading,
          {
            y: 72,
            clipPath: 'inset(0 0 100% 0)',
          },
          {
            y: 0,
            clipPath: 'inset(0 0 0% 0)',
            duration: 1.2,
            ease: 'power4.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 76%',
              once: true,
            },
          },
        );
      }

      if (eyebrow) {
        gsap.fromTo(
          eyebrow,
          {
            x: -24,
            autoAlpha: 0,
          },
          {
            x: 0,
            autoAlpha: 1,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 78%',
              once: true,
            },
          },
        );
      }

      if (title) {
        gsap.fromTo(
          title,
          {
            y: 48,
            autoAlpha: 0,
          },
          {
            y: 0,
            autoAlpha: 1,
            duration: 1,
            ease: 'power4.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 74%',
              once: true,
            },
          },
        );
      }

      if (subcopy) {
        gsap.fromTo(
          subcopy,
          {
            y: 34,
            autoAlpha: 0,
          },
          {
            y: 0,
            autoAlpha: 1,
            duration: 0.9,
            delay: 0.05,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 72%',
              once: true,
            },
          },
        );
      }

      if (cards.length > 0) {
        gsap.fromTo(
          cards,
          {
            autoAlpha: 0,
            y: 80,
          },
          {
            autoAlpha: 1,
            y: 0,
            duration: 1,
            stagger: 0.16,
            ease: 'power4.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 68%',
              once: true,
            },
          },
        );
      }

      if (paragraphs.length > 0 && cards.length === 0) {
        gsap.fromTo(
          paragraphs,
          {
            autoAlpha: 0,
            y: 28,
          },
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.85,
            stagger: 0.06,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 68%',
              once: true,
            },
          },
        );
      }

      if (buttons.length > 0) {
        gsap.fromTo(
          buttons,
          {
            autoAlpha: 0,
            y: 18,
          },
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.8,
            stagger: 0.08,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 66%',
              once: true,
            },
          },
        );
      }

      gsap.to(section, {
        yPercent: index % 2 === 0 ? -3 : 3,
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1.3,
        },
      });
    });

    gsap.utils.toArray<HTMLElement>('[data-parallax-card]').forEach((card, index) => {
      gsap.to(card, {
        yPercent: index % 2 === 0 ? -9 : 9,
        ease: 'none',
        scrollTrigger: {
          trigger: card,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1.6,
        },
      });
    });
  }
</script>
