---
import { pickByLocale, type Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const fieldConfig = {
  locale,
  zhText:
    '未来人研究所把研究理解为一种持续移动的问题场。AI、组织、品牌、空间、地方与共同体彼此碰撞，重新组织知识进入现实的方式。未来不是答案，而是一种仍在形成中的存在结构。我们真正关心的，不是技术能替代什么，而是未来我们将如何学习、工作、连接、居住与存在。',
  enText:
    'Entia Futura Institut treats research as a moving field of questions. AI, institutions, brands, space, place, and collective life collide and reorganize the way knowledge enters reality. The future is not an answer but a structure of existence still taking form. What matters is not what technology replaces, but how we shall learn, work, connect, dwell, and exist.',
  eyebrow: pickByLocale(locale, '问题场 / 运动文本 / 未来存在', 'Question Field / Moving Text / Future Existence'),
  orbs: [
    { label: 'Exist', color: [255, 244, 90], fx: 0.5, fy: 0.24, radius: 116, ampX: 14, ampY: 12, speed: 0.44, phase: 0.3 },
    { label: 'AI', color: [95, 53, 255], fx: 0.74, fy: 0.44, radius: 58, ampX: 18, ampY: 14, speed: 0.9, phase: 1.4 },
    { label: 'Space', color: [255, 255, 255], fx: 0.24, fy: 0.72, radius: 68, ampX: 16, ampY: 12, speed: 0.72, phase: 2.8 },
  ],
};
---

<div class="pretext-hero" data-pretext-hero>
  <p class="pretext-hero-eyebrow">{fieldConfig.eyebrow}</p>
  <div class="pretext-hero-stage" data-pretext-hero-stage>
    <div class="pretext-hero-fallback">
      <img
        class="pretext-hero-logo"
        src="/brand/entia-logo-cutout.png"
        alt="Entia Futura brand mark"
      />
    </div>
    <div class="pretext-hero-centerpiece" aria-hidden="true">
      <div class="pretext-hero-halo"></div>
      <img
        class="pretext-hero-logo"
        src="/brand/entia-logo-cutout.png"
        alt=""
      />
      <div class="pretext-hero-slit"></div>
    </div>
    <div class="pretext-hero-accessible">
      <p>{pickByLocale(locale, fieldConfig.zhText, fieldConfig.enText)}</p>
    </div>
  </div>
  <script type="application/json" data-pretext-hero-config set:html={JSON.stringify(fieldConfig)}></script>

  <script>
    import {
      layoutNextLine,
      prepareWithSegments,
      type LayoutCursor,
      type PreparedTextWithSegments,
    } from '@chenglou/pretext';

    type OrbConfig = {
      label: string;
      color: [number, number, number];
      fx: number;
      fy: number;
      radius: number;
      ampX: number;
      ampY: number;
      speed: number;
      phase: number;
    };

    type HeroConfig = {
      locale: 'zh' | 'en';
      zhText: string;
      enText: string;
      eyebrow: string;
      orbs: OrbConfig[];
    };

    type Interval = {
      left: number;
      right: number;
    };

    type PositionedLine = {
      x: number;
      y: number;
      text: string;
      font: string;
      lineHeight: number;
      tone: 'zh' | 'en';
    };

    type OrbState = OrbConfig & {
      offsetX: number;
      offsetY: number;
      velocityX: number;
      velocityY: number;
      x: number;
      y: number;
      currentRadius: number;
    };

    function carveSlots(base: Interval, blocked: Interval[], minimumWidth: number): Interval[] {
      let slots = [base];
      for (let i = 0; i < blocked.length; i++) {
        const interval = blocked[i]!;
        const next: Interval[] = [];
        for (let j = 0; j < slots.length; j++) {
          const slot = slots[j]!;
          if (interval.right <= slot.left || interval.left >= slot.right) {
            next.push(slot);
            continue;
          }
          if (interval.left > slot.left) next.push({ left: slot.left, right: interval.left });
          if (interval.right < slot.right) next.push({ left: interval.right, right: slot.right });
        }
        slots = next;
      }
      return slots.filter((slot) => slot.right - slot.left >= minimumWidth);
    }

    function circleIntervalForBand(
      cx: number,
      cy: number,
      radius: number,
      bandTop: number,
      bandBottom: number,
      horizontalPad: number,
      verticalPad: number,
    ): Interval | null {
      const top = bandTop - verticalPad;
      const bottom = bandBottom + verticalPad;
      if (top >= cy + radius || bottom <= cy - radius) return null;

      const minDy = cy >= top && cy <= bottom ? 0 : cy < top ? top - cy : cy - bottom;
      if (minDy >= radius) return null;

      const maxDx = Math.sqrt(radius * radius - minDy * minDy);
      return {
        left: cx - maxDx - horizontalPad,
        right: cx + maxDx + horizontalPad,
      };
    }

    function syncPool<T extends HTMLElement>(
      pool: T[],
      targetSize: number,
      createElement: () => T,
      mountPoint: HTMLElement,
    ): void {
      while (pool.length < targetSize) {
        const element = createElement();
        mountPoint.appendChild(element);
        pool.push(element);
      }

      for (let index = 0; index < pool.length; index++) {
        pool[index]!.style.display = index < targetSize ? '' : 'none';
      }
    }

    function layoutFieldBlock(
      prepared: PreparedTextWithSegments,
      font: string,
      lineHeight: number,
      regionX: number,
      regionY: number,
      regionWidth: number,
      regionBottom: number,
      circles: OrbState[],
      minimumSlotWidth: number,
      tone: PositionedLine['tone'],
    ): PositionedLine[] {
      let cursor: LayoutCursor = { segmentIndex: 0, graphemeIndex: 0 };
      let lineTop = regionY;
      const lines: PositionedLine[] = [];

      while (lineTop + lineHeight <= regionBottom) {
        const blocked: Interval[] = [];

        for (let orbIndex = 0; orbIndex < circles.length; orbIndex++) {
          const orb = circles[orbIndex]!;
          const interval = circleIntervalForBand(
            orb.x,
            orb.y,
            orb.currentRadius,
            lineTop,
            lineTop + lineHeight,
            16,
            4,
          );
          if (interval !== null) blocked.push(interval);
        }

        const slots = carveSlots(
          { left: regionX, right: regionX + regionWidth },
          blocked,
          minimumSlotWidth,
        );

        if (slots.length === 0) {
          lineTop += lineHeight;
          continue;
        }

        const orderedSlots = [...slots].sort((left, right) => left.left - right.left);

        for (let slotIndex = 0; slotIndex < orderedSlots.length; slotIndex++) {
          const slot = orderedSlots[slotIndex]!;
          const line = layoutNextLine(prepared, cursor, slot.right - slot.left);
          if (line === null) return lines;

          lines.push({
            x: Math.round(slot.left),
            y: Math.round(lineTop),
            text: line.text,
            font,
            lineHeight,
            tone,
          });
          cursor = line.end;
        }

        lineTop += lineHeight;
      }

      return lines;
    }

    async function initPretextHero(): Promise<void> {
      const root = document.querySelector('[data-pretext-hero]');
      const stage = root?.querySelector('[data-pretext-hero-stage]');
      const configNode = root?.querySelector('[data-pretext-hero-config]');
      if (!(root instanceof HTMLDivElement) || !(stage instanceof HTMLDivElement) || !(configNode instanceof HTMLScriptElement)) return;
      if (stage.dataset.pretextReady === 'true') return;

      const config = JSON.parse(configNode.textContent || '{}') as HeroConfig;
      if (!config.zhText || !config.enText || !Array.isArray(config.orbs)) return;

      stage.dataset.pretextReady = 'true';
      stage.dataset.enhanced = 'true';

      if ('fonts' in document) {
        await document.fonts.ready;
      }

      const BODY_FONT_FAMILY =
        '"Songti SC", "STSong", "Noto Serif SC", "Source Han Serif SC", "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif';
      const zhFont = `500 18px ${BODY_FONT_FAMILY}`;
      const enFont = `400 17px ${BODY_FONT_FAMILY}`;
      const preparedZh = prepareWithSegments(config.zhText, zhFont, { whiteSpace: 'pre-wrap' });
      const preparedEn = prepareWithSegments(config.enText, enFont, { whiteSpace: 'pre-wrap' });

      const linePool: HTMLSpanElement[] = [];
      const orbPool: HTMLDivElement[] = [];
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const pointer = { x: -9999, y: -9999, active: false };
      const orbs: OrbState[] = config.orbs.map((orb) => ({
        ...orb,
        offsetX: 0,
        offsetY: 0,
        velocityX: 0,
        velocityY: 0,
        x: 0,
        y: 0,
        currentRadius: orb.radius,
      }));

      syncPool(
        orbPool,
        orbs.length,
        () => {
          const element = document.createElement('div');
          element.className = 'pretext-hero-orb';
          const label = document.createElement('span');
          label.className = 'pretext-hero-orb-label';
          element.appendChild(label);
          return element;
        },
        stage,
      );

      let animationFrame = 0;
      let lastTime = 0;

      function scheduleRender(): void {
        if (animationFrame !== 0) return;
        animationFrame = requestAnimationFrame(render);
      }

      function render(now: number): void {
        animationFrame = 0;

        const width = stage.clientWidth;
        const height = stage.clientHeight;
        if (width === 0 || height === 0) return;

        const isNarrow = width < 840;
        const padX = isNarrow ? 22 : 36;
        const padY = isNarrow ? 22 : 36;
        const innerWidth = Math.max(1, width - padX * 2);
        const innerHeight = Math.max(1, height - padY * 2);
        const dt = lastTime === 0 ? 0.016 : Math.min((now - lastTime) / 1000, 0.04);
        const activeText = config.locale === 'zh' ? preparedZh : preparedEn;
        const activeFont = config.locale === 'zh' ? zhFont : enFont;
        const activeLineHeight = config.locale === 'zh' ? 32 : 30;
        const minimumSlotWidth = isNarrow ? (config.locale === 'zh' ? 110 : 180) : config.locale === 'zh' ? 150 : 240;

        for (let orbIndex = 0; orbIndex < orbs.length; orbIndex++) {
          const orb = orbs[orbIndex]!;
          const baseX = padX + orb.fx * innerWidth + Math.sin(now * 0.001 * orb.speed + orb.phase) * orb.ampX;
          const baseY = padY + orb.fy * innerHeight + Math.cos(now * 0.001 * orb.speed * 0.9 + orb.phase) * orb.ampY;

          if (!reduceMotion.matches) {
            if (pointer.active) {
              const currentX = baseX + orb.offsetX;
              const currentY = baseY + orb.offsetY;
              const dx = currentX - pointer.x;
              const dy = currentY - pointer.y;
              const distance = Math.sqrt(dx * dx + dy * dy);
              const influence = Math.max(180, orb.radius * 2.8);
              if (distance > 0 && distance < influence) {
                const strength = (1 - distance / influence) * 520 * dt;
                orb.velocityX += (dx / distance) * strength;
                orb.velocityY += (dy / distance) * strength;
              }
            }

            orb.velocityX += -orb.offsetX * 3.4 * dt;
            orb.velocityY += -orb.offsetY * 3.4 * dt;
            orb.velocityX *= 0.92;
            orb.velocityY *= 0.92;
            orb.offsetX += orb.velocityX;
            orb.offsetY += orb.velocityY;
          } else {
            orb.offsetX = 0;
            orb.offsetY = 0;
            orb.velocityX = 0;
            orb.velocityY = 0;
          }

          orb.x = baseX + orb.offsetX;
          orb.y = baseY + orb.offsetY;
          orb.currentRadius = orb.radius * (isNarrow ? 0.76 : 1);
        }

        const lines = layoutFieldBlock(
          activeText,
          activeFont,
          activeLineHeight,
          padX,
          padY,
          innerWidth,
          height - padY,
          orbs,
          minimumSlotWidth,
          config.locale,
        );

        syncPool(
          linePool,
          lines.length,
          () => {
            const element = document.createElement('span');
            element.className = 'pretext-hero-line';
            element.setAttribute('aria-hidden', 'true');
            return element;
          },
          stage,
        );

        for (let lineIndex = 0; lineIndex < lines.length; lineIndex++) {
          const line = lines[lineIndex]!;
          const element = linePool[lineIndex]!;
          element.className = `pretext-hero-line pretext-hero-line-${line.tone}`;
          element.textContent = line.text.length > 0 ? line.text : '\u00A0';
          element.style.left = `${line.x}px`;
          element.style.top = `${line.y}px`;
          element.style.font = line.font;
          element.style.lineHeight = `${line.lineHeight}px`;
        }

        for (let orbIndex = 0; orbIndex < orbPool.length; orbIndex++) {
          const element = orbPool[orbIndex]!;
          const orb = orbs[orbIndex]!;
          const label = element.firstElementChild;

          element.style.left = `${orb.x - orb.currentRadius}px`;
          element.style.top = `${orb.y - orb.currentRadius}px`;
          element.style.width = `${orb.currentRadius * 2}px`;
          element.style.height = `${orb.currentRadius * 2}px`;
          element.style.setProperty('--orb-rgb', `${orb.color[0]} ${orb.color[1]} ${orb.color[2]}`);
          if (label instanceof HTMLSpanElement) label.textContent = orb.label;
        }

        lastTime = now;
        if (!reduceMotion.matches) scheduleRender();
      }

      stage.addEventListener('pointermove', (event) => {
        const rect = stage.getBoundingClientRect();
        pointer.x = event.clientX - rect.left;
        pointer.y = event.clientY - rect.top;
        pointer.active = true;
        scheduleRender();
      });

      stage.addEventListener('pointerleave', () => {
        pointer.active = false;
        pointer.x = -9999;
        pointer.y = -9999;
        scheduleRender();
      });

      window.addEventListener('resize', () => {
        lastTime = 0;
        scheduleRender();
      });

      reduceMotion.addEventListener('change', () => {
        lastTime = 0;
        scheduleRender();
      });

      scheduleRender();
    }

    void initPretextHero();
  </script>
</div>

<style>
  .pretext-hero {
    position: relative;
    width: 100%;
  }

  .pretext-hero-eyebrow {
    margin: 0 0 14px;
    color: rgba(22, 22, 22, 0.58);
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .pretext-hero-stage {
    position: relative;
    min-height: min(72vh, 44rem);
    overflow: hidden;
    border: 1px solid rgba(22, 22, 22, 0.16);
    background:
      radial-gradient(circle at 50% 18%, rgba(255, 244, 90, 0.74), rgba(255, 244, 90, 0.08) 32%, transparent 52%),
      radial-gradient(circle at 82% 32%, rgba(95, 53, 255, 0.18), transparent 22rem),
      radial-gradient(circle at 18% 76%, rgba(255, 255, 255, 0.26), transparent 18rem),
      linear-gradient(180deg, rgba(184, 201, 211, 0.78), rgba(176, 194, 205, 0.9));
  }

  .pretext-hero-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(22, 22, 22, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(22, 22, 22, 0.05) 1px, transparent 1px);
    background-size: 100% 42px, 42px 100%;
    mask-image: radial-gradient(circle at center, rgba(0, 0, 0, 0.9), transparent 92%);
    pointer-events: none;
  }

  .pretext-hero-fallback {
    display: grid;
    place-items: center;
    min-height: inherit;
  }

  .pretext-hero-stage[data-enhanced='true'] .pretext-hero-fallback {
    display: none;
  }

  .pretext-hero-centerpiece {
    position: absolute;
    inset: 50% auto auto 50%;
    z-index: 4;
    width: min(50%, 22rem);
    aspect-ratio: 1 / 1;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .pretext-hero-halo {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 244, 90, 0.9) 0%, rgba(255, 244, 90, 0.22) 52%, rgba(255, 244, 90, 0) 76%);
    filter: blur(8px);
  }

  .pretext-hero-logo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 20px 36px rgba(22, 22, 22, 0.08));
  }

  .pretext-hero-slit {
    position: absolute;
    top: 41%;
    left: 50%;
    width: 18%;
    height: 2.8%;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(95, 53, 255, 0.96), rgba(0, 0, 0, 0.98));
    transform: translate(-50%, -50%) rotate(-9deg);
    box-shadow: 0 0 16px rgba(95, 53, 255, 0.4);
  }

  .pretext-hero-accessible {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  :global(.pretext-hero-line) {
    position: absolute;
    z-index: 2;
    white-space: pre;
    pointer-events: none;
  }

  :global(.pretext-hero-line-zh) {
    color: rgba(22, 22, 22, 0.9);
    letter-spacing: 0.03em;
  }

  :global(.pretext-hero-line-en) {
    color: rgba(22, 22, 22, 0.76);
    letter-spacing: 0.02em;
  }

  :global(.pretext-hero-orb) {
    position: absolute;
    z-index: 3;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background:
      radial-gradient(circle at 32% 28%, rgb(var(--orb-rgb) / 0.7), rgb(255 255 255 / 0.16) 34%, rgb(var(--orb-rgb) / 0.12) 64%, transparent 76%),
      linear-gradient(180deg, rgb(255 255 255 / 0.18), rgb(255 255 255 / 0.05));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.24),
      0 16px 40px rgb(var(--orb-rgb) / 0.2);
    backdrop-filter: blur(14px);
    pointer-events: none;
  }

  :global(.pretext-hero-orb-label) {
    width: min(74%, 7rem);
    color: rgba(255, 255, 255, 0.92);
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-align: center;
    text-transform: uppercase;
    line-height: 1.35;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.14);
  }

  @media (max-width: 920px) {
    .pretext-hero-stage {
      min-height: 34rem;
    }

    .pretext-hero-centerpiece {
      width: min(56%, 18rem);
    }
  }

  @media (max-width: 720px) {
    .pretext-hero-stage {
      min-height: 30rem;
    }

    .pretext-hero-centerpiece {
      width: min(64%, 15rem);
    }
  }
</style>
