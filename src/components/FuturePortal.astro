---
interface Props {
  bare?: boolean;
}

const { bare = false } = Astro.props;
---

<div class:list={['future-portal-shell', { 'future-portal-shell-bare': bare }]} data-future-portal-shell>
  <div class:list={['future-portal-sky', { 'future-portal-sky-bare': bare }]} aria-hidden="true" data-future-portal-sky>
    <img class="future-portal-sky-image" src="/textures/starfield-panorama.jpg" alt="" />
  </div>
  <canvas class="future-portal-canvas" data-future-portal-canvas></canvas>
  {!bare && <div class="future-portal-vignette" aria-hidden="true"></div>}
  {!bare && (
    <div class="future-portal-label" aria-hidden="true">
      <span>portal calibration</span>
      <strong>ENTIA FUTURA / THRESHOLD-01</strong>
    </div>
  )}
</div>

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
  import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
  import { UnrealBloomPass } from 'three/examples/jsm/postprocessing/UnrealBloomPass.js';

  gsap.registerPlugin(ScrollTrigger);

  const portalShell = document.querySelector('[data-future-portal-shell]');
  const canvas = portalShell?.querySelector('[data-future-portal-canvas]');
  const skyLayer = portalShell?.querySelector('[data-future-portal-sky]');
  const calibrationRoot = document.querySelector('[data-calibration-root]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (
    portalShell instanceof HTMLElement &&
    canvas instanceof HTMLCanvasElement &&
    skyLayer instanceof HTMLElement &&
    calibrationRoot instanceof HTMLElement
  ) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 400);
    camera.position.set(0, 12, 46);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      powerPreference: 'high-performance',
    });
    renderer.setClearColor(0x000000, 0);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.1;

    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    const bloomPass = new UnrealBloomPass(new THREE.Vector2(1, 1), 1.2, 0.95, 0.72);
    composer.addPass(bloomPass);

    const textureLoader = new THREE.TextureLoader();
    const rockTexture = textureLoader.load('/textures/megalith-rock-texture.jpg');
    rockTexture.colorSpace = THREE.SRGBColorSpace;
    rockTexture.wrapS = THREE.RepeatWrapping;
    rockTexture.wrapT = THREE.RepeatWrapping;
    rockTexture.repeat.set(1.2, 1.8);

    const astronautTexture = textureLoader.load('/brand/astronaut-silhouette.png');
    astronautTexture.colorSpace = THREE.SRGBColorSpace;

    const ambientLight = new THREE.AmbientLight(0x7ca4ff, 0.22);
    scene.add(ambientLight);

    const rimLight = new THREE.DirectionalLight(0xa9d4ff, 0.8);
    rimLight.position.set(-8, 18, 12);
    scene.add(rimLight);

    const portalMaterial = new THREE.MeshStandardMaterial({
      map: rockTexture,
      color: new THREE.Color('#0a0d11'),
      roughness: 0.84,
      metalness: 0.12,
    });
    const portal = new THREE.Mesh(new THREE.BoxGeometry(7.6, 21.5, 2.2), portalMaterial);
    portal.position.set(0, 12.4, 0);
    scene.add(portal);

    const portalLightMaterial = new THREE.MeshBasicMaterial({
      color: new THREE.Color('#f8fdff'),
      transparent: true,
      opacity: 0.92,
    });
    const portalLight = new THREE.Mesh(new THREE.PlaneGeometry(0.32, 19.8), portalLightMaterial);
    portalLight.position.set(0, 12.4, 1.16);
    scene.add(portalLight);

    const pointLight = new THREE.PointLight(0xe5f7ff, 12, 65, 1.3);
    pointLight.position.set(0, 12.8, 5.4);
    scene.add(pointLight);

    const astronautMaterial = new THREE.MeshBasicMaterial({
      map: astronautTexture,
      transparent: true,
      depthWrite: false,
    });
    const astronaut = new THREE.Mesh(new THREE.PlaneGeometry(2.9, 7.68), astronautMaterial);
    astronaut.position.set(0, 4.2, 4.8);
    const astronautBaseY = astronaut.position.y;
    scene.add(astronaut);

    const floor = new THREE.Mesh(
      new THREE.CircleGeometry(12, 96),
      new THREE.MeshBasicMaterial({
        color: new THREE.Color('#09101a'),
        transparent: true,
        opacity: 0.42,
      }),
    );
    floor.rotation.x = -Math.PI / 2;
    floor.position.set(0, 0.15, 1.6);
    scene.add(floor);

    const cameraTarget = { x: 0, y: 13.6, z: 0 };

    const setSize = () => {
      const { width, height } = portalShell.getBoundingClientRect();
      if (width === 0 || height === 0) {
        return;
      }

      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(width, height, false);
      composer.setSize(width, height);
      bloomPass.setSize(width, height);
    };

    setSize();

    let scrollTween;
    let skyTween;

    if (!prefersReducedMotion && !bare) {
      skyTween = gsap.fromTo(
        skyLayer,
        {
          xPercent: -4,
          scale: 1.08,
        },
        {
          xPercent: 8,
          scale: 1.16,
          ease: 'none',
          scrollTrigger: {
            trigger: calibrationRoot,
            start: 'top top',
            end: '+=2400',
            scrub: 1.2,
          },
        },
      );

      scrollTween = gsap.timeline({
        defaults: { ease: 'none' },
        scrollTrigger: {
          trigger: calibrationRoot,
          start: 'top top',
          end: '+=2400',
          scrub: 1.2,
        },
      });

      scrollTween
        .to(
          camera.position,
          {
            z: 15,
            y: 11.8,
            x: 0.9,
            duration: 1,
          },
          0,
        )
        .to(
          cameraTarget,
          {
            y: 12.8,
            x: 0.2,
            duration: 1,
          },
          0,
        )
        .to(
          portalLight.scale,
          {
            x: 4.6,
            y: 1.02,
            duration: 0.66,
          },
          0.34,
        )
        .to(
          portal.rotation,
          {
            y: 0.12,
            duration: 1,
          },
          0,
        )
        .to(
          astronaut.position,
          {
            z: 8.4,
            y: 4.5,
            duration: 1,
          },
          0.08,
        );
    }

    const clock = new THREE.Clock();
    let animationFrame = 0;

    const tick = () => {
      const elapsedTime = clock.getElapsedTime();
      const breath = (Math.sin(elapsedTime * 2.8) + 1) * 0.5;

      pointLight.intensity = 7 + breath * 8;
      portalLight.material.opacity = 0.52 + breath * 0.42;
      astronaut.material.opacity = 0.8 + Math.sin(elapsedTime * 1.4) * 0.08;
      astronaut.position.x = Math.sin(elapsedTime * 0.85) * 0.18;
      astronaut.position.y = astronautBaseY + Math.sin(elapsedTime * 1.1) * 0.1;
      floor.material.opacity = 0.28 + breath * 0.14;

      camera.lookAt(cameraTarget.x, cameraTarget.y, cameraTarget.z);
      if (bare) {
        renderer.render(scene, camera);
      } else {
        composer.render();
      }
      animationFrame = window.requestAnimationFrame(tick);
    };

    tick();

    const handleResize = () => {
      setSize();
    };

    window.addEventListener('resize', handleResize);

    const cleanup = () => {
      window.cancelAnimationFrame(animationFrame);
      window.removeEventListener('resize', handleResize);
      scrollTween?.scrollTrigger?.kill();
      scrollTween?.kill();
      skyTween?.scrollTrigger?.kill();
      skyTween?.kill();
      composer.dispose();
      renderer.dispose();
      portal.geometry.dispose();
      portal.material.dispose();
      portalLight.geometry.dispose();
      portalLight.material.dispose();
      astronaut.geometry.dispose();
      astronaut.material.dispose();
      floor.geometry.dispose();
      floor.material.dispose();
      rockTexture.dispose();
      astronautTexture.dispose();
    };

    window.addEventListener('pagehide', cleanup, { once: true });
  }
</script>

<style>
  .future-portal-shell {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #02050c;
  }

  .future-portal-shell-bare {
    background: #000;
  }

  .future-portal-sky {
    position: absolute;
    inset: -4% -22%;
    transform-origin: center center;
    z-index: 0;
  }

  .future-portal-sky::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.03), transparent 34%),
      linear-gradient(180deg, rgba(2, 6, 14, 0.02), rgba(2, 6, 14, 0.18));
  }

  .future-portal-shell-bare .future-portal-sky::after {
    background: none;
  }

  .future-portal-sky-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center center;
  }

  .future-portal-sky-bare .future-portal-sky-image {
    width: 132%;
    max-width: none;
    height: 112%;
    object-fit: cover;
    object-position: left center;
    transform-origin: left center;
    animation: portal-sky-drift 32s linear infinite alternate;
    will-change: transform;
  }

  .future-portal-canvas,
  .future-portal-vignette {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .future-portal-canvas {
    display: block;
    z-index: 1;
  }

  .future-portal-vignette {
    pointer-events: none;
    z-index: 2;
    background:
      radial-gradient(circle at 50% 54%, transparent 0 26%, rgba(255, 255, 255, 0.02) 38%, transparent 62%),
      linear-gradient(180deg, rgba(2, 6, 14, 0.08) 0%, rgba(2, 6, 14, 0) 34%, rgba(4, 8, 18, 0.28) 100%);
  }

  .future-portal-label {
    position: absolute;
    left: 1.15rem;
    right: 1.15rem;
    bottom: 1rem;
    display: grid;
    gap: 0.18rem;
    pointer-events: none;
    color: rgba(228, 239, 255, 0.78);
    text-transform: uppercase;
    z-index: 3;
  }

  .future-portal-label span,
  .future-portal-label strong {
    font-family: 'EntiaTitleEn', "Helvetica Neue", Arial, sans-serif;
    letter-spacing: 0.18em;
  }

  .future-portal-label span {
    font-size: 0.58rem;
  }

  .future-portal-label strong {
    font-size: 0.78rem;
    font-weight: 400;
  }

  @keyframes portal-sky-drift {
    from {
      transform: translate3d(0%, 0, 0) scale(1.08);
    }

    to {
      transform: translate3d(14%, 0, 0) scale(1.08);
    }
  }
 </style>
