---
---

<div class="page-loader" id="page-loader" aria-hidden="true">
  <div class="page-loader__label">Loading</div>
  <div class="page-loader__percent" id="loader-percent">0%</div>
  <div class="page-loader__bar-track" aria-hidden="true">
    <div class="page-loader__bar-fill" id="loader-bar"></div>
  </div>
</div>

<style>
  .page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: transparent;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: max(2rem, calc(env(safe-area-inset-bottom) + 2rem))
      max(2.4rem, calc(env(safe-area-inset-right) + 2rem))
      max(2rem, calc(env(safe-area-inset-bottom) + 2rem))
      max(2.4rem, calc(env(safe-area-inset-left) + 2rem));
    pointer-events: all;
    transition: opacity 0.72s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0.72s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .page-loader.is-done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .page-loader__label {
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(3.2rem, 8vw, 8rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--color-primary);
    line-height: 1;
    align-self: flex-end;
  }

  .page-loader__percent {
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(3.2rem, 8vw, 8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-primary);
    line-height: 1;
    align-self: flex-end;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* Thin horizontal progress bar at the very bottom */
  .page-loader__bar-track {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: color-mix(in srgb, var(--color-text-primary) 18%, transparent);
  }

  .page-loader__bar-fill {
    height: 100%;
    width: 0%;
    background: var(--color-text-primary);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-text-primary) 40%, transparent);
    transition: width 0.18s ease-out;
  }
</style>

<script>
  (() => {
    const loader = document.getElementById('page-loader');
    const percentEl = document.getElementById('loader-percent');
    const barEl = document.getElementById('loader-bar');

    if (!loader || !percentEl || !barEl) return;

    // Lock scroll during loading
    document.body.style.overflow = 'hidden';

    // ── Config ────────────────────────────────────────────────────────────────
    const MIN_DISPLAY_MS = 1800;  // always show loader for at least this long
    // If video data is still 0% after this many ms, skip the hero entirely.
    const VIDEO_SKIP_TIMEOUT_MS = 6000;

    // ── State ─────────────────────────────────────────────────────────────────
    let displayed = 0;
    let target = 0;
    let windowLoaded = false;
    let minTimeReached = false;
    let videoBufferReady = false;
    let videoHadAnyData = false; // tracks whether any buffer progress was received
    let skipHero = false;
    let raf: number;

    // ── Display tick — smoothly eases displayed toward target ─────────────────
    const tick = () => {
      if (displayed < target) {
        const step = Math.max(0.25, (target - displayed) * 0.055);
        displayed = Math.min(target, displayed + step);
        percentEl.textContent = `${Math.round(displayed)}%`;
        barEl.style.width = `${displayed}%`;
      }
      raf = requestAnimationFrame(tick);
    };
    raf = requestAnimationFrame(tick);

    // ── Completion logic ──────────────────────────────────────────────────────
    const tryFinish = () => {
      if (!windowLoaded || !minTimeReached || !videoBufferReady) return;

      cancelAnimationFrame(raf);
      target = 100;
      displayed = 100;
      percentEl.textContent = '100%';
      barEl.style.width = '100%';

      setTimeout(() => {
        loader.classList.add('is-done');
        document.querySelectorAll('[data-hero-stage]').forEach((el) => {
          el.classList.add('is-revealed');
        });
        // Signal that loading is fully done — effects init listens for this.
        // Scroll is unlocked by the effects init after ScrollTrigger is ready.
        document.dispatchEvent(new CustomEvent('loader:done', { detail: { skipHero } }));
      }, 320);
    };

    // Minimum display time gate
    setTimeout(() => {
      minTimeReached = true;
      tryFinish();
    }, MIN_DISPLAY_MS);

    // window.load gate
    const onLoad = () => {
      windowLoaded = true;
      tryFinish();
    };

    if (document.readyState === 'complete') {
      setTimeout(onLoad, 0);
    } else {
      window.addEventListener('load', onLoad, { once: true });
    }

    // Real buffer progress gate — HomeHeroScreen polls video.buffered every 200ms
    // and dispatches scrollvideo:bufferupdate with the current fraction (0–1).
    // The progress bar directly mirrors the real download: buffer 0→1 = loader 0→99.
    // When buffered >= 95%, scrollvideo:bufferready is dispatched and we can finish.
    // 6-second skip-hero watchdog: if video data is still 0 after 6s, skip the hero.
    setTimeout(() => {
      if (!videoHadAnyData && !videoBufferReady) {
        skipHero = true;
        videoBufferReady = true; // release the gate
        tryFinish();
      }
    }, VIDEO_SKIP_TIMEOUT_MS);

    document.addEventListener('scrollvideo:bufferupdate', (e: Event) => {
      const pct = (e as CustomEvent<{ pct: number }>).detail?.pct ?? 0;
      if (pct > 0) videoHadAnyData = true;
      // buffer 0–1 → loader 0–99 (100 is reserved for the final "done" snap)
      const loaderTarget = Math.round(pct * 99);
      if (loaderTarget > target) target = loaderTarget;
    });

    document.addEventListener('scrollvideo:bufferready', () => {
      videoBufferReady = true;
      tryFinish();
    }, { once: true });
  })();
</script>
