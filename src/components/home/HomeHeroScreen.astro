---
import './landing-hero/landingHero.css';
import { siteMeta } from '../../content/site';
const { assetsUrl } = siteMeta;
---

<section class="hero-transition-stage" data-hero-transition-root>
  <div class="hero-transition-frame" data-orbit-frame>
    <div class="hero-video-shell" data-hero-video-shell>
      <div class="hero-video-loading" data-hero-video-loading aria-hidden="true"></div>
      <video
        class="hero-video hero-video-scroll"
        data-scroll-video
        src={`${assetsUrl}/root/portal-scroll.mp4`}
        crossorigin="anonymous"
        muted
        playsinline
        preload="auto"
      ></video>
      <video
        class="hero-video hero-video-loop"
        data-loop-video
        src="/videos/portal-loop.webm"
        crossorigin="anonymous"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
      ></video>
      <div class="hero-video-overlay" aria-hidden="true"></div>
      <div class="hero-video-vignette" aria-hidden="true"></div>
    </div>
  </div>
</section>

<script>
  import { initLandingHeroInteractions } from './landing-hero/landingHeroInteractions';

  initLandingHeroInteractions();

  // Watch video.buffered and drive loader progress with real download percentage.
  // Dispatches:
  //   scrollvideo:bufferupdate  { detail: { pct: number } }  — every 200ms while loading
  //   scrollvideo:bufferready                                 — when buffered >= READY_THRESHOLD
    const scrollVideo = document.querySelector<HTMLVideoElement>('[data-scroll-video]');
  if (scrollVideo) {
    let readyDispatched = false;

    // How much of the video must be buffered before we consider it "ready".
    const READY_THRESHOLD = 0.98;

    const getBufferedPct = (): number => {
      const buf = scrollVideo.buffered;
      const dur = scrollVideo.duration;
      if (!dur || !isFinite(dur) || buf.length === 0) return 0;
      return buf.end(buf.length - 1) / dur;
    };

    const dispatchReady = () => {
      if (readyDispatched) return;
      readyDispatched = true;
      document.dispatchEvent(new CustomEvent('scrollvideo:bufferupdate', { detail: { pct: 1 } }));
      document.dispatchEvent(new CustomEvent('scrollvideo:bufferready'));
    };

    // Poll buffered progress and update loader bar every 200ms.
    const checkBuffer = () => {
      const pct = getBufferedPct();
      document.dispatchEvent(new CustomEvent('scrollvideo:bufferupdate', { detail: { pct } }));
      if (!readyDispatched) setTimeout(checkBuffer, 200);
    };

    // Fire ready as soon as the buffered threshold is reached.
    scrollVideo.addEventListener('canplaythrough', () => {
      const pct = getBufferedPct();
      if (pct >= READY_THRESHOLD) {
        dispatchReady();
      }
    }, { once: true });

    const startPolling = () => {
      checkBuffer();
      // Also watch for the progress event to catch buffered updates.
      scrollVideo.addEventListener('progress', () => {
        const pct = getBufferedPct();
        document.dispatchEvent(new CustomEvent('scrollvideo:bufferupdate', { detail: { pct } }));
        if (!readyDispatched && pct >= READY_THRESHOLD) dispatchReady();
      });
    };

    if (scrollVideo.readyState >= 1) {
      startPolling();
    } else {
      scrollVideo.addEventListener('loadedmetadata', startPolling, { once: true });
    }
  }
</script>
