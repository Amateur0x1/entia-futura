---
import { pickByLocale, type Locale } from '../../i18n/config';
import { toLocalePath } from '../../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = pickByLocale(locale, '研究方向', 'Research Areas');
const btnLabel = pickByLocale(locale, '查看全部研究方向', 'View All Research Areas');

const items = locale === 'zh'
  ? [
      'AI 与未来生活',
      '知识生产与新型学习共同体',
      '社群、空间与新的公共生活',
      '地方文化与未来组织形式',
      '商业世界中的研究能力',
      '未来共同体与生活形式实验',
    ]
  : [
      'AI and Future Life',
      'Knowledge Production and New Learning Communities',
      'Communities, Space, and New Public Life',
      'Local Culture and Future Forms of Organization',
      'Research Capacity in the Commercial World',
      'Experimenting with Future Forms of Collective Life',
    ];
---

<section
  class={`landing-fourth-panel ${locale === 'en' ? 'landing-fourth-panel--en' : ''}`}
  data-fourth-panel
  aria-label={title}
>
  <!-- Nebula particle background (matches third panel) -->
  <canvas class="landing-fourth-panel__nebula" data-nebula-canvas aria-hidden="true"></canvas>

  <!-- Atmosphere veil: top-left cyan, bottom-right violet (matches third panel) -->
  <div class="landing-fourth-panel__veil" aria-hidden="true"></div>

  <!-- Central logo -->
  <div class="landing-fourth-panel__logo-wrap" aria-hidden="true">
    <img
      class="landing-fourth-panel__logo"
      src="/brand/entia-logo-white-lines.png"
      alt=""
      draggable="false"
    />
  </div>

  <!-- Pretext canvas — research items orbit around logo -->
  <canvas
    class="landing-fourth-panel__canvas"
    data-fourth-panel-canvas
    data-items={JSON.stringify(items)}
    aria-hidden="true"
  ></canvas>

  <!-- Screen-reader / no-JS fallback list -->
  <div class="landing-fourth-panel__sr-list" aria-label={title}>
    <h2>{title}</h2>
    <ul>
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <!-- CTA button -->
  <a
    class="landing-fourth-panel__btn"
    href={toLocalePath(locale, '/research')}
    data-fourth-panel-btn
  >
    {btnLabel}
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M13.172 12l-4.95-4.95 1.414-1.414L16 12l-6.364 6.364-1.414-1.414z"/>
    </svg>
  </a>
</section>

<style>
  .landing-fourth-panel {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: var(--color-background);
    color: var(--color-secondary-foreground);
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Nebula canvas (z-index 0, same as third panel) ── */
  .landing-fourth-panel__nebula {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.88;
  }

  /* ── Atmosphere veil: top-left cyan, bottom-right violet (mirrors third panel) ── */
  .landing-fourth-panel__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 90% 90% at -10% -10%,
        color-mix(in srgb, var(--color-primary) 18%, transparent) 0%,
        color-mix(in srgb, var(--color-primary) 6%, transparent) 50%,
        transparent 78%
      ),
      radial-gradient(
        ellipse 90% 90% at 110% 110%,
        color-mix(in srgb, var(--color-secondary) 18%, transparent) 0%,
        color-mix(in srgb, var(--color-secondary) 6%, transparent) 50%,
        transparent 78%
      );
  }

  /* ── Logo ── */
  .landing-fourth-panel__logo-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    pointer-events: none;
    width: clamp(260px, 34vmin, 480px);
    height: clamp(260px, 34vmin, 480px);
  }

  .landing-fourth-panel__logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.88;
    filter: drop-shadow(0 0 32px color-mix(in srgb, var(--color-primary) 36%, transparent));
  }

  /* ── Canvas (text orbits, above logo) ── */
  .landing-fourth-panel__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 4;
    pointer-events: none;
  }

  /* ── SR fallback ── */
  .landing-fourth-panel__sr-list {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* ── CTA button ── */
  .landing-fourth-panel__btn {
    position: absolute;
    bottom: max(2.4rem, calc(env(safe-area-inset-bottom) + 1.8rem));
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.72rem 1.4rem 0.68rem;
    border: 1.5px solid color-mix(in srgb, var(--color-primary) 56%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.78rem, 0.6vw + 0.58rem, 0.96rem);
    letter-spacing: 0.12em;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-primary) 20%, transparent);
    transition: background 200ms ease, box-shadow 200ms ease, color 200ms ease;
    white-space: nowrap;
  }

  .landing-fourth-panel__btn svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    flex-shrink: 0;
  }

  .landing-fourth-panel__btn:hover,
  .landing-fourth-panel__btn:focus-visible {
    background: color-mix(in srgb, var(--color-primary) 18%, transparent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-primary) 32%, transparent);
  }

  @media (max-width: 720px) {
    .landing-fourth-panel__btn {
      font-size: clamp(0.68rem, 0.5vw + 0.52rem, 0.84rem);
      padding: 0.62rem 1.1rem 0.58rem;
      bottom: max(1.8rem, calc(env(safe-area-inset-bottom) + 1.2rem));
    }
  }
</style>

<script>
  (() => {
    const panel = document.querySelector<HTMLElement>('[data-fourth-panel]');
    const canvas = document.querySelector<HTMLCanvasElement>('[data-fourth-panel-canvas]');
    if (!panel || !canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // ── Config ──────────────────────────────────────────────────────────────
    const FONT_SIZE_BASE = 15;
    const FONT_FAMILY = "'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif";
    const LINE_HEIGHT = 1.55;
    const REPULSE_RADIUS = 90;    // px — mouse influence radius
    const REPULSE_STRENGTH = 0.38;
    const SPRING = 0.08;          // spring back to origin
    const DAMPING = 0.82;
    const ORBIT_RADIUS_SCALE = 0.30; // fraction of min(W,H) for orbit radius
    const FADE_IN_DUR = 800;      // ms for panel text to fade in

    // items injected by Astro at build time via canvas data-items attribute
    const ITEMS: string[] = JSON.parse(canvas.getAttribute('data-items') ?? '[]');

    // ── Types ────────────────────────────────────────────────────────────────
    interface TextBlock {
      lines: string[];
      // current position (may be disturbed)
      x: number;
      y: number;
      // rest position
      ox: number;
      oy: number;
      // velocity
      vx: number;
      vy: number;
      // render props
      alpha: number;
      maxW: number;
      align: 'left' | 'right' | 'center';
    }

    // ── State ────────────────────────────────────────────────────────────────
    let W = 0, H = 0;
    let mouseX = -9999, mouseY = -9999;
    let blocks: TextBlock[] = [];
    let startTime = 0;
    let active = false;
    let raf = 0;

    // ── Layout helpers ───────────────────────────────────────────────────────
    function wrapText(text: string, maxW: number, fontSize: number): string[] {
      // simple canvas-based word wrap (no pretext needed for short strings)
      ctx!.font = `${fontSize}px ${FONT_FAMILY}`;
      const words = text.split(' ');
      const lines: string[] = [];
      let current = '';
      for (const w of words) {
        const probe = current ? `${current} ${w}` : w;
        if (ctx!.measureText(probe).width > maxW && current) {
          lines.push(current);
          current = w;
        } else {
          current = probe;
        }
      }
      if (current) lines.push(current);
      return lines;
    }

    function buildBlocks(w: number, h: number) {
      if (ITEMS.length === 0) return;

      const logoR = Math.min(w, h) * 0.19; // half-logo visual radius (matches enlarged CSS size)
      const orbitR = Math.min(w, h) * ORBIT_RADIUS_SCALE + logoR;
      const cx = w / 2;
      const cy = h / 2;
      const count = ITEMS.length;
      const fs = Math.max(12, Math.min(FONT_SIZE_BASE, w / 60));
      const blockMaxW = Math.min(200, w * 0.22);

      blocks = ITEMS.map((text, i) => {
        // Evenly spread around the circle, offset by 90° so first item is at top
        const angle = (i / count) * Math.PI * 2 - Math.PI / 2;
        // Push out a bit more for long lines
        const extraR = text.length > 20 ? orbitR * 0.12 : 0;
        const r = orbitR + extraR;

        const px = cx + Math.cos(angle) * r;
        const py = cy + Math.sin(angle) * r;

        // text alignment: items on the right align left, items on left align right
        const align: 'left' | 'right' | 'center' =
          Math.cos(angle) > 0.2 ? 'left' : Math.cos(angle) < -0.2 ? 'right' : 'center';

        const lines = wrapText(text, blockMaxW, fs);

        return {
          lines,
          x: px, y: py,
          ox: px, oy: py,
          vx: 0, vy: 0,
          alpha: 0,
          maxW: blockMaxW,
          align,
        };
      });
    }

    // ── Resize ───────────────────────────────────────────────────────────────
    function resize() {
      W = panel!.offsetWidth;
      H = panel!.offsetHeight;
      canvas!.width = W;
      canvas!.height = H;
      buildBlocks(W, H);
    }

    // ── Draw ─────────────────────────────────────────────────────────────────
    function draw(ts: number) {
      if (!startTime) startTime = ts;
      const elapsed = ts - startTime;
      ctx!.clearRect(0, 0, W, H);

      const fs = Math.max(12, Math.min(FONT_SIZE_BASE, W / 60));
      const lh = fs * LINE_HEIGHT;
      const fadeProgress = Math.min(elapsed / FADE_IN_DUR, 1);

      for (const b of blocks) {
        // ── spring physics ──
        const dx = mouseX - b.x;
        const dy = mouseY - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < REPULSE_RADIUS && dist > 0) {
          const force = (1 - dist / REPULSE_RADIUS) * REPULSE_STRENGTH;
          b.vx -= (dx / dist) * force * 12;
          b.vy -= (dy / dist) * force * 12;
        }

        // Spring back to origin
        b.vx += (b.ox - b.x) * SPRING;
        b.vy += (b.oy - b.y) * SPRING;
        b.vx *= DAMPING;
        b.vy *= DAMPING;
        b.x += b.vx;
        b.y += b.vy;

        // fade-in
        b.alpha = fadeProgress;

        // ── render ──
        ctx!.save();
        ctx!.font = `${fs}px ${FONT_FAMILY}`;
        ctx!.textBaseline = 'middle';
        ctx!.textAlign = b.align;

        const totalH = b.lines.length * lh;
        const startY = b.y - totalH / 2 + lh / 2;

        // separator line — subtle, width of first line
        const firstW = ctx!.measureText(b.lines[0] ?? '').width;
        const sepX = b.align === 'right' ? b.x - firstW : b.align === 'left' ? b.x : b.x - firstW / 2;
        ctx!.globalAlpha = b.alpha * 0.18;
        ctx!.strokeStyle = '#00e5ff';
        ctx!.lineWidth = 0.5;
        ctx!.beginPath();
        ctx!.moveTo(sepX, startY - lh * 0.62);
        ctx!.lineTo(sepX + firstW, startY - lh * 0.62);
        ctx!.stroke();

        // text glow pass
        ctx!.globalAlpha = b.alpha * 0.28;
        ctx!.fillStyle = '#00e5ff';
        ctx!.shadowColor = '#00e5ff';
        ctx!.shadowBlur = 8;
        b.lines.forEach((line, li) => {
          ctx!.fillText(line, b.x, startY + li * lh);
        });

        // main text pass
        ctx!.globalAlpha = b.alpha * 0.82;
        ctx!.shadowBlur = 0;
        ctx!.fillStyle = '#b9cad0';
        b.lines.forEach((line, li) => {
          ctx!.fillText(line, b.x, startY + li * lh);
        });

        ctx!.restore();
      }

      if (active) raf = requestAnimationFrame(draw);
    }

    // ── Mouse ────────────────────────────────────────────────────────────────
    function onMouseMove(e: MouseEvent) {
      const r = panel!.getBoundingClientRect();
      mouseX = e.clientX - r.left;
      mouseY = e.clientY - r.top;
    }
    function onPointerLeave() { mouseX = -9999; mouseY = -9999; }

    // ── Intersection ─────────────────────────────────────────────────────────
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          if (!active) {
            active = true;
            startTime = 0;
            raf = requestAnimationFrame(draw);
          }
        } else {
          active = false;
          cancelAnimationFrame(raf);
        }
      }
    }, { threshold: 0.01 });

    io.observe(panel);
    document.addEventListener('mousemove', onMouseMove, { passive: true });
    panel.addEventListener('mouseleave', onPointerLeave, { passive: true });

    resize();
    new ResizeObserver(resize).observe(panel);
  })();
</script>
