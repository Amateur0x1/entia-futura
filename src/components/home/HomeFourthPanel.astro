---
import { pickByLocale, type Locale } from '../../i18n/config';
import { toLocalePath } from '../../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = pickByLocale(locale, '研究方向', 'Research Areas');
// Left block — Collaboration
const colTitle  = pickByLocale(locale, '合作方式', 'Collaboration');
const colBody   = pickByLocale(
  locale,
  '我们欢迎与企业、品牌、地方项目、文化空间、书店、学校及各类组织与个人展开合作。我们理解的合作，不只是项目执行，而是把研究能力、问题意识与现实场景连接起来。',
  'We welcome collaboration with enterprises, brands, place-based initiatives, cultural spaces, bookstores, schools, and a wide range of organizations and individuals. For us, collaboration is not merely execution, but a way of connecting research capacity, problem-consciousness, and real-world settings.',
);
const colBtn    = pickByLocale(locale, '发起合作', 'Start a Collaboration');

// Right block — Join Us
const joinTitle = pickByLocale(locale, '加入我们', 'Join Us');
const joinBody  = pickByLocale(
  locale,
  '未来人研究所欢迎所有认真对待未来问题的人。加入研究所不一定意味着固定身份，它也可以意味着参与讨论、加入计划、共创项目、提交提案，或在某个阶段与研究所共同工作。',
  'Entia Futura Institut welcomes all those who take the future seriously. Joining the institute does not necessarily mean entering a fixed role; it may mean entering a discussion, joining a program, co-creating a project, submitting a proposal, or working alongside the institute for a certain period of time.',
);
const joinBtn   = pickByLocale(locale, '了解参与方式', 'Learn How to Participate');

const items = locale === 'zh'
  ? [
      'AI 与未来生活',
      '知识生产\n与新型学习共同体',
      '社群、空间\n与新的公共生活',
      '地方文化\n与未来组织形式',
      '商业世界\n中的研究能力',
      '未来共同体\n与生活形式实验',
    ]
  : [
      'AI and\nFuture Life',
      'Knowledge Production\nand New Learning Communities',
      'Communities, Space,\nand New Public Life',
      'Local Culture and\nFuture Forms of Organization',
      'Research Capacity\nin the Commercial World',
      'Experimenting with\nFuture Forms of Collective Life',
    ];
---

<section
  class={`landing-fourth-panel ${locale === 'en' ? 'landing-fourth-panel--en' : ''}`}
  data-fourth-panel
  aria-label={title}
>
  <!-- Nebula particle background (matches third panel) -->
  <canvas class="landing-fourth-panel__nebula" data-nebula-canvas aria-hidden="true"></canvas>

  <!-- Atmosphere veil: top-left cyan, bottom-right violet (matches third panel) -->
  <div class="landing-fourth-panel__veil" aria-hidden="true"></div>

  <!-- Central logo -->
  <div class="landing-fourth-panel__logo-wrap" aria-hidden="true">
    <img
      class="landing-fourth-panel__logo"
      src="/brand/entia-logo-white-lines.png"
      alt=""
      draggable="false"
    />
  </div>

  <!-- Orbit items — HTML divs positioned by JS -->
  <div class="landing-fourth-panel__orbit" data-orbit aria-hidden="true">
    {items.map((item, i) => (
      <div class="landing-fourth-panel__orbit-item" data-orbit-item data-index={i}>
        <span class="landing-fourth-panel__orbit-dot" aria-hidden="true"></span>
        <span class="landing-fourth-panel__orbit-text" set:html={item.replace(/\n/g, '<br>')} />
      </div>
    ))}
  </div>

  <!-- Screen-reader / no-JS fallback list -->
  <div class="landing-fourth-panel__sr-list" aria-label={title}>
    <h2>{title}</h2>
    <ul>
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <!-- Left side block: Collaboration (cyan / primary) -->
  <div class="landing-fourth-panel__side landing-fourth-panel__side--left landing-fourth-panel__side--cyan" aria-label={colTitle}>
    <p class="landing-fourth-panel__side-label">{pickByLocale(locale, '合作', 'Collab')}</p>
    <h2 class="landing-fourth-panel__side-title">{colTitle}</h2>
    <div class="landing-fourth-panel__side-divider" aria-hidden="true"></div>
    <p class="landing-fourth-panel__side-body">{colBody}</p>
    <a class="landing-fourth-panel__side-btn" href={toLocalePath(locale, '/collaboration')}>
      {colBtn}
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M13.172 12l-4.95-4.95 1.414-1.414L16 12l-6.364 6.364-1.414-1.414z"/>
      </svg>
    </a>
  </div>

  <!-- Right side block: Join Us (violet / secondary) -->
  <div class="landing-fourth-panel__side landing-fourth-panel__side--right landing-fourth-panel__side--violet" aria-label={joinTitle}>
    <p class="landing-fourth-panel__side-label">{pickByLocale(locale, '参与', 'Join')}</p>
    <h2 class="landing-fourth-panel__side-title">{joinTitle}</h2>
    <div class="landing-fourth-panel__side-divider" aria-hidden="true"></div>
    <p class="landing-fourth-panel__side-body">{joinBody}</p>
    <a class="landing-fourth-panel__side-btn" href={toLocalePath(locale, '/join')}>
      {joinBtn}
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M13.172 12l-4.95-4.95 1.414-1.414L16 12l-6.364 6.364-1.414-1.414z"/>
      </svg>
    </a>
  </div>

</section>

<style>
  .landing-fourth-panel {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: var(--color-background);
    color: var(--color-secondary-foreground);
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Nebula canvas (z-index 0, same as third panel) ── */
  .landing-fourth-panel__nebula {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.88;
  }

  /* ── Atmosphere veil: top-left cyan, bottom-right violet (mirrors third panel) ── */
  .landing-fourth-panel__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 90% 90% at -10% -10%,
        color-mix(in srgb, var(--color-primary) 18%, transparent) 0%,
        color-mix(in srgb, var(--color-primary) 6%, transparent) 50%,
        transparent 78%
      ),
      radial-gradient(
        ellipse 90% 90% at 110% 110%,
        color-mix(in srgb, var(--color-secondary) 18%, transparent) 0%,
        color-mix(in srgb, var(--color-secondary) 6%, transparent) 50%,
        transparent 78%
      );
  }

  /* ── Logo ── */
  .landing-fourth-panel__logo-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    pointer-events: none;
    width: clamp(260px, 34vmin, 480px);
    height: clamp(260px, 34vmin, 480px);
  }

  .landing-fourth-panel__logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.88;
    filter: drop-shadow(0 0 32px color-mix(in srgb, var(--color-primary) 36%, transparent));
  }

  /* ── Orbit container ── */
  .landing-fourth-panel__orbit {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }

  /* ── Individual orbit item ── */
  .landing-fourth-panel__orbit-item {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    pointer-events: none;
    opacity: 0;
    will-change: transform, opacity;
    /* JS sets top/left to 50%/50% and uses translateX/Y to position */
    top: 50%;
    left: 50%;
  }

  .landing-fourth-panel__orbit-dot {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #fff;
    box-shadow:
      0 0 6px 1px var(--color-primary),
      0 0 16px 2px color-mix(in srgb, var(--color-primary) 70%, transparent),
      0 0 1px #fff;
    opacity: 1;
  }

  .landing-fourth-panel__orbit-text {
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.75rem, 0.7vw + 0.52rem, 1.05rem);
    letter-spacing: 0.06em;
    line-height: 1.45;
    color: #b9cad0;
    white-space: pre-line;   /* respect <br> / newlines, still wrap naturally */
    text-shadow: 0 0 12px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  /* .is-right no longer used — dot is always on the left */

  /* ── SR fallback ── */
  .landing-fourth-panel__sr-list {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* ── Side blocks (left = Collaboration / cyan, right = Join Us / violet) ── */

  /* Colour tokens per variant */
  .landing-fourth-panel__side--cyan   { --accent: var(--color-primary); }
  .landing-fourth-panel__side--violet { --accent: var(--color-secondary); }

  .landing-fourth-panel__side {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: clamp(260px, 26vw, 400px);
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    padding: 2rem 1.8rem;
    /* transparent border + frosted glass — colour driven by --accent */
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    border-radius: 1.2rem;
    background: color-mix(in srgb, var(--color-background) 55%, transparent);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow:
      0 0 48px color-mix(in srgb, var(--accent) 12%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .landing-fourth-panel__side--left {
    left: clamp(1.5rem, 3.5vw, 4rem);
  }

  .landing-fourth-panel__side--right {
    right: clamp(1.5rem, 3.5vw, 4rem);
    text-align: right;
  }

  .landing-fourth-panel__side-label {
    margin: 0;
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.62rem, 0.5vw + 0.44rem, 0.76rem);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.75;
    line-height: 1;
  }

  .landing-fourth-panel__side-title {
    margin: 0;
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(1.6rem, 1.8vw + 0.8rem, 2.6rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-foreground, #f0f4f8);
    line-height: 1.05;
  }

  .landing-fourth-panel__side-divider {
    width: 2.4rem;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .landing-fourth-panel__side--right .landing-fourth-panel__side-divider {
    margin-left: auto;
  }

  .landing-fourth-panel__side-body {
    margin: 0;
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.78rem, 0.65vw + 0.54rem, 1rem);
    line-height: 1.8;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, var(--color-foreground, #f0f4f8) 72%, transparent);
  }

  .landing-fourth-panel__side-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.62rem 1.3rem 0.58rem;
    border: 1px solid color-mix(in srgb, var(--accent) 50%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.66rem, 0.48vw + 0.5rem, 0.84rem);
    letter-spacing: 0.13em;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    align-self: flex-start;
    transition: background 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 0 14px color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .landing-fourth-panel__side--right .landing-fourth-panel__side-btn {
    align-self: flex-end;
  }

  .landing-fourth-panel__side-btn svg {
    width: 0.85rem;
    height: 0.85rem;
    fill: currentColor;
    flex-shrink: 0;
  }

  .landing-fourth-panel__side-btn:hover,
  .landing-fourth-panel__side-btn:focus-visible {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    box-shadow: 0 0 22px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  @media (max-width: 1200px) {
    .landing-fourth-panel__side {
      width: clamp(220px, 22vw, 320px);
      padding: 1.6rem 1.4rem;
    }
    .landing-fourth-panel__side-btn {
      padding: 0.52rem 1rem 0.48rem;
      font-size: clamp(0.6rem, 0.4vw + 0.44rem, 0.76rem);
    }
    .landing-fourth-panel__side-btn svg {
      width: 0.72rem;
      height: 0.72rem;
    }
  }

  @media (max-width: 900px) {
    .landing-fourth-panel__side {
      width: clamp(180px, 24vw, 260px);
      padding: 1.2rem 1rem;
    }
    .landing-fourth-panel__side-btn {
      padding: 0.44rem 0.8rem 0.4rem;
      font-size: clamp(0.56rem, 0.4vw + 0.38rem, 0.68rem);
      gap: 0.28rem;
    }
    .landing-fourth-panel__side-btn svg {
      width: 0.62rem;
      height: 0.62rem;
    }
    .landing-fourth-panel__side-body {
      display: none;
    }
    .landing-fourth-panel__side-title {
      font-size: clamp(1.2rem, 2.5vw + 0.4rem, 1.8rem);
    }
  }

  @media (max-width: 600px) {
    .landing-fourth-panel__side {
      display: none;
    }
  }

</style>

<script>
  (() => {
    const panel = document.querySelector<HTMLElement>('[data-fourth-panel]');
    const orbitEls = Array.from(document.querySelectorAll<HTMLElement>('[data-orbit-item]'));
    if (!panel || orbitEls.length === 0) return;

    // ── Config ──────────────────────────────────────────────────────────────
    const REPULSE_RADIUS   = 100;    // px
    const REPULSE_STRENGTH = 0.42;
    const SPRING           = 0.07;
    const DAMPING          = 0.80;
    const ORBIT_RADIUS_SCALE = 0.09; // very tight around logo — fraction of min(W,H)
    const FADE_IN_DUR      = 900;    // ms
    const SPIN_SPEED       = 0.000050; // rad/ms

    // ── Per-item state ───────────────────────────────────────────────────────
    interface Item {
      el: HTMLElement;
      baseAngle: number;
      orbitR: number;
      x: number; y: number;
      vx: number; vy: number;
      hw: number; hh: number; // half-width / half-height of element
    }

    let W = 0, H = 0;
    let mouseX = -9999, mouseY = -9999;
    let items: Item[] = [];
    let startTime = 0;
    let active = false;
    let raf = 0;

    // ── Build item state ─────────────────────────────────────────────────────
    function build() {
      const count = orbitEls.length;
      const logoR    = Math.min(W, H) * 0.16;
      const orbitR   = Math.min(W, H) * ORBIT_RADIUS_SCALE + logoR;
      const cx = W / 2, cy = H / 2;

      items = orbitEls.map((el, i) => {
        const baseAngle = (i / count) * Math.PI * 2 - Math.PI / 2;
        const px = cx + Math.cos(baseAngle) * orbitR;
        const py = cy + Math.sin(baseAngle) * orbitR;
        const rect = el.getBoundingClientRect();
        return {
          el,
          baseAngle,
          orbitR,
          x: px, y: py,
          vx: 0, vy: 0,
          hw: rect.width  / 2,
          hh: rect.height / 2,
        };
      });
    }

    // ── Resize ───────────────────────────────────────────────────────────────
    function resize() {
      W = panel!.offsetWidth;
      H = panel!.offsetHeight;
      build();
    }

    // ── Draw loop ────────────────────────────────────────────────────────────
    function draw(ts: number) {
      if (!startTime) startTime = ts;
      const elapsed = ts - startTime;
      const fadeProgress = Math.min(elapsed / FADE_IN_DUR, 1);
      const spinAngle = elapsed * SPIN_SPEED;
      const cx = W / 2, cy = H / 2;

      for (const it of items) {
        // rotating origin
        const rotAngle = it.baseAngle + spinAngle;
        const ox = cx + Math.cos(rotAngle) * it.orbitR;
        const oy = cy + Math.sin(rotAngle) * it.orbitR;

        // mouse repulsion
        const dx = mouseX - it.x;
        const dy = mouseY - it.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < REPULSE_RADIUS && dist > 0) {
          const force = (1 - dist / REPULSE_RADIUS) * REPULSE_STRENGTH;
          it.vx -= (dx / dist) * force * 14;
          it.vy -= (dy / dist) * force * 14;
        }

        // spring back
        it.vx += (ox - it.x) * SPRING;
        it.vy += (oy - it.y) * SPRING;
        it.vx *= DAMPING;
        it.vy *= DAMPING;
        it.x += it.vx;
        it.y += it.vy;

        // dot always on left side — no flip

        // apply transform: offset by -50% to use element centre as anchor
        it.el.style.transform = `translate(calc(${it.x - W / 2}px - 50%), calc(${it.y - H / 2}px - 50%))`;
        it.el.style.opacity = String(fadeProgress);
      }

      if (active) raf = requestAnimationFrame(draw);
    }

    // ── Mouse ────────────────────────────────────────────────────────────────
    function onMouseMove(e: MouseEvent) {
      const r = panel!.getBoundingClientRect();
      mouseX = e.clientX - r.left;
      mouseY = e.clientY - r.top;
    }
    function onPointerLeave() { mouseX = -9999; mouseY = -9999; }

    // ── Intersection ─────────────────────────────────────────────────────────
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          if (!active) {
            active = true;
            startTime = 0;
            raf = requestAnimationFrame(draw);
          }
        } else {
          active = false;
          cancelAnimationFrame(raf);
        }
      }
    }, { threshold: 0.01 });

    io.observe(panel);
    document.addEventListener('mousemove', onMouseMove, { passive: true });
    panel.addEventListener('mouseleave', onPointerLeave, { passive: true });

    resize();
    new ResizeObserver(resize).observe(panel);
  })();
</script>
