---
import { pickByLocale, type Locale, toLocalePath } from '../../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = pickByLocale(locale, '合作方式', 'Collaboration');
const body = pickByLocale(
  locale,
  '我们欢迎与企业、品牌、地方项目、文化空间、书店、学校及各类组织与个人展开合作。我们理解的合作，不只是项目执行，而是把研究能力、问题意识与现实场景连接起来。',
  'We welcome collaboration with enterprises, brands, place-based initiatives, cultural spaces, bookstores, schools, and a wide range of organizations and individuals. For us, collaboration is not merely execution, but a way of connecting research capacity, problem-consciousness, and real-world settings.',
);
const btnLabel = pickByLocale(locale, '发起合作', 'Start a Collaboration');
---

<section
  class={`landing-fifth-panel ${locale === 'en' ? 'landing-fifth-panel--en' : ''}`}
  data-fifth-panel
  aria-label={title}
>
  <div class="landing-fifth-panel__veil" aria-hidden="true"></div>
  <div class="landing-fifth-panel__inner">
    <article class="landing-fifth-panel__block">
      <p class="landing-fifth-panel__label">{pickByLocale(locale, '合作', 'Collaboration')}</p>
      <h2 class="landing-fifth-panel__title">{title}</h2>
      <div class="landing-fifth-panel__divider" aria-hidden="true"></div>
      <p class="landing-fifth-panel__body">{body}</p>
      <a
        class="landing-fifth-panel__btn"
        href={toLocalePath(locale, '/contact')}
      >
        {btnLabel}
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M13.172 12l-4.95-4.95 1.414-1.414L16 12l-6.364 6.364-1.414-1.414z"/>
        </svg>
      </a>
    </article>
  </div>
</section>

<style>
  .landing-fifth-panel {
    position: fixed;
    inset: 0;
    z-index: 42;
    background: transparent;
    color: var(--color-secondary-foreground);
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .landing-fifth-panel__veil {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 90% 90% at -10% 110%,
        color-mix(in srgb, var(--color-primary) 16%, transparent) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse 90% 90% at 110% -10%,
        color-mix(in srgb, var(--color-secondary) 14%, transparent) 0%,
        transparent 60%
      );
  }

  .landing-fifth-panel__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 720px;
    padding: clamp(4rem, 12vh, 8rem) clamp(1.4rem, 5vw, 4rem);
  }

  .landing-fifth-panel__block {
    display: grid;
    gap: 0;
  }

  .landing-fifth-panel__label {
    margin: 0 0 0.6rem;
    font-size: clamp(0.72rem, 0.5vw + 0.56rem, 0.9rem);
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-primary);
    opacity: 0.78;
  }

  .landing-fifth-panel__title {
    margin: 0 0 clamp(1.2rem, 2.5vh, 2rem);
    font-size: clamp(2.4rem, 4vw + 1rem, 5.2rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.06;
    color: var(--color-text-primary);
  }

  .landing-fifth-panel__divider {
    width: clamp(40px, 8vw, 80px);
    height: 1px;
    background: color-mix(in srgb, var(--color-primary) 48%, transparent);
    margin-bottom: clamp(1.4rem, 3vh, 2.4rem);
  }

  .landing-fifth-panel__body {
    margin: 0 0 clamp(2rem, 4vh, 3.2rem);
    font-size: clamp(1.1rem, 0.8vw + 0.8rem, 1.6rem);
    line-height: 1.84;
    color: color-mix(in srgb, var(--color-text-secondary) 88%, transparent);
    max-width: 56ch;
  }

  .landing-fifth-panel__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.76rem 1.6rem 0.72rem;
    border: 1.5px solid color-mix(in srgb, var(--color-primary) 56%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.8rem, 0.6vw + 0.6rem, 1rem);
    letter-spacing: 0.1em;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-primary) 18%, transparent);
    transition: background 200ms ease, box-shadow 200ms ease;
    width: fit-content;
  }

  .landing-fifth-panel__btn svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    flex-shrink: 0;
  }

  .landing-fifth-panel__btn:hover,
  .landing-fifth-panel__btn:focus-visible {
    background: color-mix(in srgb, var(--color-primary) 18%, transparent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  @media (max-width: 720px) {
    .landing-fifth-panel__title {
      font-size: clamp(2rem, 5vw + 0.5rem, 3.2rem);
    }

    .landing-fifth-panel__body {
      font-size: clamp(1rem, 1vw + 0.76rem, 1.36rem);
    }
  }
</style>
