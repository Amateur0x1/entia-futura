---
import { pickByLocale, type Locale, toLocalePath } from '../../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = pickByLocale(locale, '加入我们', 'Join Us');
const body = pickByLocale(
  locale,
  '未来人研究所欢迎所有认真对待未来问题的人。加入研究所不一定意味着固定身份，它也可以意味着参与讨论、加入计划、共创项目、提交提案，或在某个阶段与研究所共同工作。',
  'Entia Futura Institut welcomes all those who take the future seriously. Joining the institute does not necessarily mean entering a fixed role; it may mean entering a discussion, joining a program, co-creating a project, submitting a proposal, or working alongside the institute for a certain period of time.',
);
const btnLabel = pickByLocale(locale, '了解参与方式', 'Learn How to Participate');
---

<section
  class={`landing-sixth-panel ${locale === 'en' ? 'landing-sixth-panel--en' : ''}`}
  data-sixth-panel
  aria-label={title}
>
  <div class="landing-sixth-panel__veil" aria-hidden="true"></div>
  <div class="landing-sixth-panel__inner">
    <article class="landing-sixth-panel__block">
      <p class="landing-sixth-panel__label">{pickByLocale(locale, '参与', 'Join')}</p>
      <h2 class="landing-sixth-panel__title">{title}</h2>
      <div class="landing-sixth-panel__divider" aria-hidden="true"></div>
      <p class="landing-sixth-panel__body">{body}</p>
      <a
        class="landing-sixth-panel__btn"
        href={toLocalePath(locale, '/contact')}
      >
        {btnLabel}
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M13.172 12l-4.95-4.95 1.414-1.414L16 12l-6.364 6.364-1.414-1.414z"/>
        </svg>
      </a>
    </article>
  </div>
</section>

<style>
  .landing-sixth-panel {
    position: fixed;
    inset: 0;
    z-index: 44;
    background: transparent;
    color: var(--color-secondary-foreground);
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .landing-sixth-panel__veil {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 90% 90% at 110% 110%,
        color-mix(in srgb, var(--color-secondary) 16%, transparent) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse 90% 90% at -10% -10%,
        color-mix(in srgb, var(--color-primary) 12%, transparent) 0%,
        transparent 60%
      );
  }

  .landing-sixth-panel__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 720px;
    padding: clamp(4rem, 12vh, 8rem) clamp(1.4rem, 5vw, 4rem);
    /* Right-aligned for visual variety */
    margin-left: auto;
    margin-right: clamp(2rem, 8vw, 12rem);
  }

  .landing-sixth-panel__block {
    display: grid;
    gap: 0;
  }

  .landing-sixth-panel__label {
    margin: 0 0 0.6rem;
    font-size: clamp(0.72rem, 0.5vw + 0.56rem, 0.9rem);
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-secondary);
    opacity: 0.78;
  }

  .landing-sixth-panel__title {
    margin: 0 0 clamp(1.2rem, 2.5vh, 2rem);
    font-size: clamp(2.4rem, 4vw + 1rem, 5.2rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.06;
    color: var(--color-text-primary);
  }

  .landing-sixth-panel__divider {
    width: clamp(40px, 8vw, 80px);
    height: 1px;
    background: color-mix(in srgb, var(--color-secondary) 48%, transparent);
    margin-bottom: clamp(1.4rem, 3vh, 2.4rem);
  }

  .landing-sixth-panel__body {
    margin: 0 0 clamp(2rem, 4vh, 3.2rem);
    font-size: clamp(1.1rem, 0.8vw + 0.8rem, 1.6rem);
    line-height: 1.84;
    color: color-mix(in srgb, var(--color-text-secondary) 88%, transparent);
    max-width: 56ch;
  }

  .landing-sixth-panel__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.76rem 1.6rem 0.72rem;
    border: 1.5px solid color-mix(in srgb, var(--color-secondary) 56%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
    color: var(--color-secondary);
    font-family: 'POIRETONE-REGULAR', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.8rem, 0.6vw + 0.6rem, 1rem);
    letter-spacing: 0.1em;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-secondary) 18%, transparent);
    transition: background 200ms ease, box-shadow 200ms ease;
    width: fit-content;
    /* violet accent for join panel */
    filter: none;
  }

  .landing-sixth-panel__btn svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    flex-shrink: 0;
  }

  .landing-sixth-panel__btn:hover,
  .landing-sixth-panel__btn:focus-visible {
    background: color-mix(in srgb, var(--color-secondary) 18%, transparent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-secondary) 30%, transparent);
  }

  @media (max-width: 720px) {
    .landing-sixth-panel__inner {
      margin-left: 0;
      margin-right: 0;
    }

    .landing-sixth-panel__title {
      font-size: clamp(2rem, 5vw + 0.5rem, 3.2rem);
    }

    .landing-sixth-panel__body {
      font-size: clamp(1rem, 1vw + 0.76rem, 1.36rem);
    }
  }
</style>
