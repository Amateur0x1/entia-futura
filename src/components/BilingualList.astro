---
interface Props {
  zhTitle?: string;
  enTitle?: string;
  zhItems: string[];
  enItems: string[];
}

const { zhTitle = '中文', enTitle = 'English', zhItems, enItems } = Astro.props;
---

<div class="list-columns">
  <div class="list-card">
    <div class="section-heading">
      <h2>{zhTitle}</h2>
    </div>
    <ul class="clean">
      {zhItems.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
  <div class="list-card">
    <div class="section-heading">
      <h2>{enTitle}</h2>
    </div>
    <ul class="clean">
      {enItems.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
</div>
