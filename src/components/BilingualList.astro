---
import { pickByLocale, type Locale } from '../i18n/config';

interface Props {
  zhTitle?: string;
  enTitle?: string;
  zhItems: string[];
  enItems: string[];
  locale?: Locale;
}

const { zhTitle = '中文', enTitle = 'English', zhItems, enItems, locale } = Astro.props;
---

{
  locale ? (
    <div class="list-columns localized-list">
      <div class="list-card">
        <div class="section-heading">
          <h2>{pickByLocale(locale, zhTitle, enTitle)}</h2>
        </div>
        <ul class="clean">
          {pickByLocale(locale, zhItems, enItems).map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  ) : (
    <div class="list-columns">
      <div class="list-card">
        <div class="section-heading">
          <h2>{zhTitle}</h2>
        </div>
        <ul class="clean">
          {zhItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
      <div class="list-card">
        <div class="section-heading">
          <h2>{enTitle}</h2>
        </div>
        <ul class="clean">
          {enItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  )
}
