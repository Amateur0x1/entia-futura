---
import { pickByLocale, toLocalePath, type Locale } from '../i18n/config';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
---

<div class="locale-switcher" aria-label={pickByLocale(locale, '语言切换', 'Language switcher')}>
  <a class:list={['locale-link', { active: locale === 'zh' }]} href={toLocalePath('zh', currentPath)}>
    中文
  </a>
  <a class:list={['locale-link', { active: locale === 'en' }]} href={toLocalePath('en', currentPath)}>
    EN
  </a>
</div>
