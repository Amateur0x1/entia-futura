---
import BilingualIntro from './BilingualIntro.astro';
import { pickByLocale, type Locale } from '../i18n/config';

interface Props {
  eyebrow?: string;
  zhTitle: string;
  enTitle: string;
  zhBody: string;
  enBody: string;
  locale?: Locale;
}

const { eyebrow, zhTitle, enTitle, zhBody, enBody, locale } = Astro.props;
---

<section class="section-card">
  <div class="section-heading">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{pickByLocale(locale ?? 'zh', zhTitle, enTitle)}</h2>
    {!locale && <p>{enTitle}</p>}
  </div>
  <BilingualIntro zh={zhBody} en={enBody} locale={locale} />
</section>
