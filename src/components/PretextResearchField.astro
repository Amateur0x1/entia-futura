---
const fieldConfig = {
  zhText:
    '未来人研究所不把研究理解为静态结论，而把它理解为一种持续移动的问题场。AI、组织、品牌、空间、地方与共同体并不会彼此分离地变化，它们会不断碰撞、重组，并迫使我们重新发明知识进入现实的方式。\n\n我们真正关心的，不是技术能替代什么，而是当技术、制度与生活方式一起变形时，未来我们将如何学习、工作、连接、居住与存在。',
  enText:
    'Entia Futura Institut treats research as a live field rather than a fixed archive. AI, institutions, place, commerce, and collective life move through one another, continuously changing the frame of the question.\n\nThe challenge is not simply to describe the future, but to build forms that can think with motion: research that enters practice, ventures that emerge from inquiry, and communities that can metabolize change.',
  orbs: [
    { label: 'AI', color: [226, 178, 74], fx: 0.2, fy: 0.26, radius: 72, ampX: 18, ampY: 12, speed: 0.9, phase: 0.5 },
    { label: 'Institutions', color: [138, 171, 122], fx: 0.7, fy: 0.2, radius: 84, ampX: 22, ampY: 14, speed: 0.72, phase: 1.2 },
    { label: 'Place', color: [188, 116, 93], fx: 0.28, fy: 0.68, radius: 96, ampX: 20, ampY: 16, speed: 0.56, phase: 2.5 },
    { label: 'Collective Life', color: [110, 132, 166], fx: 0.76, fy: 0.7, radius: 78, ampX: 16, ampY: 18, speed: 0.84, phase: 3.1 },
  ],
};
---

<section class="section-card pretext-research-field">
  <div class="section-heading">
    <p class="eyebrow">Pretext Motion Study</p>
    <h2>研究场域动效实验</h2>
    <p>A live editorial field built with pretext</p>
  </div>

  <div class="pretext-field-copy-block">
    <p>
      我们更适合做“文字与研究对象一起运动”的版块，而不是泛用的视差、飞入或粒子装饰。这个模块把研究文本本身当作可重排的材料。
    </p>
    <p>
      This site benefits more from motion that reorganizes meaning than motion that merely decorates the page. Here, text reflows around moving fields in real time.
    </p>
  </div>

  <div class="pretext-field-stage" data-pretext-stage>
    <div class="pretext-field-fallback">
      <p>
        未来人研究所不把研究理解为静态结论，而把它理解为一种持续移动的问题场。AI、组织、品牌、空间、地方与共同体并不会彼此分离地变化，它们会不断碰撞、重组，并迫使我们重新发明知识进入现实的方式。
      </p>
      <p>
        Entia Futura Institut treats research as a live field rather than a fixed archive. AI, institutions, place, commerce, and collective life move through one another, continuously changing the frame of the question.
      </p>
    </div>
    <div class="pretext-field-accessible">
      <p>
        未来人研究所不把研究理解为静态结论，而把它理解为一种持续移动的问题场。AI、组织、品牌、空间、地方与共同体并不会彼此分离地变化，它们会不断碰撞、重组，并迫使我们重新发明知识进入现实的方式。
      </p>
      <p>
        我们真正关心的，不是技术能替代什么，而是当技术、制度与生活方式一起变形时，未来我们将如何学习、工作、连接、居住与存在。
      </p>
      <p>
        Entia Futura Institut treats research as a live field rather than a fixed archive. AI, institutions, place, commerce, and collective life move through one another, continuously changing the frame of the question.
      </p>
      <p>
        The challenge is not simply to describe the future, but to build forms that can think with motion: research that enters practice, ventures that emerge from inquiry, and communities that can metabolize change.
      </p>
    </div>
  </div>

  <div class="pretext-field-meta">
    <span>pretext manual line layout</span>
    <span>cursor-reactive editorial flow</span>
    <span>no DOM text measurement</span>
  </div>

  <script type="application/json" data-pretext-config set:html={JSON.stringify(fieldConfig)}></script>

  <script>
    import {
      layoutNextLine,
      prepareWithSegments,
      type LayoutCursor,
      type PreparedTextWithSegments,
    } from '@chenglou/pretext';

    type OrbConfig = {
      label: string;
      color: [number, number, number];
      fx: number;
      fy: number;
      radius: number;
      ampX: number;
      ampY: number;
      speed: number;
      phase: number;
    };

    type FieldConfig = {
      zhText: string;
      enText: string;
      orbs: OrbConfig[];
    };

    type Interval = {
      left: number;
      right: number;
    };

    type PositionedLine = {
      x: number;
      y: number;
      text: string;
      font: string;
      lineHeight: number;
      tone: 'zh' | 'en';
    };

    type OrbState = OrbConfig & {
      offsetX: number;
      offsetY: number;
      velocityX: number;
      velocityY: number;
      x: number;
      y: number;
      currentRadius: number;
    };

    function carveSlots(base: Interval, blocked: Interval[], minimumWidth: number): Interval[] {
      let slots = [base];
      for (let blockedIndex = 0; blockedIndex < blocked.length; blockedIndex++) {
        const interval = blocked[blockedIndex]!;
        const next: Interval[] = [];
        for (let slotIndex = 0; slotIndex < slots.length; slotIndex++) {
          const slot = slots[slotIndex]!;
          if (interval.right <= slot.left || interval.left >= slot.right) {
            next.push(slot);
            continue;
          }
          if (interval.left > slot.left) next.push({ left: slot.left, right: interval.left });
          if (interval.right < slot.right) next.push({ left: interval.right, right: slot.right });
        }
        slots = next;
      }
      return slots.filter((slot) => slot.right - slot.left >= minimumWidth);
    }

    function circleIntervalForBand(
      cx: number,
      cy: number,
      radius: number,
      bandTop: number,
      bandBottom: number,
      horizontalPad: number,
      verticalPad: number,
    ): Interval | null {
      const top = bandTop - verticalPad;
      const bottom = bandBottom + verticalPad;
      if (top >= cy + radius || bottom <= cy - radius) return null;

      const minDy = cy >= top && cy <= bottom ? 0 : cy < top ? top - cy : cy - bottom;
      if (minDy >= radius) return null;

      const maxDx = Math.sqrt(radius * radius - minDy * minDy);
      return {
        left: cx - maxDx - horizontalPad,
        right: cx + maxDx + horizontalPad,
      };
    }

    function syncPool<T extends HTMLElement>(
      pool: T[],
      targetSize: number,
      createElement: () => T,
      mountPoint: HTMLElement,
    ): void {
      while (pool.length < targetSize) {
        const element = createElement();
        mountPoint.appendChild(element);
        pool.push(element);
      }

      for (let index = 0; index < pool.length; index++) {
        pool[index]!.style.display = index < targetSize ? '' : 'none';
      }
    }

    function layoutFieldBlock(
      prepared: PreparedTextWithSegments,
      font: string,
      lineHeight: number,
      regionX: number,
      regionY: number,
      regionWidth: number,
      regionBottom: number,
      circles: OrbState[],
      singleSlotOnly: boolean,
      minimumSlotWidth: number,
      tone: PositionedLine['tone'],
    ): { lines: PositionedLine[]; nextY: number } {
      let cursor: LayoutCursor = { segmentIndex: 0, graphemeIndex: 0 };
      let lineTop = regionY;
      const lines: PositionedLine[] = [];

      while (lineTop + lineHeight <= regionBottom) {
        const bandTop = lineTop;
        const bandBottom = lineTop + lineHeight;
        const blocked: Interval[] = [];

        for (let orbIndex = 0; orbIndex < circles.length; orbIndex++) {
          const orb = circles[orbIndex]!;
          const interval = circleIntervalForBand(
            orb.x,
            orb.y,
            orb.currentRadius,
            bandTop,
            bandBottom,
            14,
            4,
          );
          if (interval !== null) blocked.push(interval);
        }

        const slots = carveSlots(
          { left: regionX, right: regionX + regionWidth },
          blocked,
          minimumSlotWidth,
        );
        if (slots.length === 0) {
          lineTop += lineHeight;
          continue;
        }

        const orderedSlots = singleSlotOnly
          ? [
              slots.reduce((best, slot) => {
                const bestWidth = best.right - best.left;
                const slotWidth = slot.right - slot.left;
                if (slotWidth > bestWidth) return slot;
                if (slotWidth < bestWidth) return best;
                return slot.left < best.left ? slot : best;
              }),
            ]
          : [...slots].sort((left, right) => left.left - right.left);

        let exhausted = false;
        for (let slotIndex = 0; slotIndex < orderedSlots.length; slotIndex++) {
          const slot = orderedSlots[slotIndex]!;
          const line = layoutNextLine(prepared, cursor, slot.right - slot.left);
          if (line === null) {
            exhausted = true;
            break;
          }

          lines.push({
            x: Math.round(slot.left),
            y: Math.round(lineTop),
            text: line.text,
            font,
            lineHeight,
            tone,
          });
          cursor = line.end;
        }

        lineTop += lineHeight;
        if (exhausted) break;
      }

      return { lines, nextY: lineTop };
    }

    async function initPretextField(): Promise<void> {
      const stage = document.querySelector('[data-pretext-stage]');
      const configNode = document.querySelector('[data-pretext-config]');
      if (!(stage instanceof HTMLDivElement) || !(configNode instanceof HTMLScriptElement)) return;
      if (stage.dataset.pretextReady === 'true') return;

      const config = JSON.parse(configNode.textContent || '{}') as FieldConfig;
      if (!config.zhText || !config.enText || !Array.isArray(config.orbs)) return;

      stage.dataset.pretextReady = 'true';
      stage.dataset.enhanced = 'true';

      if ('fonts' in document) {
        await document.fonts.ready;
      }

      const BODY_FONT_FAMILY =
        '"Songti SC", "STSong", "Noto Serif SC", "Source Han Serif SC", "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif';
      const zhFont = `500 17px ${BODY_FONT_FAMILY}`;
      const enFont = `400 16px ${BODY_FONT_FAMILY}`;
      const zhLineHeight = 30;
      const enLineHeight = 28;
      const preparedZh = prepareWithSegments(config.zhText, zhFont, { whiteSpace: 'pre-wrap' });
      const preparedEn = prepareWithSegments(config.enText, enFont, { whiteSpace: 'pre-wrap' });

      const linePool: HTMLSpanElement[] = [];
      const orbPool: HTMLDivElement[] = [];
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const pointer = { x: -9999, y: -9999, active: false };
      const orbs: OrbState[] = config.orbs.map((orb) => ({
        ...orb,
        offsetX: 0,
        offsetY: 0,
        velocityX: 0,
        velocityY: 0,
        x: 0,
        y: 0,
        currentRadius: orb.radius,
      }));

      syncPool(
        orbPool,
        orbs.length,
        () => {
          const element = document.createElement('div');
          element.className = 'pretext-field-orb';
          element.setAttribute('aria-hidden', 'true');
          const label = document.createElement('span');
          label.className = 'pretext-field-orb-label';
          element.appendChild(label);
          return element;
        },
        stage,
      );

      let animationFrame = 0;
      let lastTime = 0;

      function scheduleRender(): void {
        if (animationFrame !== 0) return;
        animationFrame = requestAnimationFrame(render);
      }

      function render(now: number): void {
        animationFrame = 0;

        const width = stage.clientWidth;
        const height = stage.clientHeight;
        if (width === 0 || height === 0) return;

        const isNarrow = width < 720;
        const padX = isNarrow ? 18 : 28;
        const padY = isNarrow ? 18 : 28;
        const lineRegionX = padX;
        const lineRegionWidth = width - padX * 2;
        const topInset = isNarrow ? 16 : 24;
        const bottomInset = isNarrow ? 18 : 24;
        const gapBetweenBlocks = isNarrow ? 18 : 22;
        const zhMinimumSlotWidth = isNarrow ? 84 : 110;
        const enMinimumSlotWidth = isNarrow ? 150 : 190;
        const innerWidth = Math.max(1, width - padX * 2);
        const innerHeight = Math.max(1, height - padY * 2);
        const dt = lastTime === 0 ? 0.016 : Math.min((now - lastTime) / 1000, 0.04);
        const activeOrbs = isNarrow ? orbs.slice(0, 3) : orbs;

        for (let orbIndex = 0; orbIndex < orbs.length; orbIndex++) {
          const orb = orbs[orbIndex]!;
          const baseX = padX + orb.fx * innerWidth + Math.sin(now * 0.001 * orb.speed + orb.phase) * orb.ampX;
          const baseY = padY + orb.fy * innerHeight + Math.cos(now * 0.001 * orb.speed * 0.9 + orb.phase) * orb.ampY;
          const radiusScale = isNarrow ? 0.82 : 1;

          if (!reduceMotion.matches) {
            if (pointer.active) {
              const currentX = baseX + orb.offsetX;
              const currentY = baseY + orb.offsetY;
              const dx = currentX - pointer.x;
              const dy = currentY - pointer.y;
              const distance = Math.sqrt(dx * dx + dy * dy);
              const influence = Math.max(140, orb.radius * 2.4);
              if (distance > 0 && distance < influence) {
                const strength = (1 - distance / influence) * 460 * dt;
                orb.velocityX += (dx / distance) * strength;
                orb.velocityY += (dy / distance) * strength;
              }
            }

            orb.velocityX += -orb.offsetX * 3.1 * dt;
            orb.velocityY += -orb.offsetY * 3.1 * dt;
            orb.velocityX *= 0.92;
            orb.velocityY *= 0.92;
            orb.offsetX += orb.velocityX;
            orb.offsetY += orb.velocityY;
          } else {
            orb.offsetX = 0;
            orb.offsetY = 0;
            orb.velocityX = 0;
            orb.velocityY = 0;
          }

          orb.x = baseX + orb.offsetX;
          orb.y = baseY + orb.offsetY;
          orb.currentRadius = orb.radius * radiusScale;
        }

        const zhLayout = layoutFieldBlock(
          preparedZh,
          zhFont,
          zhLineHeight,
          lineRegionX,
          padY + topInset,
          lineRegionWidth,
          height - padY - bottomInset,
          activeOrbs,
          isNarrow,
          zhMinimumSlotWidth,
          'zh',
        );

        const enStartY = Math.min(
          zhLayout.nextY + gapBetweenBlocks,
          height - padY - bottomInset - enLineHeight * 3,
        );

        const enLayout = layoutFieldBlock(
          preparedEn,
          enFont,
          enLineHeight,
          lineRegionX,
          enStartY,
          lineRegionWidth,
          height - padY - bottomInset,
          activeOrbs,
          true,
          enMinimumSlotWidth,
          'en',
        );

        const allLines = [...zhLayout.lines, ...enLayout.lines];

        syncPool(
          linePool,
          allLines.length,
          () => {
            const element = document.createElement('span');
            element.className = 'pretext-field-line';
            element.setAttribute('aria-hidden', 'true');
            return element;
          },
          stage,
        );

        for (let lineIndex = 0; lineIndex < allLines.length; lineIndex++) {
          const line = allLines[lineIndex]!;
          const element = linePool[lineIndex]!;
          element.className = `pretext-field-line pretext-field-line-${line.tone}`;
          element.textContent = line.text.length > 0 ? line.text : '\u00A0';
          element.style.left = `${line.x}px`;
          element.style.top = `${line.y}px`;
          element.style.font = line.font;
          element.style.lineHeight = `${line.lineHeight}px`;
        }

        for (let orbIndex = 0; orbIndex < orbPool.length; orbIndex++) {
          const element = orbPool[orbIndex]!;
          const orb = orbs[orbIndex]!;
          const label = element.firstElementChild;
          const isActive = orbIndex < activeOrbs.length;
          if (!isActive) {
            element.style.display = 'none';
            continue;
          }

          element.style.display = '';
          element.style.left = `${orb.x - orb.currentRadius}px`;
          element.style.top = `${orb.y - orb.currentRadius}px`;
          element.style.width = `${orb.currentRadius * 2}px`;
          element.style.height = `${orb.currentRadius * 2}px`;
          element.style.setProperty('--orb-rgb', `${orb.color[0]} ${orb.color[1]} ${orb.color[2]}`);
          if (label instanceof HTMLSpanElement) label.textContent = orb.label;
        }

        lastTime = now;
        if (!reduceMotion.matches) scheduleRender();
      }

      stage.addEventListener('pointermove', (event) => {
        const rect = stage.getBoundingClientRect();
        pointer.x = event.clientX - rect.left;
        pointer.y = event.clientY - rect.top;
        pointer.active = true;
        scheduleRender();
      });

      stage.addEventListener('pointerleave', () => {
        pointer.active = false;
        pointer.x = -9999;
        pointer.y = -9999;
        scheduleRender();
      });

      window.addEventListener('resize', () => {
        lastTime = 0;
        scheduleRender();
      });

      reduceMotion.addEventListener('change', () => {
        lastTime = 0;
        scheduleRender();
      });

      scheduleRender();
    }

    void initPretextField();
  </script>
</section>

<style>
  .pretext-research-field {
    overflow: hidden;
  }

  .pretext-field-copy-block {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin: 24px 0 18px;
  }

  .pretext-field-copy-block p {
    margin: 0;
    padding: 18px 20px;
    border: 1px solid rgba(23, 23, 23, 0.08);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.56);
    color: rgba(23, 23, 23, 0.76);
    line-height: 1.7;
  }

  .pretext-field-stage {
    position: relative;
    min-height: 580px;
    overflow: hidden;
    border: 1px solid rgba(23, 23, 23, 0.1);
    border-radius: 26px;
    background:
      radial-gradient(circle at 18% 18%, rgba(243, 236, 89, 0.22), transparent 20rem),
      radial-gradient(circle at 84% 22%, rgba(138, 171, 122, 0.18), transparent 22rem),
      radial-gradient(circle at 48% 86%, rgba(188, 116, 93, 0.14), transparent 18rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(243, 244, 239, 0.94));
  }

  .pretext-field-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(23, 23, 23, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(23, 23, 23, 0.03) 1px, transparent 1px);
    background-size: 100% 44px, 44px 100%;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.36), transparent 78%);
    pointer-events: none;
  }

  .pretext-field-fallback {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 16px;
    padding: 28px;
  }

  .pretext-field-fallback p {
    margin: 0;
    max-width: 62ch;
    color: rgba(23, 23, 23, 0.78);
    line-height: 1.8;
  }

  .pretext-field-stage[data-enhanced='true'] .pretext-field-fallback {
    display: none;
  }

  .pretext-field-accessible {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .pretext-field-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }

  .pretext-field-meta span {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid rgba(23, 23, 23, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.58);
    color: rgba(23, 23, 23, 0.68);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  :global(.pretext-field-line) {
    position: absolute;
    z-index: 2;
    white-space: pre;
    pointer-events: none;
  }

  :global(.pretext-field-line-zh) {
    color: rgba(23, 23, 23, 0.9);
    letter-spacing: 0.02em;
  }

  :global(.pretext-field-line-en) {
    color: rgba(23, 23, 23, 0.72);
  }

  :global(.pretext-field-orb) {
    position: absolute;
    z-index: 3;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background:
      radial-gradient(circle at 32% 28%, rgb(var(--orb-rgb) / 0.64), rgb(255 255 255 / 0.18) 36%, rgb(var(--orb-rgb) / 0.12) 64%, transparent 76%),
      linear-gradient(180deg, rgb(255 255 255 / 0.22), rgb(255 255 255 / 0.04));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 20px 50px rgb(var(--orb-rgb) / 0.22);
    backdrop-filter: blur(18px);
    pointer-events: none;
  }

  :global(.pretext-field-orb-label) {
    width: min(72%, 8rem);
    color: rgba(255, 255, 255, 0.92);
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-align: center;
    text-transform: uppercase;
    text-wrap: balance;
    line-height: 1.35;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.14);
  }

  @media (max-width: 920px) {
    .pretext-field-copy-block {
      grid-template-columns: 1fr;
    }

    .pretext-field-stage {
      min-height: 520px;
    }
  }

  @media (max-width: 720px) {
    .pretext-field-stage {
      min-height: 460px;
      border-radius: 22px;
    }

    .pretext-field-meta {
      gap: 8px;
    }

    .pretext-field-meta span {
      min-height: 34px;
      padding: 0 12px;
      font-size: 0.74rem;
    }
  }
</style>
