---
import { navItems, siteMeta } from '../content/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${siteMeta.zhName} | ${siteMeta.enName}`,
  description = siteMeta.oneLineEn,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteMeta.siteUrl}${currentPath}`} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteMeta.siteUrl}/brand/entia-logo.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#eef0e8" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <img src="/brand/entia-logo.png" alt="Entia Futura logo" />
          <div class="brand-copy">
            <span class="brand-zh">{siteMeta.zhName}</span>
            <span class="brand-en">{siteMeta.enName}</span>
          </div>
        </a>
        <nav class="nav">
          {navItems.map((item) => (
            <a class:list={['nav-link', { active: currentPath === item.href }]} href={item.href}>
              <span>{item.zh}</span>
              <small>{item.en}</small>
            </a>
          ))}
        </nav>
      </header>
      <slot />
      <footer class="site-footer">
        <div class="footer-brand">
          <p>{siteMeta.zhName}</p>
          <p>{siteMeta.enName}</p>
          <p>{siteMeta.enSubtitle}</p>
        </div>
        <div class="footer-statement">
          <p>{siteMeta.coreQuestionZh}</p>
          <p>{siteMeta.coreQuestionEn}</p>
          <p>{siteMeta.oneLineZh}</p>
          <p>{siteMeta.oneLineEn}</p>
        </div>
        <nav class="footer-nav">
          {navItems.slice(1).map((item) => (
            <a href={item.href}>{item.zh}</a>
          ))}
        </nav>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --paper: #eef0e8;
    --paper-2: #f8f8f3;
    --ink: #171717;
    --muted: rgba(23, 23, 23, 0.64);
    --line: rgba(23, 23, 23, 0.12);
    --accent: #f3ec59;
    --panel: rgba(255, 255, 255, 0.72);
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
    color: var(--ink);
    background: var(--paper);
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background:
      radial-gradient(circle at top left, rgba(243, 236, 89, 0.28), transparent 24rem),
      linear-gradient(180deg, var(--paper) 0%, #f4f4ef 55%, #eceee5 100%);
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    max-width: 1420px;
    margin: 0 auto;
    padding: 18px 24px 40px;
  }

  .site-header {
    position: sticky;
    top: 12px;
    z-index: 20;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 18px;
    align-items: start;
    margin-bottom: 28px;
    padding: 14px 18px;
    border: 1px solid var(--line);
    border-radius: 22px;
    backdrop-filter: blur(18px);
    background: rgba(248, 248, 243, 0.78);
  }

  .brand {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .brand img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid var(--line);
  }

  .brand-copy {
    display: grid;
    gap: 2px;
  }

  .brand-zh {
    font-size: 1rem;
    letter-spacing: 0.06em;
  }

  .brand-en {
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .nav-link {
    display: grid;
    gap: 2px;
    min-width: 100px;
    padding: 10px 12px;
    border: 1px solid transparent;
    border-radius: 14px;
    color: var(--muted);
    transition: all 160ms ease;
  }

  .nav-link span {
    font-size: 0.95rem;
  }

  .nav-link small {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--ink);
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.62);
  }

  main {
    display: grid;
    gap: 20px;
  }

  .hero-panel,
  .section-card,
  .content-card,
  .list-card,
  .contact-card {
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--panel);
    backdrop-filter: blur(18px);
    box-shadow: 0 24px 70px rgba(24, 29, 32, 0.06);
  }

  .hero-panel {
    padding: 32px;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--muted);
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-title-zh {
    margin: 0;
    font-size: clamp(2.8rem, 7vw, 5.8rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .hero-title-en {
    margin: 12px 0 0;
    font-size: clamp(1.35rem, 2.5vw, 2.1rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(23, 23, 23, 0.78);
  }

  .hero-subtitle {
    margin: 8px 0 0;
    font-size: 1.05rem;
    color: var(--muted);
  }

  .core-question {
    margin: 28px 0 0;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    display: grid;
    gap: 8px;
  }

  .core-question strong {
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 500;
  }

  .lede {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.95;
    color: rgba(23, 23, 23, 0.84);
  }

  .dual-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .lang-block h3 {
    margin: 0 0 12px;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
  }

  .lang-block p,
  .lang-block li,
  .content-card p,
  .list-card li,
  .contact-card p,
  .contact-card label {
    font-size: 1rem;
    line-height: 1.95;
    color: rgba(23, 23, 23, 0.86);
  }

  .section-card,
  .content-card,
  .list-card,
  .contact-card {
    padding: 28px;
  }

  .section-heading {
    display: grid;
    gap: 8px;
    margin-bottom: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.8rem);
    font-weight: 500;
  }

  .section-heading p {
    margin: 0;
    color: var(--muted);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .mini-card {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.5);
  }

  .mini-card h3 {
    margin: 0 0 6px;
    font-size: 1.3rem;
    font-weight: 500;
  }

  .mini-card .en {
    display: block;
    margin-bottom: 14px;
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .mini-card p {
    margin: 0;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 18px;
    border: 1px solid var(--ink);
    border-radius: 999px;
    font-size: 0.95rem;
    transition: transform 160ms ease, background 160ms ease, color 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    background: var(--ink);
    color: var(--accent);
  }

  .button.secondary {
    background: transparent;
    color: var(--ink);
  }

  .list-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  ul.clean {
    margin: 0;
    padding-left: 18px;
  }

  .site-footer {
    display: grid;
    grid-template-columns: 1.1fr 1.4fr 1fr;
    gap: 18px;
    margin-top: 32px;
    padding: 22px;
    border-top: 1px solid var(--line);
  }

  .site-footer p,
  .site-footer a {
    margin: 0 0 8px;
    color: rgba(23, 23, 23, 0.72);
    line-height: 1.7;
  }

  .footer-nav {
    display: grid;
    gap: 4px;
  }

  .contact-form {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.72);
    font: inherit;
  }

  .contact-form textarea {
    min-height: 180px;
    resize: vertical;
  }

  @media (max-width: 1100px) {
    .site-header,
    .dual-grid,
    .cards-grid,
    .list-columns,
    .site-footer {
      grid-template-columns: 1fr;
    }

    .nav {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .page-shell {
      padding: 14px 14px 34px;
    }

    .site-header,
    .hero-panel,
    .section-card,
    .content-card,
    .list-card,
    .contact-card {
      padding: 20px;
      border-radius: 22px;
    }

    .brand {
      align-items: flex-start;
    }
  }
</style>
