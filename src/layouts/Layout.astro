---
import { siteMeta } from '../content/site';
import { getLocaleFromPath, pickByLocale, toLocalePath, type Locale } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  theme?: 'default' | 'landing-dark';
}

const {
  title = `${siteMeta.zhName} | ${siteMeta.enName}`,
  description = siteMeta.oneLineEn,
  locale,
  theme = 'default',
} = Astro.props;

const currentPath = Astro.url.pathname;
const activeLocale = locale ?? getLocaleFromPath(currentPath);
const localizedPath = activeLocale ? toLocalePath(activeLocale, currentPath) : currentPath;
const htmlLang = activeLocale === 'en' ? 'en' : 'zh-CN';
const navLinks = [
  { href: '/', zh: '首页', en: 'Home' },
  { href: '/contact', zh: '联系', en: 'Contact' },
];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="512x512" href="/brand/entia-logo-cutout.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/brand/entia-logo-cutout.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/brand/entia-logo-cutout.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteMeta.siteUrl}${currentPath}`} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteMeta.siteUrl}/brand/entia-logo-cutout.png`} />
    {activeLocale && <link rel="alternate" hreflang="zh-CN" href={`${siteMeta.siteUrl}${toLocalePath('zh', currentPath)}`} />}
    {activeLocale && <link rel="alternate" hreflang="en" href={`${siteMeta.siteUrl}${toLocalePath('en', currentPath)}`} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#05070B" />
  </head>
  <body class:list={{ 'theme-landing-dark': theme === 'landing-dark' }}>
    <div class="dot-bg-clip" aria-hidden="true">
      <div class="dot-bg-layer"></div>
    </div>
    <div class:list={['page-shell', { 'page-shell-landing': theme === 'landing-dark' }]}>
      {theme !== 'landing-dark' && (
        <header class="site-header">
          <a class="brand" href={activeLocale ? toLocalePath(activeLocale, '/') : '/'}>
            <div class="brand-copy">
              <span class="brand-zh">{siteMeta.zhName}</span>
              <span class="brand-en">{siteMeta.enName}</span>
            </div>
          </a>
          <nav class="nav">
            {navLinks.map((item) => (
              <a
                class:list={['nav-link', { active: localizedPath === (activeLocale ? toLocalePath(activeLocale, item.href) : item.href) }]}
                href={activeLocale ? toLocalePath(activeLocale, item.href) : item.href}
              >
                {
                  activeLocale ? (
                    <span>{pickByLocale(activeLocale, item.zh, item.en)}</span>
                  ) : (
                    <>
                      <span>{item.zh}</span>
                      <small>{item.en}</small>
                    </>
                  )
                }
              </a>
            ))}
          </nav>
        </header>
      )}
      <slot />
      {theme !== 'landing-dark' && (
        <footer class="site-footer">
          <div class="footer-brand">
            <p>{siteMeta.zhName}</p>
            <p>{siteMeta.enName}</p>
            <p>{siteMeta.enSubtitle}</p>
            <p>© {new Date().getFullYear()} Entia Futura Institut</p>
          </div>
          <div class="footer-statement">
            <p>{siteMeta.coreQuestionZh}</p>
            <p>{siteMeta.coreQuestionEn}</p>
            <p>{siteMeta.oneLineZh}</p>
            <p>{siteMeta.oneLineEn}</p>
          </div>
          <nav class="footer-nav">
            {navLinks.map((item) => (
              <a href={activeLocale ? toLocalePath(activeLocale, item.href) : item.href}>
                {activeLocale ? pickByLocale(activeLocale, item.zh, item.en) : item.zh}
              </a>
            ))}
          </nav>
          <div class="footer-meta">
            <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
            <a href={activeLocale ? toLocalePath(activeLocale, '/contact') : '/contact'}>
              {pickByLocale(activeLocale ?? 'zh', '联系方式', 'Contact')}
            </a>
            <a href={siteMeta.siteUrl} target="_blank" rel="noreferrer">entiafutura.com</a>
          </div>
        </footer>
      )}
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'POIRETONE-REGULAR';
    src: url('/fonts/POIRETONE-REGULAR.ttf') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    /* Palette layer */
    --palette-bg-deep-space: #05070b;
    --palette-bg-void-black: #0a0e14;
    --palette-bg-cosmic-navy: #0f172a;
    --palette-bg-stardust-navy: #111827;
    --palette-bg-nebula-blue: #1b2336;
    --palette-bg-space-steel: #1f2937;
    --palette-surface-elevated: #11151e;
    --palette-surface-glass: #0d1117cc;
    --palette-text-starlight-white: #f5f7fa;
    --palette-text-cosmic-silver: #ccd2e0;
    --palette-text-galactic-grey: #a3a8b8;
    --palette-text-neutral-grey: #7b8494;
    --palette-text-subtle-grey: #5a6272;
    --palette-text-muted-grey: #3b4252;
    --palette-text-disabled-grey: #292a36;
    --palette-cosmic-cyan: #00e5ff;
    --palette-cyan-glow: #00e5ff66;
    --palette-cosmic-violet: #7b5cff;
    --palette-violet-glow: #8266ff66;
    --palette-hover-overlay: #ffffff1a;
    --palette-focus-ring: #7b5cff;
    --palette-pressed-overlay: #00e5ff33;
    --palette-success-500: #22d39a;
    --palette-success-glow: #22d39a66;
    --palette-warning-500: #f5a52a;
    --palette-warning-glow: #f5a52a66;
    --palette-error-500: #ff4d4f;
    --palette-error-glow: #ff4d4f66;
    --palette-info-500: #4da3ff;
    --palette-info-glow: #4da3ff66;

    /* Semantic layer */
    --color-background: var(--palette-bg-deep-space);
    --color-background-subtle: var(--palette-bg-void-black);
    --color-background-strong: var(--palette-bg-cosmic-navy);
    --color-surface-base: transparent;
    --color-surface: var(--palette-surface-elevated);
    --color-surface-variant: var(--palette-bg-stardust-navy);
    --color-surface-strong: var(--palette-bg-nebula-blue);
    --color-surface-glass: var(--palette-surface-glass);
    --color-surface-overlay: var(--palette-surface-glass);
    --color-surface-input: var(--palette-bg-nebula-blue);
    --color-surface-accent: color-mix(in srgb, var(--color-primary) 12%, transparent);
    --color-surface-interactive: color-mix(in srgb, var(--color-secondary) 18%, transparent);
    --color-surface-primary: var(--color-primary);
    --color-text-primary: var(--palette-text-starlight-white);
    --color-text-secondary: var(--palette-text-cosmic-silver);
    --color-text-body: var(--palette-text-cosmic-silver);
    --color-text-tertiary: var(--palette-text-galactic-grey);
    --color-text-muted: var(--palette-text-subtle-grey);
    --color-text-footer: var(--palette-text-neutral-grey);
    --color-text-disabled: var(--palette-text-disabled-grey);
    --color-text-inverse: var(--palette-bg-deep-space);
    --color-text-inverse-muted: var(--palette-text-muted-grey);
    --color-text-on-accent: var(--color-primary-foreground);
    --color-primary: var(--palette-cosmic-cyan);
    --color-primary-foreground: var(--palette-bg-deep-space);
    --color-secondary: var(--palette-cosmic-violet);
    --color-secondary-foreground: var(--palette-text-starlight-white);
    --color-accent: var(--palette-cosmic-cyan);
    --color-link: var(--palette-cosmic-cyan);
    --color-success: var(--palette-success-500);
    --color-warning: var(--palette-warning-500);
    --color-error: var(--palette-error-500);
    --color-info: var(--palette-info-500);
    --color-border: var(--palette-bg-space-steel);
    --color-border-subtle: color-mix(in srgb, var(--palette-text-cosmic-silver) 8%, transparent);
    --color-border-medium: color-mix(in srgb, var(--palette-text-cosmic-silver) 16%, transparent);
    --color-border-strong: color-mix(in srgb, var(--palette-text-cosmic-silver) 24%, transparent);
    --color-border-soft: color-mix(in srgb, var(--palette-bg-space-steel) 72%, transparent);
    --color-border-accent: var(--palette-violet-glow);
    --color-border-accent-medium: color-mix(in srgb, var(--palette-cosmic-violet) 34%, transparent);
    --color-border-accent-soft: color-mix(in srgb, var(--palette-cosmic-violet) 22%, transparent);
    --color-border-signal: color-mix(in srgb, var(--palette-cosmic-cyan) 56%, transparent);
    --color-border-inverse: color-mix(in srgb, var(--palette-text-starlight-white) 12%, transparent);
    --color-border-inverse-strong: color-mix(in srgb, var(--palette-text-starlight-white) 22%, transparent);
    --color-border-inverse-accent: var(--palette-violet-glow);
    --color-divider: var(--color-border);
    --color-ring: var(--palette-focus-ring);
    --color-atmosphere-primary: color-mix(in srgb, var(--color-primary) 18%, transparent);
    --color-atmosphere-secondary: color-mix(in srgb, var(--color-secondary) 22%, transparent);
    --color-atmosphere-tertiary: color-mix(in srgb, var(--palette-text-cosmic-silver) 14%, transparent);
    --color-shadow-soft: rgba(0, 0, 0, 0.24);
    --color-shadow-medium: rgba(0, 0, 0, 0.36);
    --color-secondary-border: color-mix(in srgb, var(--palette-text-cosmic-silver) 24%, transparent);

    /* Effect layer */
    --effect-glow-primary: var(--palette-cyan-glow);
    --effect-glow-secondary: var(--palette-violet-glow);
    --effect-glow-success: var(--palette-success-glow);
    --effect-glow-warning: var(--palette-warning-glow);
    --effect-glow-error: var(--palette-error-glow);
    --effect-glow-info: var(--palette-info-glow);
    --effect-hover-overlay: var(--palette-hover-overlay);
    --effect-pressed-overlay: var(--palette-pressed-overlay);

    /* Composed tokens */
    --gradient-page: linear-gradient(180deg, var(--color-background) 0%, var(--color-background-strong) 100%);
    --gradient-atmosphere-primary:
      radial-gradient(circle, var(--effect-glow-primary) 0%, color-mix(in srgb, var(--color-primary) 16%, transparent) 58%, rgba(0, 229, 255, 0) 78%);
    --gradient-atmosphere-secondary:
      radial-gradient(circle, var(--effect-glow-secondary) 0%, color-mix(in srgb, var(--color-secondary) 14%, transparent) 74%);
    --gradient-orb-primary:
      radial-gradient(circle, color-mix(in srgb, var(--color-primary) 78%, white 22%) 0%, color-mix(in srgb, var(--color-primary) 12%, transparent) 64%, transparent 78%);
    --gradient-orb-secondary:
      radial-gradient(
        circle,
        color-mix(in srgb, var(--color-secondary) 52%, transparent) 0%,
        color-mix(in srgb, var(--color-secondary) 8%, transparent) 68%,
        transparent 80%
      );
    --gradient-orb-tertiary:
      radial-gradient(circle, color-mix(in srgb, var(--palette-text-cosmic-silver) 30%, transparent) 0%, color-mix(in srgb, var(--palette-text-cosmic-silver) 3%, transparent) 60%, transparent 76%);
    --pattern-hero-grid:
      linear-gradient(var(--color-border-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border-subtle) 1px, transparent 1px);
    --gradient-hero-stage:
      radial-gradient(circle at 50% 42%, color-mix(in srgb, var(--palette-text-cosmic-silver) 12%, transparent), transparent 20rem),
      linear-gradient(180deg, var(--color-background) 0%, var(--color-background-subtle) 50%, var(--color-background-strong) 100%);
    --gradient-hero-overlay:
      radial-gradient(circle at 50% 48%, var(--color-atmosphere-tertiary), transparent 14rem),
      linear-gradient(180deg, rgba(5, 7, 11, 0.08), rgba(10, 14, 20, 0.28) 68%, rgba(5, 7, 11, 0.72));
    --gradient-hero-vignette:
      radial-gradient(circle at 50% 56%, rgba(5, 7, 11, 0), rgba(5, 7, 11, 0.34) 58%, rgba(5, 7, 11, 0.9) 100%);
    --gradient-loading-screen: linear-gradient(180deg, rgba(5, 7, 11, 0.98), rgba(10, 14, 20, 0.82));
    --gradient-interactive-sheen: linear-gradient(120deg, transparent 20%, var(--effect-glow-primary) 50%, transparent 80%);
    --filter-hero-scroll: saturate(0.92) contrast(1.02) brightness(0.94);
    --filter-hero-loop: saturate(0.94) contrast(1.02) brightness(0.92);
    --shadow-hero-figure: drop-shadow(0 26px 40px rgba(0, 0, 0, 0.28));
    --shadow-interactive-hover: 0 12px 24px rgba(0, 0, 0, 0.34);

    color-scheme: dark;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
    color: var(--color-text-primary);
    background: var(--color-background);
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background-color: var(--color-background);
  }

  /* ── Rotating dot grid — HOME only ──────────────────────────────────────── */

  /* Clipping container — fixed, fills viewport, clips overflow */
  .dot-bg-clip {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  /* The actual dot layer that rotates inside the clip container */
  .dot-bg-layer {
    position: absolute;
    inset: -5%;
    background-image: radial-gradient(circle, color-mix(in srgb, var(--color-text-primary) 50%, transparent) 22%, transparent 23%);
    background-size: 28px 28px;
    transform-origin: center center;
    animation: dot-warp 14s ease-in-out infinite;
  }

  /* Non-home pages: hide the rotating dot grid */
  body:not(.theme-landing-dark) .dot-bg-clip {
    display: none;
  }

  @keyframes dot-warp {
    0%   { transform: perspective(800px) rotateX(0deg)  rotateY(0deg);  }
    25%  { transform: perspective(800px) rotateX(10deg) rotateY(-7deg); }
    50%  { transform: perspective(800px) rotateX(0deg)  rotateY(10deg); }
    75%  { transform: perspective(800px) rotateX(-8deg) rotateY(-5deg); }
    100% { transform: perspective(800px) rotateX(0deg)  rotateY(0deg);  }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot-bg-layer {
      animation: none;
    }
  }

  /* ── Ambient glow — NON-HOME pages ───────────────────────────────────────── */
  /* Top-left: primary (cyan), bottom-right: secondary (violet)                */

  body:not(.theme-landing-dark)::before,
  body:not(.theme-landing-dark)::after {
    content: '';
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(120px);
  }

  /* Top-left cyan glow */
  body:not(.theme-landing-dark)::before {
    width: 55vmax;
    height: 55vmax;
    top: -18vmax;
    left: -18vmax;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-primary) 18%, transparent) 0%,
      transparent 70%
    );
  }

  /* Bottom-right violet glow */
  body:not(.theme-landing-dark)::after {
    width: 55vmax;
    height: 55vmax;
    bottom: -18vmax;
    right: -18vmax;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--color-secondary) 18%, transparent) 0%,
      transparent 70%
    );
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    position: relative;
    z-index: 1;
    max-width: 1420px;
    margin: 0 auto;
    padding: 18px 24px 40px;
  }

  .site-header {
    position: relative;
    z-index: 20;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 18px;
    align-items: center;
    margin-bottom: 28px;
    padding: 14px 18px;
    border: 1px solid var(--color-border);
    border-radius: 18px;
    backdrop-filter: blur(16px) saturate(140%);
    background: var(--color-surface-glass);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-text-primary) 8%, transparent),
      0 18px 48px rgba(0, 0, 0, 0.22);
  }

  .brand {
    display: flex;
    align-items: center;
  }

  .brand-copy {
    display: grid;
    gap: 2px;
  }

  .brand-zh {
    font-size: 1rem;
    letter-spacing: 0.06em;
    font-family: 'POIRETONE-REGULAR', "Hiragino Sans GB", "Noto Sans SC", sans-serif;
    font-weight: 400;
  }

  .brand-en {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-family: 'POIRETONE-REGULAR', "Helvetica Neue", Arial, sans-serif;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .nav-link {
    position: relative;
    display: grid;
    gap: 2px;
    min-width: 100px;
    padding: 10px 14px;
    border: 1px solid transparent;
    border-radius: 14px;
    background: transparent;
    color: var(--color-text-muted);
    transition:
      color 160ms ease,
      background 160ms ease,
      border-color 160ms ease,
      box-shadow 200ms ease,
      transform 160ms ease;
  }

  .nav-link span {
    font-size: 0.95rem;
  }

  .nav-link small {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    right: 14px;
    bottom: 8px;
    left: 14px;
    height: 1.5px;
    border-radius: 999px;
    background: var(--color-primary);
    box-shadow: 0 0 14px var(--effect-glow-primary);
    opacity: 0;
    transform: scaleX(0.2);
    transform-origin: center;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .locale-switcher {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface-glass) 88%, transparent);
  }

  .locale-link {
    padding: 6px 10px;
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      background 160ms ease,
      color 160ms ease,
      box-shadow 180ms ease;
  }

  .locale-link.active,
  .locale-link:hover {
    background: var(--effect-hover-overlay);
    color: var(--color-text-primary);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-secondary) 38%, transparent);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text-primary);
    border-color: color-mix(in srgb, var(--color-secondary) 42%, transparent);
    background: var(--effect-hover-overlay);
    box-shadow: 0 0 18px color-mix(in srgb, var(--effect-glow-secondary) 42%, transparent);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    opacity: 1;
    transform: scaleX(1);
  }


  .hero-panel,
  .section-card,
  .content-card,
  .list-card,
  .contact-card {
    position: relative;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    backdrop-filter: none;
  }

  .hero-panel {
    padding: 18px 0 42px;
    border-bottom: 1px solid var(--color-border);
  }

  .landing-hero {
    position: relative;
    overflow: clip;
    isolation: isolate;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  .landing-hero::before,
  .landing-hero::after {
    content: '';
    position: absolute;
    inset: auto;
    pointer-events: none;
    z-index: -1;
    filter: blur(10px);
  }

  .landing-hero::before {
    top: -2rem;
    right: 10%;
    width: min(42vw, 28rem);
    height: min(42vw, 28rem);
    border-radius: 50%;
    background: var(--gradient-atmosphere-primary);
  }

  .landing-hero::after {
    bottom: 2rem;
    left: -2rem;
    width: min(38vw, 24rem);
    height: min(20vw, 10rem);
    border-radius: 999px;
    background: var(--gradient-atmosphere-secondary);
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(8px);
    opacity: 0.8;
    mix-blend-mode: multiply;
  }

  .hero-orb-a {
    top: 0;
    right: 2%;
    width: min(26vw, 16rem);
    height: min(26vw, 16rem);
    background: var(--gradient-orb-primary);
  }

  .hero-orb-b {
    bottom: 18%;
    right: 30%;
    width: min(16vw, 10rem);
    height: min(16vw, 10rem);
    background: var(--gradient-orb-secondary);
  }

  .hero-orb-c {
    bottom: 8%;
    left: 10%;
    width: min(30vw, 18rem);
    height: min(18vw, 10rem);
    border-radius: 999px;
    background: var(--gradient-orb-tertiary);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: var(--pattern-hero-grid);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black 20%, transparent 84%);
    opacity: 0.28;
  }

  .hero-stage {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 44rem) minmax(0, 1fr);
    grid-template-rows: minmax(24rem, 1fr) auto;
    grid-template-areas:
      ". visual ."
      ". bottom .";
    gap: 24px 28px;
    min-height: min(76vh, 52rem);
  }

  .hero-heading-shell {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--color-text-muted);
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-title-zh {
    margin: 0;
