---
import { navItems, siteMeta } from '../content/site';
import { getLocaleFromPath, pickByLocale, toLocalePath, type Locale } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  theme?: 'default' | 'landing-dark';
}

const {
  title = `${siteMeta.zhName} | ${siteMeta.enName}`,
  description = siteMeta.oneLineEn,
  locale,
  theme = 'default',
} = Astro.props;

const currentPath = Astro.url.pathname;
const activeLocale = locale ?? getLocaleFromPath(currentPath);
const localizedPath = activeLocale ? toLocalePath(activeLocale, currentPath) : currentPath;
const htmlLang = activeLocale === 'en' ? 'en' : 'zh-CN';
const primaryNavItems = navItems.filter((item) => item.href !== '/publications').slice(0, 4);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="512x512" href="/brand/entia-logo-cutout.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/brand/entia-logo-cutout.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/brand/entia-logo-cutout.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${siteMeta.siteUrl}${currentPath}`} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteMeta.siteUrl}/brand/entia-logo-cutout.png`} />
    {activeLocale && <link rel="alternate" hrefLang="zh-CN" href={`${siteMeta.siteUrl}${toLocalePath('zh', currentPath)}`} />}
    {activeLocale && <link rel="alternate" hrefLang="en" href={`${siteMeta.siteUrl}${toLocalePath('en', currentPath)}`} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#090907" />
  </head>
  <body class:list={{ 'theme-landing-dark': theme === 'landing-dark' }}>
    <div class:list={['page-shell', { 'page-shell-landing': theme === 'landing-dark' }]}>
      <header class:list={['site-header', { 'site-header-landing': theme === 'landing-dark' }]}>
        <a class="brand" href={activeLocale ? toLocalePath(activeLocale, '/') : '/'}>
          <div class="brand-copy">
            <span class="brand-zh">{siteMeta.zhName}</span>
            <span class="brand-en">{siteMeta.enName}</span>
          </div>
        </a>
        <nav class="nav">
          {primaryNavItems.map((item) => (
            <a
              class:list={['nav-link', { active: localizedPath === (activeLocale ? toLocalePath(activeLocale, item.href) : item.href) }]}
              href={activeLocale ? toLocalePath(activeLocale, item.href) : item.href}
            >
              {
                activeLocale ? (
                  <span>{pickByLocale(activeLocale, item.zh, item.en)}</span>
                ) : (
                  <>
                    <span>{item.zh}</span>
                    <small>{item.en}</small>
                  </>
                )
              }
            </a>
          ))}
        </nav>
      </header>
      <slot />
      <footer class:list={['site-footer', { 'site-footer-landing': theme === 'landing-dark' }]}>
        <div class="footer-brand">
          <p>{siteMeta.zhName}</p>
          <p>{siteMeta.enName}</p>
          <p>{siteMeta.enSubtitle}</p>
          <p>© {new Date().getFullYear()} Entia Futura Institut</p>
        </div>
        <div class="footer-statement">
          <p>{siteMeta.coreQuestionZh}</p>
          <p>{siteMeta.coreQuestionEn}</p>
          <p>{siteMeta.oneLineZh}</p>
          <p>{siteMeta.oneLineEn}</p>
        </div>
        <nav class="footer-nav">
          {navItems.slice(1).map((item) => (
            <a href={activeLocale ? toLocalePath(activeLocale, item.href) : item.href}>
              {activeLocale ? pickByLocale(activeLocale, item.zh, item.en) : item.zh}
            </a>
          ))}
        </nav>
        <div class="footer-meta">
          <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
          <a href={activeLocale ? toLocalePath(activeLocale, '/contact') : '/contact'}>
            {pickByLocale(activeLocale ?? 'zh', '联系方式', 'Contact')}
          </a>
          <a href={activeLocale ? toLocalePath(activeLocale, '/privacy') : '/privacy'}>
            {pickByLocale(activeLocale ?? 'zh', '隐私政策', 'Privacy Policy')}
          </a>
          <a href={siteMeta.siteUrl} target="_blank" rel="noreferrer">entiafutura.com</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'EntiaTitleZh';
    src: url('/fonts/SmileySans-Oblique.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'EntiaTitleEn';
    src: url('/fonts/PoiretOne-Regular.ttf') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    /* Primitive tokens */
    --color-neutral-0: #ffffff;
    --color-neutral-25: #f8f8f4;
    --color-neutral-50: #f3f3f0;
    --color-neutral-100: #d9e3e7;
    --color-neutral-200: #b9cad0;
    --color-neutral-300: #8e96a6;
    --color-neutral-700: #4d4a60;
    --color-neutral-900: #090907;
    --color-neutral-950: #060605;
    --color-neutral-975: #040403;
    --color-brand-solar: #fefa71;
    --color-brand-violet: #4d4a60;
    --color-brand-mint: #b9cad0;
    --color-brand-ice: #d9e3e7;

    /* Semantic tokens */
    --color-bg-canvas: #090907;
    --color-bg-canvas-subtle: #111015;
    --color-bg-canvas-strong: #050504;
    --color-surface-base: transparent;
    --color-surface-raised: rgba(77, 74, 96, 0.34);
    --color-surface-subtle: rgba(77, 74, 96, 0.18);
    --color-surface-accent: rgba(254, 250, 113, 0.08);
    --color-surface-action-subtle: rgba(77, 74, 96, 0.56);
    --color-surface-action-strong: var(--color-brand-solar);
    --color-surface-overlay: rgba(77, 74, 96, 0.28);
    --color-surface-input: rgba(77, 74, 96, 0.3);
    --color-text-primary: #f3f3f0;
    --color-text-secondary: rgba(243, 243, 240, 0.88);
    --color-text-tertiary: rgba(243, 243, 240, 0.74);
    --color-text-body: rgba(243, 243, 240, 0.9);
    --color-text-footer: rgba(243, 243, 240, 0.64);
    --color-text-muted: rgba(243, 243, 240, 0.58);
    --color-text-inverse: #090907;
    --color-text-inverse-muted: rgba(243, 243, 240, 0.72);
    --color-text-on-accent: #090907;
    --color-border-subtle: rgba(185, 202, 208, 0.08);
    --color-border-soft: rgba(185, 202, 208, 0.14);
    --color-border-medium: rgba(185, 202, 208, 0.2);
    --color-border-default: rgba(185, 202, 208, 0.18);
    --color-border-strong: rgba(185, 202, 208, 0.28);
    --color-border-accent: rgba(254, 250, 113, 0.46);
    --color-border-accent-medium: rgba(254, 250, 113, 0.34);
    --color-border-accent-soft: rgba(254, 250, 113, 0.22);
    --color-border-signal: rgba(254, 250, 113, 0.56);
    --color-border-inverse: rgba(185, 202, 208, 0.18);
    --color-border-inverse-strong: rgba(185, 202, 208, 0.28);
    --color-border-inverse-accent: rgba(254, 250, 113, 0.46);
    --color-atmosphere-warm: rgba(254, 250, 113, 0.1);
    --color-atmosphere-cool: rgba(77, 74, 96, 0.24);
    --color-atmosphere-mint: rgba(185, 202, 208, 0.14);
    --color-atmosphere-violet: rgba(77, 74, 96, 0.3);
    --color-atmosphere-ice: rgba(185, 202, 208, 0.16);
    --color-shadow-soft: rgba(0, 0, 0, 0.24);
    --color-shadow-medium: rgba(0, 0, 0, 0.36);
    --color-action-primary-bg: #fefa71;
    --color-action-primary-fg: #090907;
    --color-action-secondary-bg: rgba(77, 74, 96, 0.52);
    --color-action-secondary-fg: #f3f3f0;
    --color-action-secondary-border: rgba(185, 202, 208, 0.24);

    /* Composed tokens */
    --gradient-page:
      radial-gradient(circle at 18% 12%, var(--color-atmosphere-warm), transparent 24rem),
      radial-gradient(circle at 82% 14%, rgba(185, 202, 208, 0.12), transparent 22rem),
      radial-gradient(circle at 62% 72%, var(--color-atmosphere-cool), transparent 26rem),
      linear-gradient(180deg, var(--color-bg-canvas) 0%, var(--color-bg-canvas-strong) 100%);
    --gradient-atmosphere-primary:
      radial-gradient(circle, rgba(254, 250, 113, 0.72) 0%, rgba(254, 250, 113, 0.16) 58%, rgba(254, 250, 113, 0) 78%);
    --gradient-atmosphere-secondary:
      radial-gradient(circle, rgba(185, 202, 208, 0.18) 0%, rgba(185, 202, 208, 0) 74%);
    --gradient-orb-primary:
      radial-gradient(circle, rgba(254, 250, 113, 0.78) 0%, rgba(254, 250, 113, 0.12) 64%, transparent 78%);
    --gradient-orb-secondary:
      radial-gradient(circle, rgba(77, 74, 96, 0.52) 0%, rgba(77, 74, 96, 0.06) 68%, transparent 80%);
    --gradient-orb-tertiary:
      radial-gradient(circle, rgba(185, 202, 208, 0.3) 0%, rgba(185, 202, 208, 0.03) 60%, transparent 76%);
    --pattern-hero-grid:
      linear-gradient(var(--color-border-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border-subtle) 1px, transparent 1px);
    --gradient-hero-stage:
      radial-gradient(circle at 50% 42%, rgba(185, 202, 208, 0.12), transparent 20rem),
      linear-gradient(180deg, #090907 0%, #111015 50%, #050504 100%);
    --gradient-hero-overlay:
      radial-gradient(circle at 50% 48%, var(--color-atmosphere-ice), transparent 14rem),
      linear-gradient(180deg, rgba(9, 9, 7, 0.08), rgba(9, 9, 7, 0.28) 68%, rgba(9, 9, 7, 0.72));
    --gradient-hero-vignette:
      radial-gradient(circle at 50% 56%, rgba(9, 9, 7, 0), rgba(9, 9, 7, 0.34) 58%, rgba(9, 9, 7, 0.9) 100%);
    --gradient-loading-screen: linear-gradient(180deg, rgba(9, 9, 7, 0.98), rgba(9, 9, 7, 0.82));
    --gradient-interactive-sheen: linear-gradient(120deg, transparent 20%, rgba(254, 250, 113, 0.16) 50%, transparent 80%);
    --filter-hero-scroll: saturate(0.92) contrast(1.02) brightness(0.94);
    --filter-hero-loop: saturate(0.94) contrast(1.02) brightness(0.92);
    --shadow-hero-figure: drop-shadow(0 26px 40px rgba(0, 0, 0, 0.28));
    --shadow-interactive-hover: 0 12px 24px rgba(0, 0, 0, 0.34);

    color-scheme: dark;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
    color: var(--color-text-primary);
    background: var(--color-bg-canvas);
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background: var(--gradient-page);
  }

  * {
    box-sizing: border-box;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    max-width: 1420px;
    margin: 0 auto;
    padding: 18px 24px 40px;
  }

  .site-header {
    position: relative;
    z-index: 20;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 18px;
    align-items: start;
    margin-bottom: 28px;
    padding: 10px 0 18px;
    border-bottom: 1px solid var(--color-border-default);
    border-radius: 0;
    backdrop-filter: none;
    background: transparent;
  }

  .brand {
    display: flex;
    align-items: center;
  }

  .brand-copy {
    display: grid;
    gap: 2px;
  }

  .brand-zh {
    font-size: 1rem;
    letter-spacing: 0.06em;
    font-family: 'EntiaTitleZh', "Hiragino Sans GB", "Noto Sans SC", sans-serif;
    font-weight: 400;
  }

  .brand-en {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-family: 'EntiaTitleEn', "Helvetica Neue", Arial, sans-serif;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .nav-link {
    display: grid;
    gap: 2px;
    min-width: 100px;
    padding: 8px 0;
    border: 1px solid transparent;
    color: var(--color-text-muted);
    transition: all 160ms ease;
  }

  .nav-link span {
    font-size: 0.95rem;
  }

  .nav-link small {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .locale-switcher {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: var(--color-surface-action-subtle);
  }

  .locale-link {
    padding: 6px 10px;
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 160ms ease, color 160ms ease;
  }

  .locale-link.active,
  .locale-link:hover {
    background: var(--color-action-primary-bg);
    color: var(--color-action-primary-fg);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text-primary);
    border-color: var(--color-border-accent);
    background: transparent;
  }

  main {
    display: grid;
    gap: 48px;
  }

  .hero-panel,
  .section-card,
  .content-card,
  .list-card,
  .contact-card {
    position: relative;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    backdrop-filter: none;
  }

  .hero-panel {
    padding: 18px 0 42px;
    border-bottom: 1px solid var(--color-border-default);
  }

  .landing-hero {
    position: relative;
    overflow: clip;
    isolation: isolate;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  .landing-hero::before,
  .landing-hero::after {
    content: '';
    position: absolute;
    inset: auto;
    pointer-events: none;
    z-index: -1;
    filter: blur(10px);
  }

  .landing-hero::before {
    top: -2rem;
    right: 10%;
    width: min(42vw, 28rem);
    height: min(42vw, 28rem);
    border-radius: 50%;
    background: var(--gradient-atmosphere-primary);
  }

  .landing-hero::after {
    bottom: 2rem;
    left: -2rem;
    width: min(38vw, 24rem);
    height: min(20vw, 10rem);
    border-radius: 999px;
    background: var(--gradient-atmosphere-secondary);
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(8px);
    opacity: 0.8;
    mix-blend-mode: multiply;
  }

  .hero-orb-a {
    top: 0;
    right: 2%;
    width: min(26vw, 16rem);
    height: min(26vw, 16rem);
    background: var(--gradient-orb-primary);
  }

  .hero-orb-b {
    bottom: 18%;
    right: 30%;
    width: min(16vw, 10rem);
    height: min(16vw, 10rem);
    background: var(--gradient-orb-secondary);
  }

  .hero-orb-c {
    bottom: 8%;
    left: 10%;
    width: min(30vw, 18rem);
    height: min(18vw, 10rem);
    border-radius: 999px;
    background: var(--gradient-orb-tertiary);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: var(--pattern-hero-grid);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black 20%, transparent 84%);
    opacity: 0.28;
  }

  .hero-stage {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 44rem) minmax(0, 1fr);
    grid-template-rows: minmax(24rem, 1fr) auto;
    grid-template-areas:
      ". visual ."
      ". bottom .";
    gap: 24px 28px;
    min-height: min(76vh, 52rem);
  }

  .hero-heading-shell {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--color-text-muted);
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-title-zh {
    margin: 0;
    font-size: clamp(3.4rem, 7.4vw, 7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 0.94;
    max-width: 9ch;
    font-family: 'EntiaTitleZh', "Hiragino Sans GB", "Noto Sans SC", sans-serif;
  }

  .hero-title-en {
    margin: 0 0 12px;
    font-size: clamp(0.98rem, 1.6vw, 1.2rem);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    font-family: 'EntiaTitleEn', "Helvetica Neue", Arial, sans-serif;
    text-align: center;
  }

  .hero-subtitle {
    margin: 0;
    max-width: 15ch;
    font-size: clamp(1.4rem, 2vw, 2rem);
    line-height: 1.25;
    color: var(--color-text-primary);
  }

  .hero-flash {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.84rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
  }

  .hero-visual {
    grid-area: visual;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100%;
  }

  .hero-core {
    position: relative;
    display: grid;
    place-items: center;
    width: min(100%, 38rem);
    aspect-ratio: 1 / 1;
  }

  .gravity-ring {
    position: absolute;
    inset: 50% auto auto 50%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .gravity-ring {
    border: 1px solid var(--color-border-soft);
    will-change: transform, opacity;
  }

  .gravity-ring-a {
    width: 74%;
    height: 74%;
    border-color: var(--color-border-medium);
  }

  .gravity-ring-b {
    width: 88%;
    height: 88%;
    border-style: dashed;
    border-color: var(--color-border-accent-medium);
  }

  .gravity-ring-c {
    width: 106%;
    height: 84%;
    border-color: var(--color-border-signal);
    transform: translate(-50%, -50%) rotate(-12deg);
  }

  .gravity-ring-d {
    width: 112%;
    height: 112%;
    border-color: var(--color-border-subtle);
  }

  .gravity-ring-e {
    width: 126%;
    height: 70%;
    border-color: var(--color-border-accent-soft);
    transform: translate(-50%, -50%) rotate(18deg);
  }

  .hero-side {
    display: flex;
    align-items: center;
  }

  .hero-side-left {
    grid-area: visual;
    align-self: end;
    justify-content: flex-start;
    text-align: left;
    z-index: 3;
    padding: 0 0 2rem 1rem;
  }

  .hero-bottom {
    grid-area: bottom;
    display: flex;
    justify-content: center;
  }

  .hero-logo-frame {
    position: relative;
    width: min(100%, 44rem);
    aspect-ratio: 1 / 1;
  }

  .hero-logo-art {
    position: relative;
    z-index: 2;
    width: min(100%, 36rem);
    height: auto;
    object-fit: contain;
    filter: var(--shadow-hero-figure);
  }

  .lede {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.95;
    color: var(--color-text-secondary);
  }

  .dual-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .lang-block h3 {
    margin: 0 0 12px;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
  }

  .lang-block p,
  .lang-block li,
  .content-card p,
  .list-card li,
  .contact-card p,
  .contact-card label {
    font-size: 1rem;
    line-height: 1.95;
    color: var(--color-text-body);
  }

  .section-card,
  .content-card,
  .list-card,
  .contact-card {
    padding: 0;
  }

  .section-heading {
    display: grid;
    gap: 8px;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border-default);
    will-change: transform, opacity;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.8rem);
    font-weight: 500;
  }

  html[lang^='zh'] .section-heading h2,
  html[lang^='zh'] .mini-card h3 {
    font-family: 'EntiaTitleZh', "Hiragino Sans GB", "Noto Sans SC", sans-serif;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  html[lang='en'] .section-heading h2,
  html[lang='en'] .mini-card h3 {
    font-family: 'EntiaTitleEn', "Helvetica Neue", Arial, sans-serif;
    letter-spacing: 0.04em;
  }

  .section-heading p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 30px 42px;
  }

  .mini-card {
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    will-change: transform, opacity;
  }

  .mini-card h3 {
    margin: 0 0 10px;
    font-size: clamp(1.5rem, 2vw, 2.1rem);
    font-weight: 500;
  }

  .mini-card .en {
    display: block;
    margin-bottom: 18px;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .mini-card p {
    margin: 0;
  }

  .mini-card + .mini-card {
    border-top: 1px solid var(--color-border-default);
    padding-top: 4px;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .button {
