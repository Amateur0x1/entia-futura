---
const pageTitle = 'Video Threshold Test | Entia Futura';
const pageDescription = 'Standalone scroll-controlled video threshold test for Entia Futura.';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>
  <body>
    <main class="threshold-test">
      <section class="threshold-stage" data-threshold-root>
        <div class="threshold-frame" data-threshold-frame>
          <div class="threshold-visual" data-threshold-visual>
            <div class="threshold-loading" data-threshold-loading>
              <span>Loading threshold</span>
            </div>
            <video
              class="threshold-video threshold-video-scroll"
              data-scroll-video
              src="/videos/portal-scroll.mp4"
              muted
              playsinline
              preload="auto"
            ></video>
            <video
              class="threshold-video threshold-video-loop"
              data-loop-video
              src="/videos/portal-loop.webm"
              autoplay
              loop
              muted
              playsinline
              preload="auto"
            ></video>
            <div class="threshold-overlay" aria-hidden="true"></div>
            <div class="threshold-vignette" aria-hidden="true"></div>
            <div class="threshold-label" aria-hidden="true">
              <span>video threshold test</span>
              <strong>ENTIA FUTURA / VIDEO-01</strong>
            </div>
          </div>

          <div class="threshold-copy">
            <p class="threshold-kicker">Entia Futura / Scroll Threshold</p>
            <h1>滚动推进门槛，抵达后让呼吸继续。</h1>
            <p class="threshold-lede">
              这一页只用于测试视频驱动效果。向下滚动时，前景视频会被滚动接管；接近终点时，循环视频会淡入接棒。
            </p>
            <div class="threshold-meta">
              <span>Scroll to begin</span>
              <span>/video-threshold-test</span>
            </div>
          </div>
        </div>
      </section>

      <section class="threshold-notes">
        <article>
          <p>01</p>
          <h2>滚动控制</h2>
          <p>桌面端使用 GSAP ScrollTrigger 把滚动进度映射到 `currentTime`。</p>
        </article>
        <article>
          <p>02</p>
          <h2>双视频切换</h2>
          <p>结尾阶段淡入 `WebM` 循环层，避免停在最后一帧显得僵硬。</p>
        </article>
        <article>
          <p>03</p>
          <h2>加载降级</h2>
          <p>移动端和减少动态偏好下，不强制滚动驱动，直接展示更轻的静态循环效果。</p>
        </article>
      </section>
    </main>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const root = document.querySelector('[data-threshold-root]');
      const frame = document.querySelector('[data-threshold-frame]');
      const visual = document.querySelector('[data-threshold-visual]');
      const copy = document.querySelector('.threshold-copy');
      const loading = document.querySelector('[data-threshold-loading]');
      const scrollVideo = document.querySelector('[data-scroll-video]');
      const loopVideo = document.querySelector('[data-loop-video]');

      const hideLoading = () => {
        if (loading instanceof HTMLElement) {
          loading.classList.add('is-hidden');
        }
      };

      const startLoopVideo = () => {
        if (!(loopVideo instanceof HTMLVideoElement)) {
          return;
        }

        const playAttempt = loopVideo.play();
        if (playAttempt && typeof playAttempt.catch === 'function') {
          playAttempt.catch(() => {});
        }
      };

      if (
        root instanceof HTMLElement &&
        frame instanceof HTMLElement &&
        visual instanceof HTMLElement &&
        copy instanceof HTMLElement &&
        scrollVideo instanceof HTMLVideoElement &&
        loopVideo instanceof HTMLVideoElement
      ) {
        startLoopVideo();

        if ('requestVideoFrameCallback' in scrollVideo) {
          const callback = () => {
            scrollVideo.requestVideoFrameCallback(callback);
          };

          scrollVideo.requestVideoFrameCallback(callback);
        }

        const initialize = () => {
          const targetDuration = Math.max(scrollVideo.duration - 0.04, 0);

          hideLoading();

          if (prefersReducedMotion || window.innerWidth <= 720 || targetDuration <= 0) {
            gsap.set(loopVideo, { autoAlpha: 1 });
            gsap.set(scrollVideo, {
              autoAlpha: 0.18,
              currentTime: targetDuration,
            });
            return;
          }

          gsap.set(loopVideo, { autoAlpha: 0 });

          const intro = gsap.timeline({
            defaults: { ease: 'power3.out' },
          });

          intro
            .fromTo(
              visual,
              {
                autoAlpha: 0,
                scale: 0.97,
                y: 32,
              },
              {
                autoAlpha: 1,
                scale: 1,
                y: 0,
                duration: 1,
              },
            )
            .fromTo(
              copy,
              {
                autoAlpha: 0,
                y: 24,
              },
              {
                autoAlpha: 1,
                y: 0,
                duration: 0.82,
              },
              '-=0.56',
            );

          const timeline = gsap.timeline({
            defaults: { ease: 'none' },
            scrollTrigger: {
              trigger: root,
              start: 'top top',
              end: '+=2400',
              scrub: 1,
              pin: frame,
              anticipatePin: 1,
            },
          });

          timeline
            .to(
              visual,
              {
                yPercent: -2,
                scale: 1.03,
                duration: 1,
              },
              0,
            )
            .to(
              copy,
              {
                yPercent: -7,
                autoAlpha: 0.42,
                duration: 0.72,
              },
              0,
            )
            .to(
              scrollVideo,
              {
                currentTime: targetDuration,
                duration: 1,
              },
              0,
            )
            .to(
              loopVideo,
              {
                autoAlpha: 1,
                duration: 0.22,
              },
              0.78,
            )
            .to(
              scrollVideo,
              {
                autoAlpha: 0.16,
                duration: 0.16,
              },
              0.84,
            );
        };

        if (scrollVideo.readyState >= 1) {
          initialize();
        } else {
          scrollVideo.addEventListener('loadedmetadata', initialize, { once: true });
        }

        if (scrollVideo.readyState >= 2) {
          hideLoading();
        } else {
          scrollVideo.addEventListener('loadeddata', hideLoading, { once: true });
          scrollVideo.addEventListener('canplaythrough', hideLoading, { once: true });
        }
      }

      window.addEventListener(
        'load',
        () => {
          ScrollTrigger.refresh();
        },
        { once: true },
      );
    </script>
  </body>
</html>

<style is:global>
  :root {
    color: #eef3ff;
    background: #02050c;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: #02050c;
  }

  body {
    overflow-x: hidden;
  }
 </style>

<style>
  .threshold-test {
    background:
      radial-gradient(circle at 50% 18%, rgba(235, 242, 255, 0.08), transparent 18rem),
      linear-gradient(180deg, #02050c 0%, #030813 48%, #050b16 100%);
  }

  .threshold-stage {
    position: relative;
    min-height: 100vh;
  }

  .threshold-frame {
    position: relative;
    min-height: 100vh;
    overflow: clip;
    isolation: isolate;
  }

  .threshold-visual {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.1), transparent 20rem),
      linear-gradient(180deg, #02060d 0%, #040813 50%, #02050c 100%);
  }

  .threshold-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .threshold-video-scroll {
    filter: saturate(0.92) contrast(1.06) brightness(0.88);
  }

  .threshold-video-loop {
    opacity: 0;
    filter: saturate(0.94) contrast(1.04) brightness(0.92);
  }

  .threshold-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 48%, rgba(240, 248, 255, 0.12), transparent 14rem),
      linear-gradient(180deg, rgba(2, 5, 12, 0.08), rgba(2, 5, 12, 0.36) 68%, rgba(1, 2, 6, 0.72));
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .threshold-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 56%, rgba(8, 12, 18, 0), rgba(3, 6, 12, 0.38) 58%, rgba(1, 2, 7, 0.88) 100%);
    pointer-events: none;
  }

  .threshold-loading {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, rgba(2, 4, 10, 0.98), rgba(2, 4, 10, 0.82));
    color: rgba(228, 238, 255, 0.82);
    font-size: 0.76rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-family: "Helvetica Neue", Arial, sans-serif;
    transition: opacity 320ms ease;
  }

  .threshold-loading.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .threshold-label {
    position: absolute;
    right: clamp(1rem, 2vw, 1.8rem);
    bottom: clamp(1rem, 2vw, 1.8rem);
    z-index: 2;
    display: grid;
    gap: 0.32rem;
    padding: 0.82rem 0.95rem;
    border: 1px solid rgba(202, 220, 255, 0.18);
    border-radius: 1rem;
    background: rgba(8, 13, 24, 0.42);
    color: rgba(228, 238, 255, 0.85);
    backdrop-filter: blur(12px);
  }

  .threshold-label span,
  .threshold-label strong {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 400;
  }

  .threshold-copy {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 1.2rem;
    align-content: end;
    min-height: 100vh;
    max-width: min(44rem, calc(100vw - 3rem));
    padding:
      clamp(5rem, 14vh, 10rem)
      clamp(1.25rem, 4vw, 4rem)
      clamp(2rem, 7vh, 4rem);
  }

  .threshold-kicker {
    margin: 0;
    color: rgba(213, 228, 255, 0.72);
    font-size: 0.76rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-family: "Helvetica Neue", Arial, sans-serif;
  }

  .threshold-copy h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(3rem, 7vw, 6.3rem);
    line-height: 0.94;
    font-weight: 400;
  }

  .threshold-lede {
    margin: 0;
    max-width: 34rem;
    color: rgba(228, 238, 255, 0.82);
    font-size: 1.02rem;
    line-height: 1.85;
  }

  .threshold-meta {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    color: rgba(192, 210, 240, 0.8);
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-family: "Helvetica Neue", Arial, sans-serif;
  }

  .threshold-notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    padding: 2rem clamp(1.25rem, 4vw, 4rem) 3rem;
  }

  .threshold-notes article {
    padding: 1.1rem 1.15rem 1.2rem;
    border: 1px solid rgba(202, 220, 255, 0.14);
    border-radius: 1.25rem;
    background: linear-gradient(180deg, rgba(10, 16, 28, 0.72), rgba(8, 13, 24, 0.46));
    box-shadow: 0 20px 42px rgba(2, 4, 11, 0.22);
  }

  .threshold-notes p:first-child {
    margin: 0 0 0.6rem;
    color: rgba(153, 207, 255, 0.88);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: "Helvetica Neue", Arial, sans-serif;
  }

  .threshold-notes h2 {
    margin: 0 0 0.65rem;
    font-size: 1.08rem;
    font-weight: 400;
  }

  .threshold-notes p:last-child {
    margin: 0;
    color: rgba(228, 238, 255, 0.78);
    line-height: 1.72;
  }

  @media (max-width: 900px) {
    .threshold-notes {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .threshold-copy {
      max-width: calc(100vw - 2rem);
      padding-inline: 1rem;
    }

    .threshold-label {
      right: 0.9rem;
      bottom: 0.9rem;
      padding: 0.72rem 0.78rem;
    }

    .threshold-copy h1 {
      max-width: 100%;
      font-size: clamp(2.5rem, 12vw, 4.2rem);
    }

    .threshold-notes {
      padding-inline: 1rem;
    }
  }
</style>
