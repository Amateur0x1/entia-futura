---
import BilingualIntro from '../components/BilingualIntro.astro';
import BilingualList from '../components/BilingualList.astro';
import Layout from '../layouts/Layout.astro';
import { publicationCategoriesEn, publicationCategoriesZh, siteMeta } from '../content/site';
---

<Layout title={`研究成果 | ${siteMeta.enName}`} description="Publications of Entia Futura Institut.">
  <main>
    <section class="hero-panel">
      <p class="eyebrow">Publications</p>
      <h1 class="hero-title-zh">研究成果</h1>
      <p class="hero-title-en">Publications</p>
    </section>
    <section class="section-card">
      <div class="section-heading">
        <h2>研究成果</h2>
        <p>Publications</p>
      </div>
      <BilingualIntro
        zh="未来人研究所的成果不只是一种形式。它可能表现为研究文章、案例档案、访谈、报告、圆桌记录、出版计划、公共讨论、空间项目、工具原型或未来项目。"
        en="The institute’s outputs do not take a single form. They may appear as essays, case archives, interviews, reports, roundtable records, publications, public conversations, spatial projects, tool prototypes, or future ventures."
      />
    </section>
    <BilingualList zhTitle="分类建议" enTitle="Suggested Categories" zhItems={publicationCategoriesZh} enItems={publicationCategoriesEn} />
  </main>
</Layout>
