---
import BilingualIntro from '../components/BilingualIntro.astro';
import Layout from '../layouts/Layout.astro';
import { siteMeta } from '../content/site';
---

<Layout title={`成员 | ${siteMeta.enName}`} description="People of Entia Futura Institut.">
  <main>
    <section class="hero-panel">
      <p class="eyebrow">People</p>
      <h1 class="hero-title-zh">成员</h1>
      <p class="hero-title-en">People</p>
    </section>
    <section class="section-card">
      <div class="section-heading">
        <h2>成员</h2>
        <p>People</p>
      </div>
      <BilingualIntro
        zh="未来人研究所由研究者、写作者、工程师、创业者、策展人、空间主理人、品牌建设者与青年行动者共同构成。我们不把成员理解为单一职业标签，而把它理解为一种围绕问题形成的工作关系。"
        en="Entia Futura Institut is composed of researchers, writers, engineers, entrepreneurs, curators, space-makers, brand builders, and young organizers. We do not understand people through a single professional label, but through forms of working relation organized around questions."
      />
    </section>
    <section class="section-card">
      <div class="section-heading">
        <h2>成员模板</h2>
        <p>People Template</p>
      </div>
      <div class="cards-grid">
        <article class="mini-card">
          <h3>姓名</h3>
          <span class="en">Name</span>
          <p>角色 / 职务</p>
          <p>一句简介</p>
          <p>关键词</p>
        </article>
        <article class="mini-card">
          <h3>Name</h3>
          <span class="en">Template</span>
          <p>Role / Position</p>
          <p>Short Bio</p>
          <p>Keywords</p>
        </article>
      </div>
    </section>
  </main>
</Layout>
