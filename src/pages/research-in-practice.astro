---
import BilingualCards from '../components/BilingualCards.astro';
import BilingualIntro from '../components/BilingualIntro.astro';
import Layout from '../layouts/Layout.astro';
import { practiceItems, siteMeta } from '../content/site';
---

<Layout title={`研究转化 | ${siteMeta.enName}`} description="Research in Practice at Entia Futura Institut.">
  <main>
    <section class="hero-panel">
      <p class="eyebrow">Research in Practice</p>
      <h1 class="hero-title-zh">研究转化</h1>
      <p class="hero-title-en">Research in Practice</p>
    </section>
    <section class="section-card">
      <div class="section-heading">
        <h2>研究转化</h2>
        <p>Research in Practice</p>
      </div>
      <BilingualIntro
        zh="未来人研究所相信，研究不应停留在理论层面，也不应被压缩成单纯的策略包装。我们强调研究转化：让高等研究进入现实问题、组织实践、品牌叙事、空间场景与协作机制之中。"
        en="Entia Futura Institut believes that research should not remain at the level of theory alone, nor be reduced to strategic packaging. We emphasize research in practice: bringing advanced inquiry into real-world problems, organizational practice, narrative work, spatial settings, and collaborative mechanisms."
      />
    </section>
    <section class="section-card">
      <div class="section-heading">
        <h2>工作维度</h2>
        <p>Practice Areas</p>
      </div>
      <BilingualCards items={practiceItems} />
    </section>
  </main>
</Layout>
