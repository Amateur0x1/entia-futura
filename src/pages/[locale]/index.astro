---
import HomeEffects from '../../components/home/HomeEffects.astro';
import HomeHeroScreen from '../../components/home/HomeHeroScreen.astro';
import HomeSecondPanel from '../../components/home/HomeSecondPanel.astro';
import HomeThirdPanel from '../../components/home/HomeThirdPanel.astro';
import PageLoader from '../../components/home/PageLoader.astro';
import Layout from '../../layouts/Layout.astro';
import { siteMeta } from '../../content/site';
import { isLocale, pickByLocale, toLocalePath } from '../../i18n/config';

const { locale } = Astro.params;

if (!isLocale(locale)) {
  throw new Error(`Unsupported locale: ${locale}`);
}

const pageTitle = pickByLocale(locale, siteMeta.zhName, siteMeta.enName);
const pageDescription = pickByLocale(
  locale,
  '一个以轨道档案为视觉母题的研究所首页：问题被重新编目，研究通过横向转译链进入现实。',
  'An institute homepage built around an orbital archive: questions are re-indexed and research enters reality through a horizontal chain of translation.',
);
const coreQuestionLabel = pickByLocale(locale, '核心问题：', 'Core Question:');
const coreQuestion = pickByLocale(locale, '未来我们将如何存在？', 'How shall we exist in the future?');
const instituteIntro = pickByLocale(
  locale,
  '未来人研究所是一个围绕"未来我们将如何存在？"这一核心问题展开工作的独立研究机构。我们以高等研究为基础，同时强调研究向现实问题、合作机制、未来项目与社会实验的持续转化。',
  'Entia Futura Institut is an independent institute organized around the question: "How shall we exist in the future?" Grounded in advanced research, we are equally committed to the translation of inquiry into real-world problems, collaborative forms, future ventures, and social experimentation.',
);
const whatWeDoTitle = pickByLocale(locale, '我们做什么？', 'What We Do?');
const whatWeDoIntro = pickByLocale(
  locale,
  '我们关心的不只是技术将如何改变世界，更关心在技术剧变与社会重组的时代，我们将如何学习、工作、居住、连接、创造，并重新组织知识、空间与共同体。',
  'We are concerned not only with how technology is changing the world, but with how, in a time of technological transformation and social reconfiguration, we shall learn, work, dwell, connect, create, and reorganize knowledge, space, and collective life.',
);
const whatWeDoModules = [
  {
    zhTitle: '研究',
    enTitle: 'Research',
    zhBody: '围绕未来社会的重要议题展开长期研究、写作、访谈、观察、案例档案与公共讨论。',
    enBody:
      'Long-term inquiry, writing, interviews, observation, case archives, and public discussion around critical questions of future society.',
  },
  {
    zhTitle: '项目机制',
    enTitle: 'Programs',
    zhBody: '通过研究项目、公共活动、协作项目、驻留机制、社群结构与实验项目组织工作。',
    enBody:
      'Work organized through research programs, public programs, collaborative projects, residencies, community structures, and experimental initiatives.',
  },
  {
    zhTitle: '研究转化',
    enTitle: 'Research in Practice',
    zhBody: '让高等研究进入现实问题、组织实践、品牌叙事、空间场景与协作机制之中。',
    enBody:
      'Bringing advanced inquiry into real-world questions, organizational practice, narrative work, spaces, and collaborative structures.',
  },
  {
    zhTitle: '未来项目',
    enTitle: 'Future Ventures',
    zhBody: '从研究中发展项目、机制、原型与新的组织形式，测试未来社会的可能结构。',
    enBody:
      'Developing projects, mechanisms, prototypes, and new institutional forms out of inquiry to test possible futures.',
  },
] as const;
---

<Layout title={`${pageTitle} | ${siteMeta.enName}`} description={pageDescription} locale={locale} theme="landing-dark">
  <PageLoader />
  <main class="landing-main" data-hero-stage>
    <HomeHeroScreen />
    <HomeSecondPanel
      locale={locale}
      coreQuestionLabel={coreQuestionLabel}
      coreQuestion={coreQuestion}
      instituteIntro={instituteIntro}
    />
    <div class="landing-scroll-spacer" data-landing-scroll-spacer aria-hidden="true"></div>
    <HomeThirdPanel
      locale={locale}
      title={whatWeDoTitle}
      intro={whatWeDoIntro}
      modules={whatWeDoModules}
    />
  </main>
  <section class="landing-system" data-hero-stage>
    <div class="floating-brand-cluster" data-brand-cluster>
      <!-- Logo buttons intentionally avoid sheen classes; motion is GSAP-only for now. -->
      <a
        class="floating-base-button floating-nameplate-button"
        data-brand-logo-button
        data-brand-cluster-button
        href={toLocalePath(locale, '/')}
      >
        <span data-brand-animated-text>Entia Futura</span>
        <small data-brand-animated-text>未来人研究所</small>
      </a>
    </div>
    <a class="floating-base-button floating-button floating-contact-button" data-brand-contact-button href={toLocalePath(locale, '/contact')}>
      <i class="floating-more-fill" data-contact-fill aria-hidden="true"></i>
      <span style="transform: translateY(-0.5px)">Contact</span>
    </a>
    <button class="floating-know-more-button" data-know-more-button type="button" aria-label="Know more">
      <span>KNOW MORE</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M12 16.2 5.8 10l1.4-1.4L12 13.4l4.8-4.8 1.4 1.4z"></path>
      </svg>
    </button>
    <!-- Second panel Know More — same pill style, shown after second panel text reveal -->
    <button
      class="floating-know-more-button second-panel-know-more"
      data-second-panel-know-more
      type="button"
      aria-label={locale === 'en' ? 'Know more' : '了解更多'}
    >
      <span>{locale === 'en' ? 'KNOW MORE' : '了解更多'}</span>
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M12 16.2 5.8 10l1.4-1.4L12 13.4l4.8-4.8 1.4 1.4z"></path>
      </svg>
    </button>
  </section>
  <HomeEffects />
</Layout>

<style>
  :global(body.theme-landing-dark .page-shell-landing) {
    padding: 0;
  }

  [data-hero-stage] {
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  [data-hero-stage].is-revealed {
    opacity: 1;
  }

  .landing-scroll-spacer {
    height: 380svh;
    width: 100%;
    pointer-events: none;
  }

  /* Second-panel Know More button: same pill as screen 1 but sits above
     second panel (z-index 31), hidden until JS adds .is-visible */
  :global(.second-panel-know-more) {
    z-index: 31;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  :global(.second-panel-know-more.is-visible) {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 720px) {
    .landing-scroll-spacer {
      height: 320svh;
    }
  }
</style>
