---
import LandingEffects from '../../components/LandingEffects.astro';
import OrbitLanding from '../../components/OrbitLanding.astro';
import Layout from '../../layouts/Layout.astro';
import { siteMeta } from '../../content/site';
import { isLocale, pickByLocale } from '../../i18n/config';

const { locale } = Astro.params;

if (!isLocale(locale)) {
  throw new Error(`Unsupported locale: ${locale}`);
}

const pageTitle = pickByLocale(locale, siteMeta.zhName, siteMeta.enName);
const pageDescription = pickByLocale(
  locale,
  '一个滚动驱动的单页落地页：人形标记沿轨道前进，问题随滚动逐一浮现。',
  'A scroll-driven landing page where a humanoid mark moves around an orbital ring and questions appear node by node.',
);
---

<Layout title={`${pageTitle} | ${siteMeta.enName}`} description={pageDescription} locale={locale}>
  <main class="landing-main">
    <OrbitLanding locale={locale} />
  </main>
  <LandingEffects />
</Layout>

<style>
  .landing-main {
    gap: 0;
  }

  :global(.site-header) {
    border-bottom-color: transparent;
  }

  :global(.site-footer) {
    margin-top: 0;
    border-top-color: transparent;
    background: transparent;
  }
</style>
