---
import BilingualCards from '../../components/BilingualCards.astro';
import CollaborationExperience from '../../components/CollaborationExperience.astro';
import BilingualIntro from '../../components/BilingualIntro.astro';
import BilingualList from '../../components/BilingualList.astro';
import BilingualSection from '../../components/BilingualSection.astro';
import Layout from '../../layouts/Layout.astro';
import {
  collaborationFormsEn,
  collaborationFormsZh,
  collaborationMethodEn,
  collaborationMethodZh,
  collaborationPartnersEn,
  collaborationPartnersZh,
  joinValuesEn,
  joinValuesZh,
  joinWaysEn,
  joinWaysZh,
  joinWhoEn,
  joinWhoZh,
  publicationCategoriesEn,
  publicationCategoriesZh,
  researchAreas,
  siteMeta,
  ventureItems,
} from '../../content/site';
import { isLocale, pickByLocale } from '../../i18n/config';

const pageSlugs = [
  'about',
  'research',
  'future-ventures',
  'collaboration',
  'people',
  'publications',
  'join-us',
  'contact',
] as const;

type PageSlug = (typeof pageSlugs)[number];

const { locale, slug } = Astro.params;

if (!isLocale(locale) || !slug || !pageSlugs.includes(slug as PageSlug)) {
  throw new Error(`Unsupported localized route: ${locale}/${slug}`);
}

const pageSlug = slug as PageSlug;

const pageMeta: Record<PageSlug, { titleZh: string; titleEn: string; eyebrowZh: string; eyebrowEn: string; descriptionZh: string; descriptionEn: string }> = {
  about: {
    titleZh: '关于我们',
    titleEn: 'About',
    eyebrowZh: '关于',
    eyebrowEn: 'About',
    descriptionZh: '关于未来人研究所。',
    descriptionEn: 'About Entia Futura Institut.',
  },
  research: {
    titleZh: '研究方向',
    titleEn: 'Research',
    eyebrowZh: '研究',
    eyebrowEn: 'Research',
    descriptionZh: '未来人研究所的研究方向。',
    descriptionEn: 'Research areas of Entia Futura Institut.',
  },
  'future-ventures': {
    titleZh: '未来项目',
    titleEn: 'Future Ventures',
    eyebrowZh: '未来项目',
    eyebrowEn: 'Future Ventures',
    descriptionZh: '未来人研究所的未来项目。',
    descriptionEn: 'Future Ventures of Entia Futura Institut.',
  },
  collaboration: {
    titleZh: '合作方式',
    titleEn: 'Collaboration',
    eyebrowZh: '合作',
    eyebrowEn: 'Collaboration',
    descriptionZh: '与未来人研究所合作。',
    descriptionEn: 'Collaboration with Entia Futura Institut.',
  },
  people: {
    titleZh: '成员',
    titleEn: 'People',
    eyebrowZh: '成员',
    eyebrowEn: 'People',
    descriptionZh: '未来人研究所的成员。',
    descriptionEn: 'People of Entia Futura Institut.',
  },
  publications: {
    titleZh: '研究成果',
    titleEn: 'Publications',
    eyebrowZh: '研究成果',
    eyebrowEn: 'Publications',
    descriptionZh: '未来人研究所的研究成果。',
    descriptionEn: 'Publications of Entia Futura Institut.',
  },
  'join-us': {
    titleZh: '加入我们',
    titleEn: 'Join Us',
    eyebrowZh: '加入我们',
    eyebrowEn: 'Join Us',
    descriptionZh: '加入未来人研究所。',
    descriptionEn: 'Join Entia Futura Institut.',
  },
  contact: {
    titleZh: '联系我们',
    titleEn: 'Contact',
    eyebrowZh: '联系',
    eyebrowEn: 'Contact',
    descriptionZh: '联系未来人研究所。',
    descriptionEn: 'Contact Entia Futura Institut.',
  },
};

const meta = pageMeta[pageSlug];
const pageTitle = pickByLocale(locale, meta.titleZh, meta.titleEn);
const pageDescription = pickByLocale(locale, meta.descriptionZh, meta.descriptionEn);
const contactFocusAreas = [
  {
    zhTitle: '我们是谁',
    enTitle: 'Who We Are',
    zhBody: '一个围绕“未来我们将如何存在？”展开工作的独立研究机构，把高等研究与现实问题、合作机制和未来项目连接起来。',
    enBody:
      'An independent institute organized around the question “How shall we exist in the future?”, connecting advanced research with real-world problems, collaborative forms, and future-oriented projects.',
  },
  {
    zhTitle: '我们做什么',
    enTitle: 'What We Do',
    zhBody: '我们通过研究、研究转化、未来项目与公共讨论，把关于技术、社会、空间、组织与生活形式的问题持续带入现实。',
    enBody:
      'Through research, research in practice, future ventures, and public inquiry, we bring questions about technology, society, space, organization, and forms of life into reality.',
  },
  {
    zhTitle: '我们如何看待合作',
    enTitle: 'How We See Collaboration',
    zhBody: '对我们来说，合作不是研究的附属执行，而是让研究进入真实场景、真实组织与真实问题的一种方式。',
    enBody:
      'For us, collaboration is not secondary execution attached to research, but one of the ways research enters real settings, real organizations, and real questions.',
  },
];
---

<Layout title={`${pageTitle} | ${siteMeta.enName}`} description={pageDescription} locale={locale}>
  <main>
    <section class="hero-panel">
      <p class="eyebrow">{pickByLocale(locale, meta.eyebrowZh, meta.eyebrowEn)}</p>
      <h1 class="hero-title-zh">{pageTitle}</h1>
      <p class="hero-title-en">{pickByLocale(locale, siteMeta.zhName, siteMeta.enName)}</p>
      {pageSlug === 'research' && <p class="hero-subtitle">{pickByLocale(locale, siteMeta.coreQuestionZh, siteMeta.coreQuestionEn)}</p>}
      {pageSlug === 'about' && <p class="hero-subtitle">{pickByLocale(locale, siteMeta.enSubtitle, siteMeta.enSubtitle)}</p>}
    </section>

    {pageSlug === 'about' && (
      <>
        <BilingualSection
          locale={locale}
          eyebrow={pickByLocale(locale, '我们是谁', 'Who We Are')}
          zhTitle="我们是谁"
          enTitle="Who We Are"
          zhBody="未来人研究所是一个独立研究机构，围绕“未来我们将如何存在？”这一核心问题展开工作。我们以高等研究为基础，同时强调研究向现实问题、合作机制与未来项目的持续转化。这意味着，我们不仅重视思想、方法与长期观察，也重视研究如何进入现实，如何与企业、地方、空间、社群及各类实践者形成真实合作，如何在现实中测试新的组织形式、学习机制、空间原型与未来生活方式。"
          enBody="Entia Futura Institut is an independent institute organized around one core question: “How shall we exist in the future?” Grounded in advanced research, we are equally committed to the translation of inquiry into real-world problems, collaborative forms, and future-oriented projects. We value thought, method, and long-term observation, while also asking how research can enter reality, form real collaborations with enterprises, local initiatives, spaces, communities, and practitioners, and test new forms of organization, learning, spatial prototypes, and future ways of living."
        />
        <BilingualSection
          locale={locale}
          eyebrow={pickByLocale(locale, '我们不是什么', 'What We Are Not')}
          zhTitle="我们不是什么"
          enTitle="What We Are Not"
          zhBody="我们不是传统学院，不是普通咨询公司，不是内容平台，也不是松散社群。我们希望成为一种新的机构形态：以研究为骨架，以社群为生命，以协作为接口，以实验和项目为现实转化路径。"
          enBody="We are not a traditional academic institution, nor a conventional consulting firm, nor a content platform, nor a loose social community. We seek to become a new institutional form: research as structure, community as vitality, collaboration as interface, and experimentation and projects as pathways of translation into reality."
        />
        <BilingualSection
          locale={locale}
          eyebrow={pickByLocale(locale, '我们的信念', 'What We Believe')}
          zhTitle="我们的信念"
          enTitle="What We Believe"
          zhBody="我们相信，未来的问题不能只在学院中被讨论，也不能只在商业世界中被消费。它们需要一种新的研究机构来承接：既有方法和判断力，也有现实进入能力；既能形成知识成果，也能发起合作、孵化项目并培育共同体。"
          enBody="We believe that the questions of the future cannot remain confined to academic discourse, nor be reduced to trends in the commercial world. They require a new kind of institute: one with method and judgment, but also with the capacity to enter reality; one that produces knowledge, while also initiating collaborations, incubating projects, and cultivating forms of collective life."
        />
      </>
    )}

    {pageSlug === 'research' && (
      <section class="section-card">
        <div class="section-heading">
          <h2>{pickByLocale(locale, '研究方向', 'Research Areas')}</h2>
        </div>
        <BilingualCards items={researchAreas} locale={locale} />
      </section>
    )}

    {pageSlug === 'future-ventures' && (
      <>
        <section class="section-card">
          <div class="section-heading">
            <h2>{pickByLocale(locale, '未来项目', 'Future Ventures')}</h2>
          </div>
          <BilingualIntro
            locale={locale}
            zh="未来人研究所不仅关注研究，也关注研究如何进一步长成项目、机制、原型与新的组织形式。“未来项目”不是传统意义上的创业孵化器，也不是单纯的商业板块，而是研究所内部的一层现实生成机制。"
            en="Entia Futura Institut is concerned not only with research, but with how research may grow into projects, mechanisms, prototypes, and new organizational forms. Future Ventures is not a conventional startup incubator, nor simply a commercial division, but a generative layer within the institute."
          />
        </section>
        <section class="section-card">
          <div class="section-heading">
            <h2>{pickByLocale(locale, '生成方向', 'Venture Directions')}</h2>
          </div>
          <BilingualCards items={ventureItems} locale={locale} />
        </section>
      </>
    )}

    {pageSlug === 'collaboration' && (
      <>
        <CollaborationExperience locale={locale} ctaHref={`/${locale}/contact`} />
      </>
    )}

    {pageSlug === 'people' && (
      <>
        <section class="section-card">
          <div class="section-heading">
            <h2>{pickByLocale(locale, '成员', 'People')}</h2>
          </div>
          <BilingualIntro
            locale={locale}
            zh="未来人研究所由研究者、写作者、工程师、创业者、策展人、空间主理人、品牌建设者与青年行动者共同构成。我们不把成员理解为单一职业标签，而把它理解为一种围绕问题形成的工作关系。"
            en="Entia Futura Institut is composed of researchers, writers, engineers, entrepreneurs, curators, space-makers, brand builders, and young organizers. We do not understand people through a single professional label, but through forms of working relation organized around questions."
          />
        </section>
        <section class="section-card">
          <div class="section-heading">
            <h2>{pickByLocale(locale, '成员模板', 'People Template')}</h2>
          </div>
          <div class="cards-grid">
            <article class="mini-card">
              <h3>{pickByLocale(locale, '姓名', 'Name')}</h3>
              <p>{pickByLocale(locale, '角色 / 职务', 'Role / Position')}</p>
              <p>{pickByLocale(locale, '一句简介', 'Short Bio')}</p>
              <p>{pickByLocale(locale, '关键词', 'Keywords')}</p>
            </article>
          </div>
        </section>
      </>
    )}

    {pageSlug === 'publications' && (
      <>
        <section class="section-card">
          <div class="section-heading">
            <h2>{pickByLocale(locale, '研究成果', 'Publications')}</h2>
          </div>
          <BilingualIntro
            locale={locale}
            zh="未来人研究所的成果不只是一种形式。它可能表现为研究文章、案例档案、访谈、报告、圆桌记录、出版计划、公共讨论、空间项目、工具原型或未来项目。"
            en="The institute’s outputs do not take a single form. They may appear as essays, case archives, interviews, reports, roundtable records, publications, public conversations, spatial projects, tool prototypes, or future ventures."
          />
        </section>
        <BilingualList
          locale={locale}
          zhTitle="分类建议"
          enTitle="Suggested Categories"
          zhItems={publicationCategoriesZh}
          enItems={publicationCategoriesEn}
        />
      </>
    )}

    {pageSlug === 'join-us' && (
      <>
        <BilingualList
          locale={locale}
          zhTitle="我们想连接的人"
          enTitle="Who We Hope to Connect With"
          zhItems={joinWhoZh}
          enItems={joinWhoEn}
        />
        <BilingualList
          locale={locale}
          zhTitle="参与方式"
          enTitle="Ways to Participate"
          zhItems={joinWaysZh}
          enItems={joinWaysEn}
        />
        <BilingualList
          locale={locale}
          zhTitle="我们重视什么"
          enTitle="What We Value"
          zhItems={joinValuesZh}
          enItems={joinValuesEn}
        />
      </>
    )}

    {pageSlug === 'contact' && (
      <>
        <section class="section-card contact-positioning-card">
          <div class="section-heading">
            <p class="eyebrow">{pickByLocale(locale, '定位', 'Positioning')}</p>
            <h2>{pickByLocale(locale, '研究方向与机构定位', 'Research Directions and Positioning')}</h2>
          </div>
          <p class="contact-positioning-lead">
            {pickByLocale(
              locale,
              '未来人研究所是一个围绕“未来我们将如何存在？”展开工作的独立研究机构。我们以高等研究为基础，同时强调研究向现实问题、合作机制、未来项目与社会实验的持续转化。',
              'Entia Futura Institut is an independent institute organized around the question “How shall we exist in the future?” Grounded in advanced research, we are equally committed to the translation of inquiry into real-world problems, collaborative forms, future ventures, and social experimentation.',
            )}
          </p>
          <p class="contact-positioning-note">
            {pickByLocale(
              locale,
              '我们关心的不只是技术将如何改变世界，更关心在技术剧变与社会重组的时代，我们将如何学习、工作、居住、连接、创造，并重新组织知识、空间与共同体。',
              'We are concerned not only with how technology is changing the world, but with how, in a time of technological transformation and social reconfiguration, we shall learn, work, dwell, connect, create, and reorganize knowledge, space, and collective life.',
            )}
          </p>
        </section>

        <section class="section-card contact-research-card">
          <div class="section-heading">
            <p class="eyebrow">{pickByLocale(locale, '研究方向', 'Research Directions')}</p>
            <h2>{pickByLocale(locale, '我们正在持续追问的方向', 'Questions We Continue to Pursue')}</h2>
          </div>
          <BilingualCards items={researchAreas} locale={locale} />
        </section>

        <section class="section-card contact-collaboration-card">
          <div class="section-heading">
            <p class="eyebrow">{pickByLocale(locale, '合作', 'Collaboration')}</p>
            <h2>{pickByLocale(locale, '我们如何看待商业合作', 'How We See Commercial Collaboration')}</h2>
          </div>
          <p class="contact-collaboration-lead">
            {pickByLocale(
              locale,
              '我们会先确认问题，再讨论适合的合作方式、工作节奏与现实场景，而不是直接把问题压缩成一个待执行任务。',
              'We begin by clarifying the question, then discuss the form, rhythm, and real-world setting of collaboration, rather than compressing everything into a task list to execute.',
            )}
          </p>
          <div class="contact-collaboration-grid">
            <article class="contact-collaboration-block">
              <h3>{pickByLocale(locale, '我们合作的对象', 'Who We Work With')}</h3>
              <ul class="clean">
                {pickByLocale(locale, collaborationPartnersZh, collaborationPartnersEn).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
            <article class="contact-collaboration-block">
              <h3>{pickByLocale(locale, '合作形式', 'Forms of Collaboration')}</h3>
              <ul class="clean">
                {pickByLocale(locale, collaborationFormsZh, collaborationFormsEn).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
            <article class="contact-collaboration-block">
              <h3>{pickByLocale(locale, '我们的合作方法', 'How We Work')}</h3>
              <ul class="clean">
                {pickByLocale(locale, collaborationMethodZh, collaborationMethodEn).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          </div>
        </section>

        <section class="section-card contact-join-card">
          <div class="section-heading">
            <p class="eyebrow">{pickByLocale(locale, '加入我们', 'Join Us')}</p>
            <h2>{pickByLocale(locale, '我们希望连接怎样的人', 'Who We Hope to Connect With')}</h2>
          </div>
          <div class="contact-join-grid">
            <article class="contact-collaboration-block">
              <h3>{pickByLocale(locale, '我们想连接的人', 'Who We Hope to Connect With')}</h3>
              <ul class="clean">
                {pickByLocale(locale, joinWhoZh, joinWhoEn).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
            <article class="contact-collaboration-block">
              <h3>{pickByLocale(locale, '参与方式', 'Ways to Participate')}</h3>
              <ul class="clean">
                {pickByLocale(locale, joinWaysZh, joinWaysEn).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
            <article class="contact-collaboration-block">
              <h3>{pickByLocale(locale, '我们重视什么', 'What We Value')}</h3>
              <ul class="clean">
                {pickByLocale(locale, joinValuesZh, joinValuesEn).map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          </div>
        </section>

        <section class="contact-card contact-route-card">
          <div class="section-heading">
            <p class="eyebrow">{pickByLocale(locale, '联系我们', 'Contact')}</p>
            <h2>{pickByLocale(locale, '带着问题写信给我们。', 'Write to Us with the Question.')}</h2>
          </div>
          <p class="contact-route-compact">
            {pickByLocale(
              locale,
              '告诉我们你是谁、你正在面对什么问题，以及你希望如何展开合作。',
              'The best way to begin is not a form, but a direct email. Tell us who you are, what question you are facing, and how you imagine the collaboration might begin.',
            )}
          </p>
          <p class="contact-route-email">
            Email:
            <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
          </p>
          <div class="cta-row">
            <a class="button primary" href={`mailto:${siteMeta.email}`}>
              {pickByLocale(locale, '发送邮件', 'Write to Us')}
            </a>
          </div>
        </section>
      </>
    )}
  </main>
</Layout>

<style>
  .contact-positioning-card,
  .contact-research-card,
  .contact-collaboration-card,
  .contact-join-card,
  .contact-route-card {
    position: relative;
  }

  .contact-positioning-lead {
    margin: 0;
    max-width: 58rem;
    font-size: clamp(1.08rem, 1.7vw, 1.3rem);
    line-height: 1.85;
    color: var(--color-text-body);
  }

  .contact-route-email {
    margin: 18px 0 0;
    color: var(--color-text-body);
  }

  .contact-route-email a {
    color: var(--color-primary);
  }

  .contact-positioning-note {
    margin: 14px 0 0;
    max-width: 58rem;
    color: var(--color-text-body);
    line-height: 1.85;
  }

  .contact-collaboration-lead,
  .contact-route-compact {
    margin: 0;
    max-width: 54rem;
    color: var(--color-text-body);
    line-height: 1.9;
  }

  .contact-collaboration-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-top: 22px;
  }

  .contact-join-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .contact-collaboration-block {
    padding: 18px;
    border: 1px solid var(--color-border);
    border-radius: 18px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 86%, transparent), color-mix(in srgb, var(--color-surface-variant) 80%, transparent)),
      radial-gradient(circle at top right, var(--effect-glow-secondary), transparent 58%);
  }

  .contact-collaboration-block h3 {
    margin: 0 0 12px;
    font-size: clamp(1.08rem, 1.8vw, 1.36rem);
    color: var(--color-text-primary);
  }

  .contact-collaboration-block ul {
    display: grid;
    gap: 10px;
  }

  .contact-collaboration-block li {
    color: var(--color-text-body);
    line-height: 1.78;
  }

  @media (max-width: 980px) {
    .contact-collaboration-grid,
    .contact-join-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    .contact-collaboration-grid,
    .contact-join-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
