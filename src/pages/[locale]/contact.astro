---
import Layout from '../../layouts/Layout.astro';
import { siteMeta } from '../../content/site';
import { isLocale, pickByLocale } from '../../i18n/config';

const { locale } = Astro.params;

if (!isLocale(locale)) {
  throw new Error(`Unsupported locale: ${locale}`);
}

const pageTitle = pickByLocale(locale, '联系我们', 'Contact');
const pageDescription = pickByLocale(
  locale,
  '联系未来人研究所。',
  'Contact Entia Futura Institut.',
);
---

<Layout title={`${pageTitle} | ${siteMeta.enName}`} description={pageDescription} locale={locale}>
  <main>
    <section class="section-card contact-card">
      <div class="section-heading">
        <p class="eyebrow">{pickByLocale(locale, '联系', 'Contact')}</p>
        <h1>{pickByLocale(locale, '联系我们', 'Contact')}</h1>
      </div>
      <p>
        {pickByLocale(
          locale,
          '如果你希望围绕某个问题、合作、项目、提案或计划与未来人研究所建立联系，欢迎向我们写信。',
          'If you would like to connect with Entia Futura Institut around a question, collaboration, project, proposal, or program, we welcome you to write to us.',
        )}
      </p>
      <p class="email-row">
        <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
      </p>
      <div class="cta-row">
        <a class="button primary" href={`mailto:${siteMeta.email}`}>
          {pickByLocale(locale, '发送邮件', 'Write to Us')}
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .contact-card p {
    margin: 0;
    max-width: 52rem;
    line-height: 1.9;
    color: var(--color-text-body);
  }

  .email-row {
    margin-top: 14px;
  }

  .email-row a {
    margin-left: 0.4rem;
    color: var(--color-primary);
  }
</style>
