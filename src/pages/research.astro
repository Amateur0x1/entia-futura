---
import BilingualCards from '../components/BilingualCards.astro';
import Layout from '../layouts/Layout.astro';
import { researchAreas, siteMeta } from '../content/site';
---

<Layout title={`研究方向 | ${siteMeta.enName}`} description="Research areas of Entia Futura Institut.">
  <main>
    <section class="hero-panel">
      <p class="eyebrow">Research</p>
      <h1 class="hero-title-zh">研究方向</h1>
      <p class="hero-title-en">Research</p>
      <p class="hero-subtitle">{siteMeta.coreQuestionZh}</p>
    </section>
    <section class="section-card">
      <div class="section-heading">
        <h2>研究方向</h2>
        <p>Research</p>
      </div>
      <BilingualCards items={researchAreas} />
    </section>
  </main>
</Layout>
