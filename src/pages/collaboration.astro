---
import BilingualIntro from '../components/BilingualIntro.astro';
import BilingualList from '../components/BilingualList.astro';
import Layout from '../layouts/Layout.astro';
import {
  collaborationFormsEn,
  collaborationFormsZh,
  collaborationMethodEn,
  collaborationMethodZh,
  collaborationPartnersEn,
  collaborationPartnersZh,
  siteMeta,
} from '../content/site';
---

<Layout title={`合作方式 | ${siteMeta.enName}`} description="Collaboration with Entia Futura Institut.">
  <main>
    <section class="hero-panel">
      <p class="eyebrow">Collaboration</p>
      <h1 class="hero-title-zh">合作方式</h1>
      <p class="hero-title-en">Collaboration</p>
    </section>
    <BilingualList zhTitle="我们合作的对象" enTitle="Who We Work With" zhItems={collaborationPartnersZh} enItems={collaborationPartnersEn} />
    <BilingualList zhTitle="合作形式" enTitle="Forms of Collaboration" zhItems={collaborationFormsZh} enItems={collaborationFormsEn} />
    <BilingualList zhTitle="我们的合作方法" enTitle="How We Work" zhItems={collaborationMethodZh} enItems={collaborationMethodEn} />
    <section class="section-card">
      <div class="section-heading">
        <h2>合作的理解</h2>
        <p>Collaboration</p>
      </div>
      <BilingualIntro
        zh="合作不是研究的妥协，而是研究进入现实的一种方式。"
        en="Collaboration is not a compromise of research, but one of the ways research enters reality."
      />
      <div class="cta-row">
        <a class="button primary" href="/contact">发起合作 / Start a Collaboration</a>
      </div>
    </section>
  </main>
</Layout>
