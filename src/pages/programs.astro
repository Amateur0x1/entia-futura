---
import BilingualCards from '../components/BilingualCards.astro';
import BilingualIntro from '../components/BilingualIntro.astro';
import Layout from '../layouts/Layout.astro';
import { programs, siteMeta } from '../content/site';
---

<Layout title={`项目机制 | ${siteMeta.enName}`} description="Programs of Entia Futura Institut.">
  <main>
    <section class="hero-panel">
      <p class="eyebrow">Programs</p>
      <h1 class="hero-title-zh">项目机制</h1>
      <p class="hero-title-en">Programs</p>
    </section>
    <section class="section-card">
      <div class="section-heading">
        <p class="eyebrow">Intro</p>
        <h2>项目机制</h2>
        <p>Programs</p>
      </div>
      <BilingualIntro
        zh="未来人研究所通过研究、活动、协作、驻留、社群与实验等多种机制展开工作，持续回应一个核心问题：未来我们将如何存在？"
        en="Entia Futura Institut works through research, public programs, collaboration, residencies, community structures, and experimentation, all organized around one core question: How shall we exist in the future?"
      />
    </section>
    <section class="section-card">
      <div class="section-heading">
        <h2>工作机制</h2>
        <p>Programs</p>
      </div>
      <BilingualCards items={programs} />
    </section>
  </main>
</Layout>
