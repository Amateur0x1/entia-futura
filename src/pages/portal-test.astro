---
import FuturePortal from '../components/FuturePortal.astro';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portal Test | Entia Futura</title>
    <meta name="description" content="Standalone portal scene test for Entia Futura." />
  </head>
  <body>
    <main class="portal-test-main">
      <section class="portal-hero" data-calibration-root>
        <div class="portal-frame" data-orbit-frame>
          <FuturePortal bare />
        </div>
      </section>
    </main>
  </body>
</html>

<style is:global>
  :root {
    color: #eef3ff;
    background: #02050c;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: #02050c;
  }

  body {
    overflow-x: hidden;
    overflow-y: hidden;
  }

  a {
    color: inherit;
  }
 </style>

<style>
  .portal-test-main {
    min-height: 100vh;
    background: #02050c;
  }

  .portal-hero {
    position: relative;
    height: 100vh;
    min-height: 100vh;
  }

  .portal-frame {
    position: relative;
    height: 100vh;
    min-height: 100vh;
    overflow: clip;
    isolation: isolate;
  }

  @media (max-width: 720px) {
    .portal-hero {
      height: 100vh;
      min-height: 100vh;
    }
  }
</style>
