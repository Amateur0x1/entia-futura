---
import BilingualCards from '../components/BilingualCards.astro';
import BilingualIntro from '../components/BilingualIntro.astro';
import BilingualList from '../components/BilingualList.astro';
import Layout from '../layouts/Layout.astro';
import {
  collaborationFormsEn,
  collaborationFormsZh,
  joinWaysEn,
  joinWaysZh,
  programs,
  researchAreas,
  siteMeta,
} from '../content/site';
---

<Layout title={`${siteMeta.zhName} | ${siteMeta.enName}`} description={siteMeta.oneLineEn}>
  <main>
    <section class="hero-panel">
      <p class="eyebrow">Home</p>
      <div class="dual-grid">
        <div>
          <h1 class="hero-title-zh">{siteMeta.zhName}</h1>
          <p class="hero-title-en">{siteMeta.enName}</p>
          <p class="hero-subtitle">{siteMeta.enSubtitle}</p>
          <div class="core-question">
            <strong>{siteMeta.coreQuestionZh}</strong>
            <strong>{siteMeta.coreQuestionEn}</strong>
          </div>
        </div>
        <div>
          <p class="lede">{siteMeta.oneLineZh}</p>
          <p class="lede" style="margin-top: 16px;">{siteMeta.oneLineEn}</p>
          <div class="cta-row">
            <a class="button primary" href="/about">了解我们 / About Us</a>
            <a class="button secondary" href="/research">研究方向 / Research</a>
            <a class="button secondary" href="/collaboration">发起合作 / Start a Collaboration</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-card">
      <div class="section-heading">
        <p class="eyebrow">About Entia Futura Institut</p>
        <h2>关于未来人研究所</h2>
        <p>About Entia Futura Institut</p>
      </div>
      <BilingualIntro
        zh="未来人研究所是一个围绕“未来我们将如何存在？”这一核心问题展开工作的独立研究机构。我们以高等研究为基础，同时强调研究向现实问题、合作机制、未来项目与社会实验的持续转化。我们关心的不只是技术将如何改变世界，更关心在技术剧变与社会重组的时代，我们将如何学习、工作、居住、连接、创造，并重新组织知识、空间与共同体。"
        en="Entia Futura Institut is an independent institute organized around the question: “How shall we exist in the future?” Grounded in advanced research, we are equally committed to the translation of inquiry into real-world problems, collaborative forms, future ventures, and social experimentation. We are concerned not only with how technology is changing the world, but with how, in a time of technological transformation and social reconfiguration, we shall learn, work, dwell, connect, create, and reorganize knowledge, space, and collective life."
      />
    </section>

    <section class="section-card">
      <div class="section-heading">
        <p class="eyebrow">What We Do</p>
        <h2>我们做什么</h2>
        <p>What We Do</p>
      </div>
      <BilingualCards
        items={[
          {
            zhTitle: '研究',
            enTitle: 'Research',
            zhBody: '围绕未来社会的重要议题展开长期研究、写作、访谈、观察、案例档案与公共讨论。',
            enBody:
              'Long-term inquiry, writing, interviews, observation, case archives, and public discussion around critical questions of future society.',
          },
          {
            zhTitle: '项目机制',
            enTitle: 'Programs',
            zhBody: '通过研究项目、公共活动、协作项目、驻留机制、社群结构与实验项目组织工作。',
            enBody:
              'Work organized through research programs, public programs, collaborative projects, residencies, community structures, and experimental initiatives.',
          },
          {
            zhTitle: '研究转化',
            enTitle: 'Research in Practice',
            zhBody: '让高等研究进入现实问题、组织实践、品牌叙事、空间场景与协作机制之中。',
            enBody:
              'Bringing advanced inquiry into real-world questions, organizational practice, narrative work, spaces, and collaborative structures.',
          },
          {
            zhTitle: '未来项目',
            enTitle: 'Future Ventures',
            zhBody: '从研究中发展项目、机制、原型与新的组织形式，测试未来社会的可能结构。',
            enBody:
              'Developing projects, mechanisms, prototypes, and new institutional forms out of inquiry to test possible futures.',
          },
        ]}
      />
    </section>

    <section class="section-card">
      <div class="section-heading">
        <p class="eyebrow">Research Areas</p>
        <h2>研究方向</h2>
        <p>Research Areas</p>
      </div>
      <BilingualCards items={researchAreas} />
      <div class="cta-row">
        <a class="button secondary" href="/research">查看全部研究方向 / View All Research Areas</a>
      </div>
    </section>

    <section class="section-card">
      <div class="section-heading">
        <p class="eyebrow">Collaboration</p>
        <h2>合作方式</h2>
        <p>Collaboration</p>
      </div>
      <BilingualIntro
        zh="我们欢迎与企业、品牌、地方项目、文化空间、书店、学校及各类组织与个人展开合作。我们理解的合作，不只是项目执行，而是把研究能力、问题意识与现实场景连接起来。"
        en="We welcome collaboration with enterprises, brands, place-based initiatives, cultural spaces, bookstores, schools, and a wide range of organizations and individuals. For us, collaboration is not merely execution, but a way of connecting research capacity, problem-consciousness, and real-world settings."
      />
      <div class="cta-row">
        <a class="button primary" href="/collaboration">发起合作 / Start a Collaboration</a>
      </div>
    </section>

    <section class="section-card">
      <div class="section-heading">
        <p class="eyebrow">Join Us</p>
        <h2>加入我们</h2>
        <p>Join Us</p>
      </div>
      <BilingualIntro
        zh="未来人研究所欢迎所有认真对待未来问题的人。加入研究所不一定意味着固定身份，它也可以意味着参与讨论、加入计划、共创项目、提交提案，或在某个阶段与研究所共同工作。"
        en="Entia Futura Institut welcomes all those who take the future seriously. Joining the institute does not necessarily mean entering a fixed role; it may mean entering a discussion, joining a program, co-creating a project, submitting a proposal, or working alongside the institute for a certain period of time."
      />
      <div class="cta-row">
        <a class="button secondary" href="/join-us">了解参与方式 / Learn How to Participate</a>
      </div>
    </section>

    <BilingualList zhTitle="合作形式" enTitle="Forms of Collaboration" zhItems={collaborationFormsZh} enItems={collaborationFormsEn} />
    <BilingualList zhTitle="参与方式" enTitle="Ways to Participate" zhItems={joinWaysZh} enItems={joinWaysEn} />

    <section class="hero-panel">
      <p class="lede">未来人研究所关心的，不是技术能够替代什么，而是未来我们将如何存在。</p>
      <p class="lede" style="margin-top: 12px;">What concerns Entia Futura Institut is not what technology may replace, but this: How shall we exist in the future?</p>
    </section>
  </main>
</Layout>
